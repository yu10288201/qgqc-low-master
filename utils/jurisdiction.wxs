/* 权限统一处理
 * 权限判断
 * 2020.12.24 扬衡
 */

var filters = {
  judge: function (value,object) {
    if(object.indexOf(value) != -1){
      return false;
    }else if(value == -1){
      return false;
    }
    return true;
  },
  convert: function (value){
    if(value == "标单"){
      return '30';
    }else if(value == "补单"){
      return '31';
    }else if(value == "赠送"){
      return '32';
    }else if(value == "加急"){
      return '33';
    }else if(value == "催单"){
      return '34';
    }else if(value == "分席"){
      return '39';
    }else{
      return -1;
    }
  }
}
module.exports = {
  judge: filters.judge,
  convert: filters.convert
}