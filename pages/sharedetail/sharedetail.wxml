<view class='content'  style="margin-left: 0"> 
  <view class='text1' style="font-size:40rpx;color:rgb(3,82,86);margin:25rpx 0rpx">{{shareList[0].shopName}} </view>
  <!-- <view class='text'>推荐理由:</view> -->
</view>
<view style="width:100%;display:flex;justify-content:center;align-items:center">
<image class='image' src='{{shareList[0].bigDishesImg}}' wx:if="{{image==undefined}}"></image>
<image class='image' src='{{image}}' wx:else></image>
</view>

<view class='content' style="justify-content:space-around;margin: 20rpx 0rpx;"> 
  <view class='text1'>菜品名称：{{shareList[0].dishesName}} </view>
  <view class='text1'>菜品价格：{{shareList[0].itemPrice}}元/{{shareList[0].dishesMeteringType}}</view>
  <!-- <view class='text'>推荐理由:</view> -->
</view>
<view class='go-center' style='width:100%'>
  <view class='chooseimage' bindtap='chooseimage'>拍照</view>
</view>

<view style="background-color: rgb(242,250,248);padding: 15rpx;margin-top:20rpx">
  <view style='font-size:28rpx;margin-left:40rpx'>推荐理由：输入你要转达的内容</view>
  <view class='content go-center'>
    <textarea style='font-size:28rpx;background:#ffffff;margin:20rpx;border: 1rpx solid rgb(53,156,112);' bindblur='getcontent'>{{old_sharetitle}}</textarea>
  </view>
  </view>

<button class='btn' open-type="share" style='margin-top:20rpx;' type='primary' disabled="{{disabled}}">发送给朋友</button>
 <view style="display:flex;width:100%;justify-content: center;margin-top: 40rpx;">
    <image style="width:60%;height:105rpx" src='https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/treat/bg.png'></image>
  </view>