<view style="width: 100vw;height: 100vh;display: flex;flex-direction: column;">
  <view style="margin: 10rpx;display: flex;flex-direction: column;border: #ccc 1rpx solid;border-radius: 10rpx;font-size: 28rpx;">
      <view style="display: flex;flex-direction: row;align-items: center;margin-top: 20rpx;margin-left: 20rpx;">
        <view>姓名：</view><input model:value="{{name}}"  style="width: 400rpx;border: 1rpx solid #f2f2f2;"/>
      </view>
      <view style="display: flex;flex-direction: row;align-items: center;margin-top: 20rpx;margin-bottom: 20rpx;margin-left: 20rpx;">
        <view>备注：</view><input model:value="{{remark}}" style="width: 400rpx;border: 1rpx solid #f2f2f2;"/>
        <view bind:tap="queryClick" style="background-color: #ccc;padding: 5rpx 30rpx;border-radius: 30rpx;background-color: #52A76E;color: #fff;margin-left: 20rpx;">查询</view>
      </view > 
    </view>
    <scroll-view style="flex: 1;width: 100%;overflow: auto;" scroll-y="true" bindscrolltolower="loadNextPage" scroll-top='{{scrollTop}}'>

        <view wx:if="{{person_array.length==0}}" style="width: 100;text-align: center;margin-top: 50rpx;color: #fff;font-size: 30rpx;display: flex;flex-direction: row;align-items: center;justify-content: center;">
              <view style="border:#f2f2f2 solid 1rpx; border-radius: 20rpx;padding: 10rpx 40rpx;background-color: rgba(0, 0, 0, 0.7);">
                无结果
              </view>
          </view>

          <view style="display: grid;grid-template-columns: repeat(2,1fr);gap:10rpx;margin: 10rpx;box-sizing: border-box;">
          <view  wx:for="{{person_array}}" wx:key="{{index}}" >
            <view style="width: 100%;background-color: #f2f2f2;display: flex;flex-direction: column;align-items: center;border:#ccc 1rpx solid;border-radius: 10rpx;position: relative;">
              <image bind:tap="toOutfit" data-img_url="{{item.img_url}}" data-name="{{item.name}}" style="width: 100%;height: 750rpx;" mode="aspectFill" src="{{item.img_url}}">
                
              </image>
              <view data-index="{{index}}" data-name="{{item.name}}" bind:tap="personDialogShowShow" style="position: absolute;font-size: 28rpx;bottom: 10rpx;background-color: rgba(0,0,0,0.5);color: #fff;padding: 5rpx 30rpx;border-radius: 10rpx;">{{item.name}}</view>
              <view data-index="{{index}}" bind:tap="mallOutfitPersonDeleteMallOutfitPersonClick" style="background-color: #ccc;padding: 5rpx 30rpx;border-radius: 30rpx;background-color:red;color: #fff;position: absolute;font-size: 26rpx;right:10rpx;top: 10rpx;">删除</view>
            </view>
              
          </view>
        
        </view>
    </scroll-view>
    
</view>



<view style="position: fixed;right: 0;left: 0;top:500rpx;margin: auto;height: 220rpx;width: 500rpx;background-color: #FFF;border-radius: 12px;display: flex;flex-direction: column;justify-content: center;align-items: center;z-index: 9999999;background-color: #ccc;border: #ccc 1rpx solid;" wx:if="{{personDialogShow==true}}">
 
 <view style="font-size: larger;padding: 0rpx;color: rgb(134,76,2);font-weight: 900;">设为默认人像</view>
 <view  catch:tap="personDialogShowChange" class="badgecontent-close"  >X</view>
 <view style="display: flex;flex-direction: column;justify-content: center;width: 100%;align-items: center;flex: 1;background-color: #fff;overflow: hidden;border-bottom-left-radius: 12rpx;border-bottom-right-radius: 12rpx;">
    <view style="width: 100%;margin-left:60rpx;font-size: 28rpx;display: flex;align-items: center;">姓名：<text style="font-size: 25rpx;">{{tmp_name}}</text></view>
  </view>
  <view style="display: flex;flex-direction: column;justify-content: center;width: 100%;align-items: center;flex: 1;background-color: #fff;overflow: hidden;border-bottom-left-radius: 12rpx;border-bottom-right-radius: 12rpx;">
    <view bind:tap="isDefaultTap"  style="display: flex;flex-direction: row;align-items: center;justify-content: flex-start;width: 100%;font-size: 28rpx;">
        <image wx:if="{{is_default==0}}" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_not_select_img}}"></image>
        <image wx:if="{{is_default==1}}" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_select_img}}"></image>
        设为默认人像
  </view>



  <view style="width: 100%;display: flex;flex-direction: row;align-items: center;justify-content: flex-end;">
        <view catch:tap="mallOutfitPersonUpdateMallOutfitPersonSetIsDefault" style="margin-top: 0rpx;margin-bottom: 10rpx;background-color: #52A76E;color: white;padding: 1rpx 20rpx;border-radius: 12rpx;font-size: 28rpx;display: flex;flex-direction: row;align-items: center;justify-content: center;margin-right: 30rpx;">
          保存
      </view>
  </view>
  
  </view>
</view>