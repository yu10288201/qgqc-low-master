page {
  background-color: #fff;
  padding: 0;
  margin: 0;
}

.container {
  min-height: 100vh;
  background-color: #fff;
  padding: 0;
  margin: 0;
}

.card {
  width: 100%;
  background-color: #fff;
  border-radius: 0;
  padding: 30rpx 30rpx;
  box-sizing: border-box;
  margin-top: 0;
}

.form-card-label-plain {
  font-size: 33rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
  gap: 8rpx;
}

.form-col {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.form-col-auto {
  flex: none;
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-right: 20rpx;
}

.form-col-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  white-space: nowrap;
  font-weight: bold;
}

.form-col-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 2rpx 8rpx;
  min-width: 150rpx;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  box-sizing: border-box;
  height: 36rpx;
  line-height: 36rpx;
}

.form-col-input-sm {
  font-size: 28rpx;
  color: #333;
  padding: 2rpx 8rpx;
  width: 100rpx;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  box-sizing: border-box;
  height: 36rpx;
  line-height: 36rpx;
}

.occ-input {
  min-width: 0;
  width: 120rpx;
}

.talent-input {
  width: 200rpx;
}

.picker-inline {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  padding: 6rpx 16rpx;
  height: 44rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 30rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.required::before {
  content: '*';
  color: #f3333e;
  margin-right: 4rpx;
}

.form-item-col {
  display: flex;
  flex-direction: column;
  padding: 16rpx 0;
}

.intro-textarea {
  width: 95%;
  height: 240rpx;
  font-size: 28rpx;
  color: #333;
  padding: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin: 12rpx 2.5% 0;
  line-height: 1.6;
}

.submit-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 30rpx 0 10rpx;
}

.submit-btn {
  background-color: #52A76E;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 44rpx;
  border-radius: 50rpx;
}

.submit-btn.disabled {
  background-color: #ccc;
}

.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.form-label-sm {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  white-space: nowrap;
  font-weight: bold;
  margin-left: 20rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 2rpx 8rpx;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  box-sizing: border-box;
  height: 36rpx;
  line-height: 36rpx;
}

.upload-square {
  width: 100rpx;
  height: 60rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  overflow: visible;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.upload-preview {
  width: 100rpx;
  height: 60rpx;
  border-radius: 12rpx;
}

.upload-delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 27rpx;
  line-height: 36rpx;
  text-align: center;
  z-index: 10;
}

.upload-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.upload-icon {
  font-size: 40rpx;
  color: #ccc;
}

.upload-loading {
  font-size: 22rpx;
  color: #aaa;
}
