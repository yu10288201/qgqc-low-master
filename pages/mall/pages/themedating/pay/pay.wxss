page {
  background-color: #f5f5f5;
}

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 金额展示块 */
.amount-block {
  background-color: #52A76E;
  padding: 60rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.amount-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 16rpx;
}

.amount-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
}

/* 卡片 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  margin: 20rpx 30rpx 0;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #52A76E;
}

/* 信息行 */
.info-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-key {
  font-size: 28rpx;
  color: #777;
  flex-shrink: 0;
  white-space: nowrap;
}

.info-val {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 支付方式 */
.pay-method {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
}

.pay-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background-color: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.wechat-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.pay-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.pay-selected {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: #52A76E;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-check {
  font-size: 24rpx;
  color: #fff;
  line-height: 44rpx;
  text-align: center;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.pay-btn {
  background-color: #07C160;
  border-radius: 50rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
