<view class="container">

  <!-- 金额展示 -->
  <view class="amount-block">
    <text class="amount-label">支付金额</text>
    <text class="amount-value">¥{{amount}}</text>
  </view>

  <!-- 订单信息 -->
  <view class="card">
    <view class="card-title">订单信息</view>
    <view class="info-row">
      <text class="info-key">活动名称：</text>
      <text class="info-val">{{activityName}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">活动编号：</text>
      <text class="info-val">{{activityNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">报名姓名：</text>
      <text class="info-val">{{signupName}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">联系电话：</text>
      <text class="info-val">{{signupPhone}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="card">
    <view class="card-title">支付方式</view>
    <view class="pay-method">
      <view class="pay-icon-wrap">
        <text class="wechat-icon">微</text>
      </view>
      <text class="pay-name">微信支付</text>
      <view class="pay-selected">
        <text class="pay-check">✓</text>
      </view>
    </view>
  </view>

  <!-- 底部支付按钮 -->
  <view class="bottom-bar">
    <view class="pay-btn" bindtap="onPay">
      <text class="pay-btn-text">确认支付 ¥{{amount}}</text>
    </view>
  </view>

</view>
