<view class="container">
  <!-- 固定头部：搜索面板 -->
  <view class="sticky-header" id="sticky-header">

    <!-- 搜索区 -->
    <view class="search-panel">
      <!-- 活动名称 -->
      <view class="search-row">
        <text class="search-label">活动名称：</text>
        <scroll-view scroll-x class="readonly-scroll">
          <text class="readonly-text">{{searchTitle || '暂无'}}</text>
        </scroll-view>
      </view>

      <!-- 活动地点 -->
      <view class="search-row">
        <text class="search-label">活动地点：</text>
        <scroll-view scroll-x class="readonly-scroll">
          <text class="readonly-text">{{searchLocation || '暂无'}}</text>
        </scroll-view>
      </view>

      <!-- 活动时间 -->
      <view class="search-row">
        <text class="search-label">活动时间：</text>
        <scroll-view scroll-x class="readonly-scroll">
          <text class="readonly-text">{{searchDateStart || '暂无'}}{{searchDateEnd ? ' - ' + searchDateEnd : ''}}</text>
        </scroll-view>
      </view>

      <!-- 活动类型 -->
      <view class="search-row">
        <text class="search-label">活动类型：</text>
        <scroll-view scroll-x class="readonly-scroll">
          <text class="readonly-text">{{activityType == 1 ? 'KTV' : activityType == 2 ? '旅游' : activityType == 3 ? '美食' : '暂无'}}</text>
        </scroll-view>
      </view>

      <!-- 活动费用 -->
      <view class="search-row">
        <text class="search-label">活动费用：</text>
        <scroll-view scroll-x class="readonly-scroll" style="flex:1;min-width:0;">
          <text class="readonly-text">男性:{{priceMale}}元 女性:{{priceFemale}}元</text>
        </scroll-view>
        <view class="search-btn" style="margin-left:16rpx;" bindtap="onSearch">活动列表</view>
      </view>
    </view>
  </view>

  <!-- 内容区 -->
  <view style="padding-top: {{headerHeight}}px; width: 100%; box-sizing: border-box;">

      <!-- 报名表单 -->
      <view wx:if="{{showForm}}" class="form-container">
        <!-- 报名信息 -->
        <view class="card">
          <view class="form-card-label-plain" style="margin-left: 20rpx;">报名信息</view>
          <!-- 姓名编号 姓名 同一行 -->
          <view class="form-row" style="margin-left: 14rpx;">
            <view class="form-col-auto" style="flex: none;">
              <text class="form-col-label">姓名编号：</text>
              <text class="form-col-input" style="width:60rpx;min-width:0;">{{nextNo || '—'}}</text>
            </view>
            <view class="form-col-auto" style="flex: none; margin-left:-8rpx;">
              <text class="form-col-label required">姓名：</text>
              <input class="form-col-input" placeholder="请输入" data-field="signupName" bindinput="onInput" value="{{signupName}}" style="width: 115rpx;" />
            </view>
          </view>
          <!-- 昵称 单独一行 -->
          <view class="form-row" style="margin-left: 14rpx;">
            <view class="form-col-auto" style="flex: none;">
              <text class="form-col-label">昵称：</text>
              <input style="width:200rpx; font-size:28rpx; color:#333; padding:4rpx 8rpx; border:1rpx solid #999; border-radius:12rpx; box-sizing:border-box;" placeholder="选填" data-field="nickname" bindinput="onInput" value="{{nickname}}" />
            </view>
          </view>
          <!-- 性别 年龄 同一行 -->
          <view class="form-row">
            <view class="form-col-auto" style="width: 140rpx; margin-left: 0rpx;">
              <text class="form-col-label required">性别：</text>
              <picker mode="selector" range="{{['男','女']}}" value="{{signupGender - 1}}" bindchange="onGenderChange">
                <view class="picker-inline" style="border: 1rpx solid #999; border-radius: 12rpx; padding: 2rpx 8rpx;">
                  <text>{{signupGender === 1 ? '男' : '女'}}</text>
                  <text class="picker-arrow">▼</text>
                </view>
              </picker>
            </view>
            <view class="form-col" style="flex: none; margin-left: 40rpx;">
              <text class="form-col-label required">年龄：</text>
              <input class="form-col-input" placeholder="年龄" data-field="signupAge" bindinput="onInput" value="{{signupAge}}" type="number" maxlength="3" style="width: 85rpx; min-width: 0; flex: none;" />
            </view>
            <view class="form-col-auto" style="margin-left: 20rpx;">
              <text class="form-col-label">婚姻状况：</text>
              <picker mode="selector" range="{{['未婚','离异','已婚']}}" value="{{maritalStatus - 1}}" bindchange="onMaritalChange">
                <view class="picker-inline" style="border: 1rpx solid #999; border-radius: 12rpx; padding: 2rpx 6rpx; min-width: 80rpx;">
                  <text>{{maritalStatus === 1 ? '未婚' : maritalStatus === 2 ? '离异' : maritalStatus === 3 ? '已婚' : '选填'}}</text>
                  <text class="picker-arrow">▼</text>
                </view>
              </picker>
            </view>
          </view>
          <!-- 手机号 才艺 同一行 -->
          <view class="form-row">
            <view class="form-col-auto" style="margin-left: 0rpx;">
              <text class="form-col-label required">手机号：</text>
              <input class="form-col-input" placeholder="请输入手机号" data-field="signupPhone" bindinput="onInput" value="{{signupPhone}}" type="number" maxlength="11" style="width: 240rpx;" />
            </view>
            <view class="form-col-auto">
              <text class="form-col-label">才艺：</text>
              <input class="form-col-input occ-input talent-input" placeholder="选填" data-field="talent" bindinput="onInput" value="{{talent}}" />
            </view>
          </view>
          <!-- 职业 学历 同一行 -->
          <view class="form-row">
            <view class="form-col-auto" style="margin-left: 14rpx;">
              <text class="form-col-label">职业：</text>
              <input class="form-col-input occ-input" placeholder="选填" data-field="occupation" bindinput="onInput" value="{{occupation}}" />
            </view>
            <view class="form-col-auto">
              <text class="form-col-label">学历：</text>
              <picker mode="selector" range="{{educationList}}" value="{{educationIndex}}" bindchange="onEducationChange">
                <view class="occ-input picker-inline" style="border: 1rpx solid #999; border-radius: 12rpx; padding: 2rpx 8rpx;">
                  <text>{{educationList[educationIndex] || '选填'}}</text>
                  <text class="picker-arrow">▼</text>
                </view>
              </picker>
            </view>
          </view>
          <!-- 身份证信息（旅游类型必填） -->
          <block wx:if="{{activityType == 2}}">
            <!-- 身份证号 -->
            <view class="form-item">
              <text class="form-label-sm required">身份证号：</text>
              <input class="form-input" placeholder="请输入身份证号" data-field="idCardNo" bindinput="onInput" value="{{idCardNo}}" maxlength="18" />
            </view>
            <!-- 身份证人像页面 -->
            <view class="form-item">
              <text class="form-label-sm required">身份证人像面：</text>
              <view class="upload-square" bindtap="uploadIdCardFront">
                <view wx:if="{{uploadingFront}}" class="upload-loading">上传中...</view>
                <block wx:elif="{{idCardFrontImg}}">
                  <image src="{{idCardFrontImg}}" class="upload-preview" mode="aspectFill" catchtap="previewFront" />
                  <view class="upload-delete" catchtap="deleteIdCardFront">×</view>
                </block>
                <view wx:else class="upload-placeholder">
                  <text class="upload-icon">+</text>
                </view>
              </view>
            </view>
            <!-- 身份证国徽图片 -->
            <view class="form-item">
              <text class="form-label-sm required">身份证国徽面：</text>
              <view class="upload-square" bindtap="uploadIdCardBack">
                <view wx:if="{{uploadingBack}}" class="upload-loading">上传中...</view>
                <block wx:elif="{{idCardBackImg}}">
                  <image src="{{idCardBackImg}}" class="upload-preview" mode="aspectFill" catchtap="previewBack" />
                  <view class="upload-delete" catchtap="deleteIdCardBack">×</view>
                </block>
                <view wx:else class="upload-placeholder">
                  <text class="upload-icon">+</text>
                </view>
              </view>
            </view>
          </block>
          <!-- 头像上传 -->
          <view class="form-item" style="margin-left: 14rpx;">
            <text style="font-size:28rpx; color:#333; font-weight:bold; white-space:nowrap; flex-shrink:0; margin-left:4rpx;">头像上传：</text>
            <view class="upload-square" bindtap="uploadAvatar">
              <view wx:if="{{uploadingAvatar}}" class="upload-loading">上传中...</view>
              <block wx:elif="{{avatarPhoto}}">
                <image src="{{avatarPhoto}}" class="upload-preview" mode="aspectFill" catchtap="previewAvatar" />
                <view class="upload-delete" catchtap="deleteAvatar">×</view>
              </block>
              <view wx:else class="upload-placeholder">
                <text class="upload-icon">+</text>
              </view>
            </view>
          </view>
          <!-- 自我简介独占一列 -->
          <view class="form-item-col">
            <view style="display:flex;flex-direction:row;align-items:center;justify-content:space-between;margin-left:20rpx;margin-right:10rpx;">
              <text class="form-label-sm">自我简介：</text>
              <view class="action-btn" style="font-size:24rpx;padding:6rpx 24rpx;" bindtap="fetchLatestIntro">选用原有</view>
            </view>
            <textarea class="intro-textarea" style="font-size:28rpx;" placeholder="简单介绍自己（选填）" placeholder-style="font-size:28rpx;" data-field="selfIntro" bindinput="onInput" value="{{selfIntro}}" maxlength="200" />
          </view>
          <!-- 备注 -->
          <view class="form-item-col">
            <text class="form-label-sm" style="margin-left: 20rpx;">备注：</text>
            <textarea class="intro-textarea" style="font-size:28rpx;" placeholder="备注信息（选填）" placeholder-style="font-size:28rpx;" data-field="remark" bindinput="onInput" value="{{remark}}" maxlength="200" />
          </view>
          <!-- 活动规则 -->
          <view wx:if="{{activityRule}}" class="form-item-col">
            <text class="form-label-sm section-title" style="margin-left: 20rpx;">活动规则：</text>
            <scroll-view scroll-y class="rule-scroll">
              <text class="rule-content">{{activityRule}}</text>
            </scroll-view>
          </view>
        </view>

        <!-- 底部提交 -->
        <view class="bottom-bar" wx:if="{{showForm}}">
          <view class="agree-row" bindtap="toggleAgree">
            <view class="agree-box {{agreed ? 'agreed' : ''}}">
              <text wx:if="{{agreed}}" class="agree-check">✓</text>
            </view>
            <text class="agree-text">我已阅读并同意<text class="agree-link">《该服务协议》</text></text>
          </view>
          <view style="display:flex;flex-direction:row;align-items:center;justify-content:center;width:100%;">
            <view style="position:absolute; left:40rpx; background-color:#52A76E; font-size:25rpx; padding:10rpx 40rpx; border-radius:30rpx; font-weight:bold; color:#fff;" bindtap="goDetail">活动详情</view>
            <view class="submit-btn {{agreed ? '' : 'disabled'}}" bindtap="onSubmit">报名提交</view>
            <view class="pay-btn" bindtap="onToPay">支付</view>
          </view>
        </view>
      </view>

      <!-- 活动卡片列表 -->
      <view wx:else class="tab-content">
        <view wx:if="{{activityList.length > 0}}">
          <view class="activity-card" wx:for="{{activityList}}" wx:key="id">
            <view class="card-row">
              <text class="card-label">活动名称：</text>
              <text class="card-text">{{item.title}}</text>
            </view>
            <view class="card-row">
              <text class="card-label">活动地点：</text>
              <scroll-view scroll-x class="card-scroll">
                <text class="card-scroll-text">{{item.location || '地点待定'}}</text>
              </scroll-view>
            </view>
            <view class="card-row">
              <text class="card-label">活动时间：</text>
              <scroll-view scroll-x class="card-scroll" style="min-width:0;">
                <text class="card-scroll-text">{{item.activityDateStart || '时间待定'}}{{item.activityDateEnd ? ' - ' + item.activityDateEnd : ''}}</text>
              </scroll-view>
            </view>
            <view class="card-row">
              <text class="card-label">活动类型：</text>
              <text class="card-text">{{item.activityType == 1 ? 'KTV' : item.activityType == 2 ? '旅游' : item.activityType == 3 ? '美食' : '暂无'}}</text>
            </view>
            <view class="card-row">
              <text class="card-label">活动费用：</text>
              <text class="card-text">男性:{{item.priceMale}}元 女性:{{item.priceFemale}}元</text>
              <view class="btn-select {{selectedActivityId == item.id ? 'btn-select-active' : 'btn-select-inactive'}}" bindtap="onSelectActivity" data-item="{{item}}">✓</view>
            </view>
          </view>
          <view wx:if="{{activityLoading}}" class="list-loading">加载中...</view>
          <view wx:elif="{{activityList && activityList.length >= activityTotal && activityTotal > 0}}" class="list-end">没有更多了</view>
        </view>
        <view wx:elif="{{activityLoading}}" class="empty-tip">加载中...</view>
        <view wx:else class="empty-tip">暂无活动</view>
      </view>

  </view>
</view>
