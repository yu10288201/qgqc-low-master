page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

/* 固定头部 */
.sticky-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background-color: #eed6ba;
  width: 100%;
  box-sizing: border-box;
}

/* 表单模式下头部不固定 */
.normal-header {
  position: relative;
  background-color: #eed6ba;
  width: 100%;
  box-sizing: border-box;
}

/* tab 栏靠左 */
.tab-bar {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
}

.tab-item {
font-size: 29rpx;
  color: #777;
  padding: 24rpx 40rpx;
}

.tab-item.active {
  color: #52A76E;
  font-weight: bold;
  border-bottom: 4rpx solid #52A76E;
}

/* 搜索面板 */
.search-panel {
  background-color: #eed6ba;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
}

.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 4rpx 0;
}


.search-label {
font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  font-weight: bold;
  white-space: nowrap;
}

.search-input {
  flex: 1;
font-size: 28rpx;
  color: #333;
}

.search-btn {
font-size: 25rpx;
  color: #fff;
  background-color: #52A76E;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
  font-weight: bold;
}

.readonly-scroll {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  min-width: 0;
}

.readonly-text {
font-size: 28rpx;
  color: #333;
  white-space: nowrap;
}

.search-btn-row {
  padding: 12rpx 0;
  display: flex;
  justify-content: flex-end;
}

.search-btn-full {
font-size: 27rpx;
  color: #fff;
  background-color: #52A76E;
  padding: 12rpx 0;
  border-radius: 30rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.date-picker-val {
font-size: 28rpx;
  color: #333;
}

.placeholder-text {
  color: #777;
}

.date-sep {
font-size: 27rpx;
  color: #aaa;
  margin: 0 4rpx;
  flex-shrink: 0;
}

.price-val {
font-size: 29rpx;
  color: #333;
  width: 120rpx;
}

/* 内容区 — 不需要 padding-top，sticky-header 不占文档流 */
.tab-content {
  padding: 0 0 40rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 活动卡片 */
.activity-card {
  background-color: #fff;
  border-radius: 0;
  margin: 0 0 12rpx;
  padding: 14rpx 24rpx;
  box-shadow: none;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
}

.card-header {
  margin-bottom: 16rpx;
}

.card-title {
font-size: 37rpx;
  font-weight: bold;
  color: #222;
}

.card-actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-detail {
font-size: 29rpx;
  color: #52A76E;
  border: 1rpx solid #52A76E;
  border-radius: 30rpx;
  padding: 8rpx 28rpx;
}

.btn-signup {
font-size: 29rpx;
  color: #fff;
  background-color: #52A76E;
  border-radius: 30rpx;
  padding: 8rpx 28rpx;
}

.card-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 8rpx;
}

.card-label {
font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  font-weight: bold;
}

.card-text {
font-size: 28rpx;
  color: #333;
  flex: 1;
}

.card-scroll {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
}

.card-scroll-text {
font-size: 28rpx;
  color: #333;
  white-space: nowrap;
  display: inline-block;
}

.card-text-scroll {
font-size: 33rpx;
  color: #333;
  flex: 1;
  overflow-x: scroll;
  white-space: nowrap;
}

.card-title {
font-size: 35rpx;
  font-weight: bold;
  color: #222;
}

.price-text {
  color: #f3333e;
  font-weight: bold;
}

/* 我的报名卡片 */
.my-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
}

.my-card-title {
font-size: 31rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #52A76E;
}

.empty-tip {
  text-align: center;
  color: #aaa;
font-size: 27rpx;
  margin-top: 100rpx;
}

.list-end {
  text-align: center;
  color: #ccc;
font-size: 23rpx;
  padding: 30rpx 0;
}

.list-loading {
  text-align: center;
  color: #aaa;
font-size: 23rpx;
  padding: 20rpx 0;
}

.btn-pay {
font-size: 29rpx;
  color: #fff;
  background-color: #07C160;
  border-radius: 30rpx;
  padding: 8rpx 28rpx;
}

.btn-select {
font-size: 23rpx;
  border-radius: 50%;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.btn-select-active {
  color: #fff;
  background-color: #52A76E;
}

.btn-select-inactive {
  color: #ccc;
  background-color: #fff;
  border: 2rpx solid #ccc;
}

/* 报名表单 */
.form-container {
  padding: 0 0 160rpx;
  margin-top: 20rpx;
}

.card {
  width: 100%;
  margin: 0;
  background-color: #fff;
  border-radius: 0;
  padding: 30rpx 30rpx;
  box-shadow: none;
  box-sizing: border-box;
}

.form-card-label {
font-size: 29rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #52A76E;
}

.form-card-label-plain {
font-size: 33rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.section-title {
font-size: 33rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.form-item-col {
  display: flex;
  flex-direction: column;
  padding: 20rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.form-item-col:last-child {
  border-bottom: none;
}

.upload-btn-rect {
font-size: 27rpx;
  color: #fff;
  background-color: #52A76E;
  padding: 10rpx 30rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.upload-preview-row {
  padding: 10rpx 0 10rpx 20rpx;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.upload-square-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}
.upload-square {
  width: 120rpx;
  height: 60rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  overflow: visible;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  align-self: center;
}

.upload-delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
font-size: 27rpx;
  line-height: 36rpx;
  text-align: center;
  z-index: 10;
}

.intro-textarea {
  width: 95%;
  height: 160rpx;
font-size: 28rpx;
  color: #333;
  padding: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin: 12rpx 2.5% 0;
  line-height: 1.6;
}

.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 4rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0 8rpx 4rpx;
  border-bottom: 0.5rpx solid #f0f0f0;
  gap: 8rpx;
}

.form-col {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.form-col-auto {
  flex: none;
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-right: 20rpx;
}

.form-col-label {
font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  white-space: nowrap;
  font-weight: bold;
}

.form-col-input {
  flex: 1;
font-size: 28rpx;
  color: #333;
  padding: 4rpx 8rpx;
  min-width: 150rpx;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.occ-input {
  min-width: 0;
  width: 120rpx;
}

.talent-input {
  width: 200rpx;
}

.form-label {
font-size: 28rpx;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
  white-space: nowrap;
  font-weight: bold;
}

.form-label-sm {
font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  white-space: nowrap;
  font-weight: bold;
}

.form-input {
  flex: 1;
font-size: 28rpx;
  color: #333;
  padding: 4rpx 8rpx;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.form-textarea {
  flex: 1;
font-size: 27rpx;
  color: #333;
  height: 120rpx;
  padding: 10rpx 0;
}

.picker-inline {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 30rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.required::before {
  content: '*';
  color: #f3333e;
}

.upload-row {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-top: 20rpx;
}

.upload-item {
  flex: 1;
  height: 180rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
font-size: 55rpx;
  color: #ccc;
  line-height: 1;
}

.upload-tip {
font-size: 21rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.upload-loading {
font-size: 23rpx;
  color: #52A76E;
}

.upload-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.avatar-row {
  align-items: flex-start;
}

.upload-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 2rpx dashed #ccc;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.intro-item {
  align-items: flex-start;
  padding-top: 20rpx;
}

.rule-scroll {
  height: 240rpx;
  width: 95%;
  margin: 8rpx 2.5% 0;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.rule-content {
  display: block;
font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  word-break: break-all;
  white-space: pre-wrap;
  padding: 12rpx;
  box-sizing: border-box;
}

.agree-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin: 10rpx 3%;
  padding: 10rpx 0;
}

.agree-box {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 2rpx solid #ccc;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.agree-box.agreed {
  background-color: #52A76E;
  border-color: #52A76E;
}

.agree-check {
  color: #fff;
font-size: 23rpx;
}

.agree-text {
font-size: 25rpx;
  color: #777;
}

.agree-link {
  color: #52A76E;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.submit-btn {
  background-color: #52A76E;
  color: #fff;
font-size: 28rpx;
  font-weight: bold;
  padding: 14rpx 44rpx;
  border-radius: 50rpx;
}

.pay-btn {
  position: absolute;
  right: 40rpx;
  background-color: #52A76E;
font-size: 25rpx;
  padding: 10rpx 40rpx;
  border-radius: 30rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
  text-indent: 8rpx;
}

.submit-btn.disabled {
  background-color: #ccc;
}

.action-btn {
  background-color: #52A76E;
  font-size: 25rpx;
  padding: 10rpx 40rpx;
  border-radius: 30rpx;
  font-weight: bold;
  color: #fff;
}
