page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.card {
  width: 100%;
  background-color: #fff;
  border-radius: 0;
  padding: 30rpx 30rpx;
  box-sizing: border-box;
  margin-top: 0;
}

.form-card-label-plain {
  font-size: 33rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.info-row-col {
  display: flex;
  flex-direction: column;
  padding: 10rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.info-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex-shrink: 0;
  white-space: nowrap;
  margin-left: 20rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.info-scroll {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
}

.info-scroll-text {
  font-size: 28rpx;
  color: #333;
  white-space: nowrap;
  display: inline-block;
}

.info-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin: 8rpx 20rpx 0;
}

.submit-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 40rpx 0 10rpx;
}

.submit-btn {
  background-color: #f3333e;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 44rpx;
  border-radius: 50rpx;
}

.submit-btn.disabled {
  background-color: #ccc;
}
