page {
    background-color: #f5f5f5;
  }
  
  .container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background-color: #f5f5f5;
    margin: 0;
    padding: 0 0 160rpx;
    box-sizing: border-box;
  }

.header {
  width: 100%;
  background-color: #52A76E;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 10rpx;
}

.reward-card {
  width: 94%;
  margin: 20rpx 3%;
  background-color: #52A76E;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 4rpx 20rpx rgba(82,167,110,0.35);
}

.reward-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.reward-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.reward-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.reward-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255,255,255,0.35);
}

.card {
  width: 94%;
  margin: 20rpx 3%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.card-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #52A76E;
}

.rule-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.rule-step {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #52A76E;
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  text-align: center;
  line-height: 48rpx;
}

.rule-text {
  font-size: 28rpx;
  color: #555;
  flex: 1;
}

.rule-tip {
  font-size: 26rpx;
  color: #999;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  margin-top: 10rpx;
}

.highlight {
  color: #f3333e;
  font-weight: bold;
  font-size: 30rpx;
}

.empty-tip {
  text-align: center;
  font-size: 28rpx;
  color: #bbb;
  padding: 40rpx 0;
}

.invite-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.invite-item:last-child {
  border-bottom: none;
}

.invite-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.invite-info {
  flex: 1;
  margin-left: 20rpx;
}

.invite-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 6rpx;
}

.invite-time {
  font-size: 24rpx;
  color: #bbb;
}

.invite-reward {
  font-size: 26rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.invite-reward.settled {
  color: #52A76E;
  background-color: #e8f5ee;
}

.invite-reward.pending {
  color: #F89600;
  background-color: #fff8e6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.share-btn {
  background-color: #52A76E;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  height: 90rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
