page {
  background-color: #f5f5f5;
}

.container {
  padding: 0 0 40rpx;
}

.search-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background-color: #eed6ba;
  padding: 16rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.search-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 10rpx;
}

.search-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex-shrink: 0;
  white-space: nowrap;
}

.search-input {
  flex: 1;
  width: 100%;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 5rpx 12rpx;
  border: 1rpx solid #ddd;
  height: 42rpx;
  box-sizing: border-box;
}

.date-val {
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 6rpx 12rpx;
  border: 1rpx solid #ddd;
  width: 150rpx;
  text-align: center;
}

.placeholder {
  color: #aaa;
}

.date-sep {
  font-size: 28rpx;
  color: #aaa;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.search-btn-row {
  justify-content: flex-end;
  gap: 10rpx;
  padding-bottom: 8rpx;
}

.btn-clear-active {
  background-color: #52A76E !important;
}

.btn-clear-disabled {
  background-color: #ccc !important;
}

.search-btn {
  font-size: 24rpx;
  color: #fff;
  background-color: #52A76E;
  border-radius: 30rpx;
  padding: 9rpx 32rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  text-indent: 2rpx;
}

.order-card {
  background-color: #fff;
  margin: 0 0 16rpx;
  padding: 24rpx 30rpx;
  box-sizing: border-box;
}

.order-card-highlight {
  background-color: #e8f5ee;
  border-left: 6rpx solid #52A76E;
}

.btn-refund-highlight {
  color: #fff !important;
  font-weight: bold;
  background-color: #52A76E;
  border-color: #52A76E;
}

.order-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.status-unpaid { color: #ff9900; }
.status-paid { color: #52A76E; }
.status-cancelled { color: #999; }
.status-refunded { color: #f3333e; }

.card-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 12rpx;
}

.card-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  font-weight: bold;
  width: auto;
}

.card-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  margin-left: 0;
}

.price-text {
  color: #f3333e;
  font-weight: bold;
}

.card-actions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 25rpx;
}

.btn-pay {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  background-color: #52A76E;
  border-radius: 30rpx;
  padding: 9rpx 32rpx;
  margin-left: 20rpx;
  letter-spacing: 2rpx;
  text-indent: 2rpx;
}

.btn-refund {
  font-size: 24rpx;
  font-weight: bold;
  color: #999;
  border: 1rpx solid #ccc;
  border-radius: 30rpx;
  padding: 9rpx 32rpx;
  box-sizing: border-box;
}

.btn-edit {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  background-color: #52A76E;
  border-radius: 30rpx;
  padding: 9rpx 32rpx;
  box-sizing: border-box;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  background: #fff;
  border-radius: 16rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 30rpx;
  margin-top: 30rpx;
}

.btn-cancel-modal {
  font-size: 28rpx;
  color: #999;
  border: 1rpx solid #ccc;
  border-radius: 30rpx;
  padding: 14rpx 50rpx;
}

.btn-confirm {
  font-size: 28rpx;
  color: #fff;
  background-color: #52A76E;
  border-radius: 30rpx;
  padding: 14rpx 50rpx;
  font-weight: bold;
}

.form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.form-col {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.form-col-auto {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-left: 14rpx;
}

.form-col-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  white-space: nowrap;
  font-weight: bold;
}

.form-col-input {
  font-size: 28rpx;
  color: #333;
  padding: 4rpx 8rpx;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  box-sizing: border-box;
  min-width: 0;
}

.picker-inline {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.required::before {
  content: '*';
  color: #f3333e;
  margin-right: 4rpx;
}

.form-item-col {
  display: flex;
  flex-direction: column;
  padding: 10rpx 0;
}

.intro-textarea {
  width: 100%;
  height: 120rpx;
  font-size: 28rpx;
  color: #333;
  padding: 8rpx;
  box-sizing: border-box;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.card-scroll {
  width: 540rpx;
  white-space: nowrap;
  overflow: hidden;
}

.card-scroll-text {
  font-size: 28rpx;
  color: #333;
  white-space: nowrap;
  display: inline-block;
}

.empty-tip {
  text-align: center;
  color: #aaa;
  font-size: 28rpx;
  margin-top: 120rpx;
}

.list-end {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  padding: 30rpx 0;
}

.list-loading {
  text-align: center;
  color: #aaa;
  font-size: 24rpx;
  padding: 20rpx 0;
}

.card-id {
  font-size: 28rpx;
  color: #333;
}

.modal-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.modal-body {
  margin-bottom: 24rpx;
}

.refund-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333;
  padding: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.modal-submit {
  background-color: #52A76E;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 30rpx;
  padding: 16rpx 0;
  text-align: center;
  width: 60%;
  margin: 0 auto;
}

.modal-header {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 24rpx;
}

.modal-close {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  font-size: 32rpx;
  color: #999;
  padding: 0 4rpx;
}

.modal-submit-row {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.refund-reject-box {
  background-color: #fff5f5;
  border: 1rpx solid #ffcccc;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-top: 16rpx;
}

.refund-reject-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #cc3333;
  display: block;
  margin-bottom: 10rpx;
}

.refund-reject-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-top: 8rpx;
}

.refund-reject-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  font-weight: bold;
}

.refund-reject-val {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}
