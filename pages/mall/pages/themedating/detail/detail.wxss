.loading-tip {
  text-align: center;
  color: #aaa;
  font-size: 28rpx;
  margin-top: 200rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.rule-content {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  word-break: break-all;
  white-space: pre-wrap;
}

.func-list {
  display: flex;
  flex-direction: column;
}

.func-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.func-item.last {
  border-bottom: none;
}

.func-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  text-align: center;
  line-height: 72rpx;
}

.signup-icon {
  background-color: #e8f5ee;
}

.chat-icon {
  background-color: #e8f0ff;
}

.promotion-icon {
  background-color: #fff3e0;
}

.func-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.func-arrow {
  font-size: 36rpx;
  color: #ccc;
}
