.share-b1 {
  border: none;
  line-height: unset;
  background-color: #FFF;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.share-b1::after {
  border: none;
  height: auto;
}

.share-cust {
  width: 80rpx;
  height: 80rpx;
  background-size: 100% 100%;
  background-image: url("data:image/svg+xml,%3Csvg t='1667375126490' class='icon' viewBox='0 0 1024 1024' version='1.1' xmlns='http://www.w3.org/2000/svg' p-id='1576' width='200' height='200'%3E%3Cpath d='M512 512m-81.92 0a81.92 81.92 0 1 0 163.84 0 81.92 81.92 0 1 0-163.84 0Z' fill='%2350b674' p-id='1577'%3E%3C/path%3E%3Cpath d='M512 0C229.376 0 0 229.376 0 512s229.376 512 512 512 512-229.376 512-512S794.624 0 512 0z m266.24 309.248L688.128 471.04c18.432 77.824-16.384 161.792-90.112 202.752-88.064 49.152-200.704 16.384-249.856-71.68-49.152-88.064-16.384-200.704 71.68-247.808 45.056-24.576 94.208-28.672 139.264-16.384l163.84-81.92c14.336-8.192 32.768-4.096 45.056 8.192 14.336 12.288 18.432 30.72 10.24 45.056z' fill='%2350b674' p-id='1578'%3E%3C/path%3E%3C/svg%3E");
