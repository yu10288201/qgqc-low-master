page {
    background-color: #f5f5f5;
  }
  
  .container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background-color: #f5f5f5;
    margin: 0;
    padding: 0 0 120rpx;
    box-sizing: border-box;
  }
  
  .cover-img {
    width: 94%;
    height: 380rpx;
    display: block;
    background-color: #e8f5ee;
    margin: 20rpx 3% 0;
    border-radius: 16rpx;
    box-sizing: border-box;
  }
  
  .card {
    width: 94%;
    margin: 20rpx 3%;
    background-color: #fff;
    border-radius: 20rpx;
    padding: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
    box-sizing: border-box;
  }

.card-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #52A76E;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 0.5rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-key {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  flex-shrink: 0;
}

.info-val {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  font-weight: bold;
}

.price-text {
  color: #f3333e;
  font-weight: bold;
}

.media-card {
  width: 94%;
  margin: 20rpx 3% 0;
  display: flex;
  flex-direction: column;
}

.media-video {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  display: block;
}

.media-img {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  display: block;
}

.info-row-col {
  display: flex;
  flex-direction: column;
  padding: 14rpx 0;
  border-top: 0.5rpx solid #f5f5f5;
}

.desc-scroll {
  height: 300rpx;
  margin-top: 12rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border: 1.5rpx solid #ccc;
}

.bottom-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 80rpx;
  padding: 20rpx 30rpx 40rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.action-btn {
  background-color: #52A76E;
  font-size: 25rpx;
  padding: 10rpx 40rpx;
  border-radius: 30rpx;
  font-weight: bold;
  color: #fff;
}

.commission-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-radius: 16rpx;
  background-color: rgb(249,210,205);
  border: 1rpx solid rgb(249,210,198);
  width: 100%;
  height: 80rpx;
  margin: 14rpx 0;
  overflow: hidden;
}

.commission-trophy {
  height: 70rpx;
  width: 44rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.commission-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background-color: #52A76E;
  border-radius: 35rpx;
  margin-left: 16rpx;
  height: 65rpx;
  flex: 1;
  padding: 0 20rpx;
}

.commission-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 10rpx;
  white-space: nowrap;
}

.commission-val {
  font-size: 25rpx;
  font-weight: 700;
  color: #fff;
}

.commission-share {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.commission-share-text {
  font-size: 22rpx;
  color: grey;
}

