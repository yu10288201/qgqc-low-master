<view class="body">
    <view class="content" >
        <view class='form' style="margin-top:10rpx;">
          <view style="z-index: 3;border: 1rpx solid;border-radius: 10rpx;display: flex;flex-direction: column;align-items: center;margin-bottom: 20rpx;">
                <view style="display: flex;flex-direction: row;justify-content: space-between;width: 100%;margin-top: 5rpx;">
                    <view style="display: flex;justify-content: center;align-items: center;margin: 10rpx 10rpx 10rpx 10rpx;width:530rpx;">
                        <view style="font-size: 28rpx;font-weight: bolder;">日期：</view>
                        <view style="flex: 1;height: 100%;border-radius: 10rpx;border: #000 1rpx solid;height: 43rpx;overflow: hidden;display: flex;flex-direction: column;justify-content: center;align-items: center;">
                            <picker mode="date" bindchange="beginCreateTimeChange" style="width: 100%;height: 100%;">
                                <view style="height: 40rpx;width: 100%;line-height: 40rpx;text-align: center;font-size: 26rpx;display: flex;width: 100%;">
                                    {{beginCreateTime}}
                                    <view style="width: 0px;height: 0px;border: 15rpx solid transparent;border-top-color: #000;position: absolute;margin-left: 150rpx;margin-top: 15rpx;"></view>
                                </view>
                            </picker>
                        </view>

                        <view style="font-size: 28rpx;font-weight: bolder;margin: 0 5rpx 0 5rpx;display: flex;flex-direction: row;justify-content: center;align-items: center;">-</view>
                        <view style="flex: 1;height: 100%;border-radius: 10rpx;border: #000 1rpx solid;height: 46rpx;overflow: hidden;display: flex;flex-direction: column;justify-content: center;align-items: center;">
                            <picker mode="date" bindchange="{{beginCreateTime ? 'endCreateTimeChange' : ''}}" start="{{beginCreateTime}}" style="width: 100%;height: 100%;">
                                <view style="height: 40rpx;width: 100%;line-height: 40rpx;text-align: center;font-size: 26rpx;display: flex;">
                                    {{endCreateTime}}
                                    <view style="width: 0px;height: 0px;border: 15rpx solid transparent;border-top-color: #000;position: absolute;margin-left: 150rpx;margin-top: 15rpx;"></view>
                                </view>
                            </picker>
                        </view>
                    </view>
                    <!-- <view style="display: flex;justify-content: center;align-items: center;margin: 10rpx 10rpx 10rpx 10rpx;">
                        <view style="font-size: 28rpx;font-weight: bolder;">区域：</view>
                        <view style="border-radius: 10rpx;border: #000 1rpx solid;max-width: 100rpx;height: 40rpx;overflow: hidden;display: flex;flex-direction: column;justify-content: center;align-items: center;">
                            <input style="width: 100%;font-size: 30rpx;" type="number" model:value="{{selectAreaName}}" />
                        </view>
                    </view> -->
                </view>
                <view style="display: flex;flex-direction: row;justify-content: space-between;width: 100%;margin-top: 5rpx;">
                    <view style="display: flex;justify-content: center;align-items: center;margin: 5rpx 0 10rpx 10rpx;flex: 1;">
                        <view style="font-size: 28rpx;font-weight: bolder;">商家：</view>
                        <view style="border-radius: 10rpx;border: #000 1rpx solid;flex: 1;height: 42rpx;overflow: hidden;display: flex;flex-direction: column;justify-content: center;align-items: center;">
                            <input style="width: 100%;font-size: 30rpx;text-align: center;"  model:value="{{selectShopName}}" />
                        </view>
                    </view>
                    <view style="display: flex;justify-content: center;align-items: center;margin: 5rpx 10rpx 5rpx 10rpx;width: 280rpx;">
                      <view style="font-size: 28rpx;font-weight: bolder;">区域：</view>
                        <view style="border-radius: 10rpx;border: #000 1rpx solid;flex: 1;height: 42rpx;overflow: hidden;display: flex;flex-direction: column;justify-content: center;align-items: center;">
                          <input style="width: 100%;font-size: 30rpx;" type="number" model:value="{{selectAreaName}}" />
                        </view>
                    </view>
                </view>

                <view style="display: flex;flex-direction: row;justify-content: space-between;width: 100%;margin-top: 5rpx;">
                    <view style="display: flex;justify-content: center;align-items: center;margin: 5rpx 10rpx 5rpx 10rpx;width: 280rpx;">
                        <view style="font-size: 28rpx;font-weight: bolder;">绑定类型：</view>
                        <view style="border-radius: 10rpx;border: #000 1rpx solid;flex: 1;height: 42rpx;overflow: hidden;display: flex;flex-direction: column;justify-content: center;align-items: center;">
                            <picker mode="selector" range="{{bindingType}}" value="{{bindingTypeIndex}}" bindchange="selectBindingType" style="width: 100%;height: 100%;">
                                <view style="height: 40rpx;width: 100%;line-height: 40rpx;text-align: center;font-size: 28rpx;display: flex;justify-content: space-between;">
                                    {{bindingType[bindingTypeIndex]}}
                                    <view style="width: 0px;height: 0px;border: 15rpx solid transparent;border-top-color: #000;position: absolute;margin-left: 110rpx;margin-top: 15rpx;"></view>
                                </view>
                            </picker>
                        </view>
                    </view>

                    <!-- <view class='th1' bindtap="toMallPersonalBenefit" style="height: 50rpx;width: 140rpx;padding: 0 10rpx;background-color:#52A76E;border-radius: 20rpx;background-image: none;color: #fff;">
                            <view class="text">我的收益</view>
                      </view> -->

                      <!-- <view class='th1' bindtap="toMallArticleEffectMain" style="height: 50rpx;width: 140rpx;padding: 0 10rpx;background-color:#52A76E;border-radius: 20rpx;background-image: none;margin-right: 10rpx;color: #fff;">
                            <view class="text">分享详情</view>
                      </view> -->

                </view>

                <view style="display: flex;flex-direction: row;justify-content: space-between;width: 100%;margin-bottom: 5rpx;margin-top: 25rpx;margin-bottom: 10rpx;">
                    <view style="display: flex;flex-direction: row;justify-content: flex-end;flex: 1;align-items: center;height: 50rpx;">

                      <view class='th1' bindtap="toMallArticleEffectMain" style="height: 50rpx;width: 140rpx;padding: 0 10rpx;background-color:#52A76E;border-radius: 20rpx;background-image: none;margin-right: 20rpx;color: #fff;">
                            <view class="text">分享详情</view>
                      </view>
                      
                      <view class='th1' bindtap="clearSelectKey"  style="height: 50rpx;width: 80rpx;padding: 0 10rpx;margin-right: 10rpx;background-color:#e7c7a8;border-radius: 20rpx;background-image: none;margin-right: 30rpx;" >
                            <view class="text">清空</view>
                      </view>
                      <view class='th1' data-id="1" bindtap="changeToadyData" style="height: 50rpx;width: 80rpx;padding: 0 10rpx;margin-right: 10rpx;background-color:#e7c7a8;border-radius: 20rpx;background-image: none;margin-right: 30rpx;">
                          <view class="text">当日</view>
                      </view>
                      <view class='th1' data-id="2" bindtap="changeToadyData" style="height: 50rpx;width: 80rpx;padding: 0 10rpx;margin-right: 10rpx;background-color:#e7c7a8;border-radius: 20rpx;background-image: none;margin-right: 30rpx;">
                          <view class="text">当月</view>
                      </view>
                      
                      <view class='th1' bindtap="getConditionCust" style="height: 50rpx;width: 80rpx;padding: 0 10rpx;margin-right: 10rpx;background-color:#e7c7a8;border-radius: 20rpx;background-image: none;">
                            <view class="text">查询</view>
                      </view>
                    </view>
                </view>
          </view>
          <view style="z-index: 3;border: 1rpx solid;border-radius: 10rpx;display: flex;flex-direction: row;align-items: center;font-size: 28rpx;">
                <view style="display: flex;flex-direction: column;justify-content: space-between;flex: 1;">
                    <view style="margin: 5rpx 0 0 10rpx;font-weight: bolder;">提成奖励总数: </view>
                    <view style="margin: 0 0 0 10rpx;font-weight: bolder;">星盾总数: <text  style="font-weight: 400;">{{saleDataInf?(saleDataInf.bind_star_count+saleDataInf.divide_star_count+saleDataInf.goods_platform_star_commission_total+saleDataInf.goods_shop_star_commission_total):0}}个</text></view>
                </view>
                <view style="display: flex;flex-direction: column;justify-content: space-between;flex: 1;">
                    <view style="margin: 5rpx 0 0 10rpx;font-weight: bolder;">现金: <text style="font-weight: 400;">{{saleDataInf?(saleDataInf.goods_platform_cash_commission_total+saleDataInf.goods_shop_cash_commission_total):0}}元</text></view>
                    <view style="margin: 0 0 0 10rpx;font-weight: bolder;width: 100rpx;font-weight: 400;color: white;">abc</view>
                    <!-- <view style="margin: 0 0 0 10rpx;font-weight: bolder;">商家星盾: <text style="font-weight: 400;">{{saleDataInf?saleDataInf.goods_shop_star_commission_total:0}}个</text></view> -->

                </view>
                <view style="display: flex;flex-direction: column;justify-content: space-between;flex: 1;">
                    <view style="margin: 5rpx 0 0 10rpx;font-weight: bolder;">充电券: <text style="font-weight: 400;">{{saleDataInf?saleDataInf.battery_buyer_amount:0}}元</text></view>
                    <view style="margin: 0 0 0 10rpx;font-weight: bolder;"><text style="font-weight: 400;color: #f2f2f2;">a</text></view>
                </view>
              
          </view>
          <view style="z-index: 3;font-size: 28rpx;">
                <view style="border: 1rpx solid;border-radius: 10rpx;margin-top: 10rpx;">
                    <view style="margin: 0 0 0 10rpx;"><text style="font-weight: bolder;">商家绑定朋友: </text>{{saleDataInf?saleDataInf.shop_bind_count:0}}个</view>
                    <view style="margin: 0 0 0 10rpx;margin-top: 0;"><text style="font-weight: bolder;">商家+商品绑定: </text>{{saleDataInf?saleDataInf.goods_bind_count:0}}个</view>
                </view>
                <view style="border: 1rpx solid;border-radius: 10rpx;margin-top: 10rpx;">
                    <!-- <view style="margin: 5rpx 0 0 10rpx;"><text style="font-weight: bolder;">平台提成奖励: </text>现金: {{saleDataInf.platform_cash_commission_total}}元 星盾: {{saleDataInf.platform_star_commission_total}}个</view> -->
                    <!-- <view style="margin: 0 0 0 10rpx;"><text style="font-weight: bolder;">商家提成奖励: </text>现金: {{saleDataInf.shop_cash_commission_total}}元 星盾: {{saleDataInf.shop_star_commission_total}}个</view> -->
                    <view style="margin: 0 0 0 10rpx;"><text style="font-weight: bolder;">商家+商品提成奖励: </text></view>
                    <view style="margin: 0 0 0 10rpx;">平台现金: <text style="color: #d01510;">{{saleDataInf?(saleDataInf.goods_platform_cash_commission_total):0}}</text> 元</view>
                    <view style="margin: 0 0 0 10rpx;">平台购物星盾: <text style="color: #009aa2;">{{saleDataInf?saleDataInf.divide_star_count:0}}</text> 个 平台绑定星盾: <text style="color: #009aa2;">{{saleDataInf?saleDataInf.bind_star_count:0}}</text> 个</view>
                    <!-- <view style="margin: 0 0 0 10rpx;">商家现金: <text style="color: #fe9b02;">{{saleDataInf?saleDataInf.goods_shop_cash_commission_total:0}}</text> 元 商家星盾: <text style="color:#3e5d71;">{{saleDataInf?saleDataInf.goods_shop_star_commission_total:0}}</text> 个</view> -->
                    <!-- <view style="margin: 0 0 0 10rpx;"><text style="font-weight: bolder;">商家+会员提成奖励: </text>{{saleDataInf.bind_ddsc_staff_income_amount}}元</view> -->
                </view>
          </view>
          <view style="display: flex;flex-direction: row;justify-content: space-between;width: 100%;margin-top: 20rpx;">
                <view class="thtd" style="width: 100%;margin: 0 0 10rpx 0;padding: 0;">
                    <view class='th1' style="width: 100%;justify-content: space-between;margin-right: 0;background-color: #eed6ba;background-image: none;">
                        <text class='text' style="margin-left: 20rpx;font-size: 28rpx;">商家绑定
                        </text>
                        <view style="display: flex;flex-direction: column;align-items: center;margin-right: 20rpx">
                            <view style="display: flex;flex-direction: row;align-items: center;margin-bottom: 10rpx;">
                                <view style="height: 30rpx;width: 30rpx;background-color: #d01510;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">平台现金提成</text>
                                <view style="height: 30rpx;width: 30rpx;background-color: #009aa2;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">平台星盾提成</text>
                            </view>
                            <view style="display: flex;flex-direction: row;align-items: center;">
                                <view style="height: 30rpx;width: 30rpx;background-color: #fe9b02;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">商家现金提成</text>
                                <view style="height: 30rpx;width: 30rpx;background-color: #3e5d71;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">商家星盾提成</text>
                            </view>
                        </view>
                    </view>
                </view>
          </view>
          <view style="width: 100%;display: flex;flex-direction: row;justify-content: center;align-items: center;">
                <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;width: 35%;">商品名称</text>
                <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;width: 15%;">类型</text>
                <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;width: 15%;">数量</text>
                <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-right: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;width: 35%;">提成/奖励</text>
          </view>
          <scroll-view  class='td1' style="width: 100%;flex: 1;border: none;overflow: auto;" scroll-y>
                <block wx:for="{{canPinList}}" wx:key="index">
                    <view style="width: 100%;display: flex;flex-direction: row;justify-content: center;align-items: center;background-color: {{canPinListIndex == index ? 'yellow' : ''}}" data-index="{{index}}" data-item="{{item}}" bindtap="selectCanPin">
                        <text class='text' style="font-weight: unset;height: 60rpx;font-size: 28rpx;width: 35%;text-align: center;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height: 60rpx;">{{item.goods_name}}</text>
                        <text class='text' style="font-weight: unset;height: 60rpx;display:flex;flex-direction: row;align-items: center;justify-content: center;font-size: 28rpx;width:15%;text-align: center;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;">{{item.table_type==2?'绑定':(item.category_id == 14 ? '大米' : '普商')}}</text>
                        <text class='text' style="font-weight: unset;height: 60rpx;display:flex;flex-direction: row;align-items: center;justify-content: center;font-size: 28rpx;width:15%;text-align: center;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;">{{item.number}}</text>
                        <view class='text' style="font-weight: unset;height: 60rpx;display:flex;flex-direction: row;align-items: center;justify-content: center;font-size: 28rpx;width: 35%;text-align: center;border-right: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;">
                            <text style="color: #d01510;">{{item.platform_cash_commission}}</text>
                            <text>/</text>
                            <text style="color: #009aa2;">{{item.platform_star_commission}}</text>
                            <text>/</text>
                            <text style="color: #fe9b02;">{{item.shop_cash_commission}}</text>
                            <text>/</text>
                            <text style="color: #3e5d71;">{{item.shop_star_commission}}</text>
                           
                        </view>
                    </view>
                </block>
          </scroll-view>
          <view style="width: 100%;display: flex;flex-direction: row;align-items: center;margin-bottom: 20rpx;border: 1rpx solid #000;border-radius: 10rpx;height: 50rpx;">
            <view wx:if="{{canPinListIndex>=0&&canPinList.length>0}}" style="width: 100%;display: flex;flex-direction: row;align-items: center;justify-content: space-around;">
                <view style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  {{canPinList[canPinListIndex].shop_name}}
                </view>
                <view style="margin-left: 40rpx;">
                  {{canPinList[canPinListIndex].create_date}}
                </view>
            </view>
          </view>
          
        </view>
       
    </view>
</view>