.ring {
  position: relative;
  margin: 80rpx auto;
  width: 20px;
  height: 20px;
  border: 5px solid #52A76E;
  border-radius: 50%;
}

.line {
  display: block;
  position: absolute;
  z-index: 99;
  top: -25px;
  left: -25px;
  width: 60px;
  height: 60px;
}

.line::before {
  content: '';
  display: block;
  position: absolute;
  z-index: 99;
  top: 0px;
  left: 23.5px;
  width: 14px;
  height: 60px;
  border: 5px solid transparent;
  border-top: 5px solid #52A76E;
  border-radius: 10px;
  animation: animateCircle 0.6s linear infinite;
}

@keyframes animateCircle {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}




.bottom_box {
  margin: 15rpx auto;
  width: 94%;
  height: 60rpx;
  background: #f8f8f8;
  background-color: rgb(254,250,245);  
  border: 2rpx solid rgb(253, 227, 210);
  border-radius: 10rpx;
  box-shadow: 0px 0px 30rpx 1rpx #eff3eb inset;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.loading1 {
  width: 20px;
  height: 20px;
  border: 2px solid #2161319f;
  border-top-color: transparent;
  border-radius: 100%;
  animation: circle1 infinite 0.75s linear;
}

@keyframes circle1 {
  0% {
    transform: rotate(0);
  }

  100% {
    transform: rotate(360deg);
  }
}


