      <view style="font-size: large;color:#F89600;margin-bottom: 10rpx;">您的叮聊中有 {{ding_not_read_count}} 条未读信息</view>
      <view catch:tap="toDingKe" style="margin-top: 5rpx;margin-bottom: 10rpx;background-color: #52A76E;color: white;padding: 8rpx 20rpx;border-radius: 12rpx;font-size: 28rpx;display: flex;flex-direction: row;align-items: center;justify-content: center;">
          立即阅读
      </view>
