.b1{
    border: none;
    line-height: unset;
    background-color: #F2F2F2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.b1::after{
    border: none;
    height: auto;
}

.popup-window1-bg {
  position: fixed;
  left: 0rpx;
  top: 0rpx;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 88;
  display: flex;
  justify-content: center;
}

.popup-window1 {
  /* background: white; */
  position: fixed;
  bottom: 0;
  height: 85%;
  width: 80%;
  margin-left: 10%;
  z-index: 88;
  border-radius: 5%;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.badgecontent {
  background: #52A76E;
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  top: -10rpx;
  right: -15rpx;
  position: absolute;
  display: flex;
  flex-direction: column;
  text-align: center;
  justify-content: center;
  color: #FFF;
  z-index: 99999;
  font-size: 22rpx;
}