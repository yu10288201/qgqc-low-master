page{
  width: 100%;
  height: 100%;
}
.content{
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
}
.content_fill{
  flex: 1;
  display: flex;
  width: 98%;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  overflow: auto;
}
.content_template_scroll{
  width: 100%;
  height: 75%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}
.content_img_scroll{
  margin-top: 5rpx;
  width: 100%;
  height: 25%;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  overflow: auto;
}
.content_article_detail_scroll{
  width: 100%;
  height: 35%;
  background-color:#fff;
  overflow: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}
.border_solid{
  border: #f2f2f2 solid 2rpx;
  border-radius: 8rpx;
}
.bottom_btn{
  height: 52rpx; 
  color: white;
  background-color: #52A76E;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 25rpx;
  padding: 0rpx 20rpx; 
  font-size: 26rpx;
}
.content_box_img_parent {
  width: 100%;
  height: 100%;
  display: flex;
  overflow: auto;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}
.content_box_img_parent::after{
  content: '';
  flex: auto;
}

.content_box_row{
  width: 150rpx;
  height: 150rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #bbb;
  border-radius: 10rpx;
  margin-left: 10rpx;
  margin-right:10rpx;
  margin-bottom: 10rpx;
}
.content_box_row_select{
  width: 150rpx;
  height: 150rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  border: 8rpx dashed #52A76E;
  border-radius: 10rpx;
  margin-left: 10rpx;
  margin-right:10rpx;
  margin-bottom: 10rpx;
}
.content_box{
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #cdcdcd;
  border-radius: 10rpx;
  margin-left: 10rpx;
  margin-right:10rpx;
  margin-bottom: 10rpx;
}
.content_box_content{
  display: flex;
  width: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
}
.content_box_content_item{
  height: 50rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-right: 15rpx;
  border: 1rpx solid #c2c2c2;
  border-radius: 10rpx;
 
}
.content_box_func_box{
  display: flex;
  width: 100%;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0rpx;
  margin: 10rpx 10rpx 0rpx 10rpx;
  border-radius: 10rpx;
}
.content_box_content_img{
  width: 32rpx;
  height: 30rpx;
  border: 1rpx dashed #cdcdcd;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}
.content_box_content_title_green{
  font-size: 32rpx;
  color: #5FB878;
  padding: 0rpx 20rpx;
}
.content_box_content_title_red{
  font-size: 32rpx;
  color: #FF5722;
  padding: 0rpx 20rpx;
}
.func_box{
  display: flex;
  width: 100%;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0rpx;
  margin: 10rpx 10rpx 0rpx 10rpx;
  border: 1rpx dashed #cdcdcd;
  border-radius: 10rpx;
}
.func_item{
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-left: 15rpx;
}
.func_img{
  width: 95rpx;
  height: 90rpx;
  border: 1rpx dashed #cdcdcd;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.func_title{
  margin-top: 4rpx;
  font-size: 30rpx;
  color: #2c2c2c;
}


.form_tittle {
  width: 95%;
  margin-top: 2%;
  height: 76rpx;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
}


.for {
  border-bottom: 2rpx solid #d6d6d6;
  width: 95%;
  margin-left: 2.5%;
  justify-content: center;
  align-items: center;
  height: 76rpx;
  font-size: 28rpx;
  display: flex;
}

.th-head {
  width: 25%;
  border-left: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  justify-content: center;
  align-items: center;
  display: flex;
  font-size: 28rpx;
}
.th-center {
  width: 25%;
  border-left: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  justify-content: center;
  align-items: center;
  display: flex;
  font-size: 28rpx;
}
.th-end {
  width: 25%;
  border-left: 2rpx solid #d6d6d6;
  border-right: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  border-right: 2rpx solid #d6d6d6;
  justify-content: center;
  align-items: center;
  display: flex;
  font-size: 28rpx;
}

.td-head {
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  border-left: 2rpx solid #d6d6d6;
  width: 25%;
  overflow:hidden;
  white-space:nowrap;
  text-overflow:ellipsis;
}
.td-center {
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  border-left: 2rpx solid #d6d6d6;
  width: 25%;
  /* overflow:hidden;
  white-space:nowrap;
  text-overflow:ellipsis; */
  word-break: break-all;/*允许在单词内换行*/ 
  text-align: left; 
  text-overflow: -o-ellipsis-lastline;/*css3中webkit内核提供的一个方法类似ellipsis  */
  overflow: hidden;
  /* display: -webkit-box;自适应盒子 */
  -webkit-line-clamp: 2;/*此处为1行,如果是两行就改成2*/
  -webkit-box-orient: vertical;
}
.td-end {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  justify-content: center;
  height: 100%;
  border-left: 2rpx solid #d6d6d6;
  border-right: 2rpx solid #d6d6d6;
  width: 25%;
 
   word-break: break-all;/*允许在单词内换行*/ 
   text-align: left; 
  text-overflow: -o-ellipsis-lastline;/*css3中webkit内核提供的一个方法类似ellipsis  */
  overflow: hidden;
  /* display: -webkit-box;自适应盒子 */
  -webkit-line-clamp: 2;/*此处为1行,如果是两行就改成2*/
  -webkit-box-orient: vertical;
}


