</view>
<view style="position: fixed;top: 0;right: 0;left: 0;bottom: 0;margin: auto;height: 360rpx;width: 700rpx;background-color: #F2F2F2;border-radius: 20px;display: flex;flex-direction: column;justify-content: center;align-items: center;z-index: 999;" wx:if="{{b_share_dlg_show}}">
  
    <view style="display: flex;flex-direction: row;justify-content: center;width: 100%;align-items: center;flex: 1;">
