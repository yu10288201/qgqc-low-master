        </view>
    </view>
</view>






<!-- 底部弹窗 转发叮聊 -->
<view wx:if="{{b_ding_main_show}}" style="height: 100%;z-index: 99999;"  class="popup-dlg-background-mask" >
	<view  class="popup-dlg-bottom mall-font-family-YaHei mall-font-size-default" style="width:100%;height: 98vh;display: flex;flex-direction: column;align-items: center;justify-content: center;">
    <view style="flex:1;"></view>
    <view style="width: 98%;margin-bottom: 10rpx;">
      <view style="font-weight: 800;font-size: 34rpx;">
        选择叮客
      </view>
    </view>
    <view style="width: 100%;display: flex;flex-direction: row;align-items: center;">
      <view style="flex: 1;margin-bottom:15rpx;margin-top:10rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;border-radius: 50rpx;border: 2rpx solid grey;padding: 0rpx 5rpx;">
        <view style="flex: 1;"> 
          <input model:value="{{ding_key_word}}" placeholder="   搜索叮客" style="width: 100%; font-size: 25rpx;"/>
        </view>
      </view>
      <view style="margin-bottom:0rpx;margin-top:0rpx; height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: flex-end;border-radius: 50rpx;">
          <view catch:tap="clearDingKeyWord" class="bottom_btn" style="margin-right: 10rpx;background-color: #FF5722;" >
            清空
          </view>
          <view  catch:tap="selectAllDingMsgRecordDingKeFromMemberInfo" class="bottom_btn" style="margin-right: 10rpx;">
            搜索
          </view>
      </view>
    </view>
    
    <scroll-view scroll-y="true" style="height:80vh;overflow: scroll;overflow: auto;" bindscrolltolower="scrollToLowerArticleMain"  scorll-top="{{scoll_top}}" >
      <block wx:if="{{dingYouList.length > 0}}">
        <view wx:for="{{dingYouList}}" data-item="{{item}}" bindtap="changeDingSelect" data-index="{{index}}" style="height: 140rpx;display: flex;flex-direction: row;justify-content: center;align-items: center;" wx:key="index">
					<view style="width: 90rpx;height: 140rpx;display: flex;flex-direction: row;align-items: center;justify-content: center;">
              <image wx:if="{{item.is_select==1}}" style="width: 60rpx;height: 60rpx;" src="{{ding_select_img}}">
              </image>
              <image wx:if="{{item.is_select==0}}" style="width: 58rpx;height: 58rpx;" src="{{ding_not_select_img}}">
              </image>
          </view>
          <view style="width: 80rpx;height: 100%;display: flex;justify-content: center;align-items: center;">
                        <view style="position: relative;">
                            <image style="height: 80rpx;width: 80rpx;border-radius: 12rpx;" src="{{item.avatar_url?item.avatar_url:item.customer_code}}" />
                        </view>
						
					</view>
					<view style='margin-left: 10rpx;border-bottom: #eeeeee 1rpx solid;flex: 1;height: 100%;display: flex;flex-direction: column;align-items: flex-start;justify-content: space-evenly;{{index==0?"border-top: #eeeeee 1rpx solid;":";"}}'>
						<view style="margin-left: 20rpx;display: flex;justify-content: space-between;align-items: center;width: 100%;height: 70rpx;">
							<view style="margin-top: 20rpx;font-weight: 400;font-size: 32rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
								{{item.customer_name}}
							</view>
          
							
						</view>
						<view style="display: flex;justify-content: flex-start;align-items: center;width: 100%;height: 70rpx;">
							<view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].msg_type==1}}" style="margin-bottom: 20rpx;font-size: 26rpx;width: 550rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
								{{item.lstDingMsgRecord[0].msg}}
							</view>
						</view>

					</view>
          

          
				</view>

			</block>
      </scroll-view>
    <view style="display: flex;flex-direction: row;align-items: center;justify-content: flex-end;width: 100%;padding: 10rpx 0rpx;">

      <view catchtap="showOrHideBDingMainShow" data-show="{{false}}" class="bottom_btn" style="background-color: #FF5722;margin-right: 150rpx;">关闭</view>
      <view catchtap="sendMsgExec" class="bottom_btn" style="margin-right: 20rpx;">发送</view>
    </view>	
   
	</view>
</view>

 	
    

	



