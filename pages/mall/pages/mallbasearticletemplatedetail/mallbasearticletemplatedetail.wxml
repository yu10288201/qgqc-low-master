

<view class="content">
  <view class="content_fill" >
      
      <scroll-view class="content_img_scroll border_solid"  scroll-y="true">
        <view class="content_box_img_parent" >
          <view  catch:tap="goodsImgClick" data-item="{{item}}" wx:for="{{mall_base_goods_multimedia_array}}"  wx:key="index">
            <view wx:if="{{current_goods_multimedia_id==item.id}}" class="content_box_row_select" >
              <image mode="aspectFill" src="{{item.url}}" style="width: 90%;height: 90%;" ></image>
            </view>
            <view wx:else="" class="content_box_row" >
              <image mode="aspectFill" src="{{item.url}}" style="width: 90%;height: 90%;" ></image>
            </view>
          </view>
          <view>
          <view wx:if="{{mall_base_goods_nine_array.length>0}}" catch:tap="goodsNineClick"  class="{{mall_base_goods_nine_array_selected==0?'content_box_row':'content_box_row_select'}}">
              <view style="width: 100%;height: 100%;display: flex;flex-direction: row;flex-wrap: wrap;">
                    <view  wx:for="{{mall_base_goods_nine_array}}"  wx:key="index" style="width: 33%;height: 33%;">
                      <image mode="aspectFill" src="{{item.url}}" style="width: 90%;height: 90%;" ></image>
                    </view>
                    <view  wx:for="{{9-mall_base_goods_nine_array.length}}"  wx:key="index" style="width: 33%;height: 33%;">
                      
                    </view>
              </view>
              
          </view>
          
          </view>
          
        </view>
      </scroll-view>

      <scroll-view scroll-into-view="{{pageId}}"  class="content_template_scroll border_solid" scroll-y="true">
        <view wx:if="{{item.is_delete==0}}"  class="content_box" wx:for="{{article_template_detail_array}}"  wx:key="index">
          <view id="page_{{index}}" class="content_box_content">
            <view style="width: 100%;margin-top: 10rpx;margin-bottom: 10rpx;display: flex;flex-direction: row;align-items: center;justify-content:space-between ;" >
              <view data-item="{{item}}" style="font-weight: 900;padding: 10rpx 20rpx;border: #ccc dashed 2rpx;border-radius: 8rpx;">
                        <text >顺序_{{item.sort_id_str}}_ </text>
                        <text wx:if="{{item.source_type==1}}">文章_{{item.item_sort_id_str}} </text>
                        <text wx:if="{{item.source_type==2}}">商品_{{item.item_sort_id_str}} </text>
                        <text wx:if="{{item.item_type==1}}">图片</text>
                        <text wx:if="{{item.item_type==2}}">视频</text>
                        <text wx:if="{{item.item_type==3}}">文字</text>
                        <text wx:if="{{item.item_type==4}}">九宫格</text>
                </view>
                <view wx:if="{{index>1||(index==1&&article_template_main_item.article_type==1)}}" style="display: flex;flex-direction: row;">
                    <view catch:tap="deleteArticleTemplateDetailItem"   data-item="{{item}}" data-index="{{index}}"  class="content_box_content_item" style="margin-right: 40rpx;">
                      <view  class="content_box_content_title_red">
                          删除
                      </view>
                    </view>
                    <view  catch:tap="addToArticleTemplateDetailFromGoodsImg"   data-item="{{item}}" data-index="{{index}}"   class="content_box_content_item" >
                      <view  class="content_box_content_title_green">
                          插入
                      </view>
                    </view>
                </view>
                
              </view>
              <view style="display: flex;flex-direction: column;">
                <view style="display: flex;flex-direction: column;align-items: flex-start;align-items: flex-start;width: 100%;">
                 
                  <text wx:if="{{item.item_type==1||item.item_type==2}}" style="text-align: center; width: 100%;">{{item.item_description}}</text>
                  <view wx:if="{{item.item_type==1}}" style="width: 100%;">
                      <image data-src="{{item.item_content}}" src="{{item.item_content}}" catchtap="showBigImg"  style="width: 70vw;" mode="aspectFit"></image>
                  </view>
                  <view wx:if="{{item.item_type==2}}">
                    <video  style="width:80vw;height: 300rpx;border-radius: 8rpx;z-index: 1;" src="{{item.item_content}}"></video>
                  </view>
                  <view  wx:if="{{item.item_type==3}}">
                    <rich-text nodes="{{item.item_content}}"></rich-text>
                  </view>
                  <view wx:if="{{item.lstNine&&item.lstNine.length>0}}" style="display: flex;width: 100%;flex-direction: row;align-items: center;justify-content: center;flex-wrap: wrap;">
                      <view wx:for="{{item.lstNine}}" wx:for-item="nine_item" wx:for-index="nine_index" wx:key="nine_index" style="width: 180rpx;height: 180rpx;border: #F2F2F2 1rpx solid;">
                        <image data-src="{{nine_item.url}}" src="{{nine_item.url}}" catchtap="showBigImg"  style="width: 100%;height: 100%;" mode="aspectFill"></image>
                      </view>
                  </view>
                
                </view>
              
              </view>
          </view>

        </view>
        <view wx:if="{{article_template_detail_array.length>0}}" class="content_box">
          <view class="content_box_content">
            <view  style="width: 100%;margin-top: 10rpx;margin-bottom: 10rpx;display: flex;flex-direction: row;align-items: center;justify-content:space-between ;" >
                <view >    
                </view>
                <view style="display: flex;flex-direction: row;align-items: center;justify-content: center;">
   
                   <view catch:tap="addToArticleTemplateDetailFromGoodsImg"    data-index="-1"  class="content_box_content_item">
                    <view  class="content_box_content_title_green">
                        插入
                    </view>
                   </view>
                </view>
                
              </view>
            
          </view>

        </view>
      </scroll-view>

  </view>
  
  <view style="display: flex;flex-direction: row;align-items: center;justify-content: space-between;width: 100%;padding: 10rpx 0rpx;">
    <view catchtap="toArticleTemplateDetailDescription" class="bottom_btn">操作说明</view>
      <view wx:if="{{article_template_detail_array.length>0}}" catchtap="previewArticleTemplateDetail" class="bottom_btn">预览</view>
      <!-- <view catchtap="previewArticleTemplateResult" class="bottom_btn">结果页</view> -->
      <view catchtap="showOrHideBArticleTemplateMainShow" data-show="{{true}}" class="bottom_btn">已有</view>
      <view wx:if="{{article_template_detail_array.length>0}}" catchtap="initData" class="bottom_btn">新增</view>
      <view wx:if="{{article_template_detail_array.length>0}}" catchtap="deleteMallBaseArticleTemplateMainClick" class="bottom_btn" style="background-color: #FF5722;">删除</view>
      <view  catchtap="showOrHideBArticleMainShow" data-show="{{true}}" class="bottom_btn">找素材</view>
      <view wx:if="{{is_updated==1}}" catchtap="insertOrUpdateMallBaseArticleTemplateMain" class="bottom_btn">保存</view>
      <view  wx:if="{{is_updated==0&&article_template_main_item&&article_template_main_item.id>0&&article_template_main_item.goods_id>0}}" class="bottom_btn" style="padding: 0;" >
        <!-- <button open-type="share" class="bottom_btn">发送</button>  -->
        <button catchtap="showShareDlg"  class="bottom_btn">发送</button>
      </view>
      
      
  </view>
 
  
</view>


<!-- 底部弹窗 转发素材查询 -->
<view wx:if="{{b_article_main_show}}" style="height: 100%;"  class="popup-dlg-background-mask">
	<view  class="popup-dlg-bottom mall-font-family-YaHei mall-font-size-default" style="width:100%;height: 92vh;display: flex;flex-direction: column;align-items: center;justify-content: center;">
    <view style="flex:1;"></view>
    <view style="width: 98%;margin-bottom: 10rpx;">
      <view style="font-weight: 800;font-size: 34rpx;">
        素材库
      </view>
    </view>
    <view style="width:98%;margin-bottom:15rpx;margin-top:10rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;border-radius: 50rpx;border: 2rpx solid grey;padding: 0rpx 5rpx;">
        <view style="flex: 1;"> 
          <input model:value="{{s_key_word}}" placeholder="   搜索转发素材" style="width: 100%; font-size: 25rpx;"/>
        </view>
    </view>
    <view style="width:98%;margin-bottom:0rpx;margin-top:0rpx; height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: flex-end;border-radius: 50rpx;">
        <view catch:tap="clearSKeyWord" class="bottom_btn" style="margin-right: 100rpx;background-color: #FF5722;" >
          清空
        </view>
        <view data-article_type="2" catch:tap="selectMallBaseArticleMainData" class="bottom_btn" style="margin-right: 50rpx;">
          图片
        </view>
        <view data-article_type="3" catch:tap="selectMallBaseArticleMainData" class="bottom_btn" style="margin-right: 50rpx;">
          视频
        </view>
        <view data-article_type="0" catch:tap="selectMallBaseArticleMainData" class="bottom_btn" style="margin-right: 20rpx;">
          搜索
        </view>
    </view>
    <view class='form_tittle'>
			<view class='th-head' style="text-align: center;width:24%;">
				<text class='text' style="font-size: 26rpx;">日期</text>
			</view>
			<view class='th-center' style="text-align: center;width:10%;">
				<text class='text' style="font-size: 26rpx;">类型</text>
			</view>
			<view class='th-end' style="text-align: center;width:66%;">
				<text class='text' style="font-size: 26rpx;">标题</text>
			</view>
		</view>
    <scroll-view scroll-y="true" style="height:65vh;overflow: scroll;overflow: auto;" bindscrolltolower="scrollToLowerArticleMain"  scorll-top="{{scoll_top}}" >
        <view class='for' wx:for='{{article_main_array}}' wx:key='index' data-index='{{index}}' catch:tap='itemClickArticleMain'>
          <view class='td-head' style='width:24%;{{listIndexArticleMain==index?"background-color:#52A76E;color:#fff":""}}'>
          {{item.article_date_str}}
          </view>
          <view class='td-center' style='width:10%;{{listIndexArticleMain==index?"background-color:#52A76E;color:#fff":""}}'>
            <text wx:if="{{item.article_type==1}}">文章</text>
            <text wx:if="{{item.article_type==2}}">图片</text>
            <text wx:if="{{item.article_type==3}}">视频</text>
          </view>			
          <view class='td-end' style='width:66%;{{listIndexArticleMain==index?"background-color:#52A76E;color:#fff":""}}'>
              {{item.name}}
          </view>
        </view>
      </scroll-view>
    <view style="display: flex;flex-direction: row;align-items: center;justify-content: flex-end;width: 100%;padding: 10rpx 0rpx;">

      <view catchtap="showOrHideBArticleMainShow" data-show="{{false}}" class="bottom_btn" style="background-color: #FF5722;margin-right: 150rpx;">关闭</view>
      <view catchtap="previewArticleDetail"  class="bottom_btn" style="margin-right: 100rpx;">预览</view>
      <view catchtap="confirmArticleMain" class="bottom_btn" style="margin-right: 20rpx;">确定</view>
    </view>	
   
	</view>
</view>



