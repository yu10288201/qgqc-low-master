            <view style="font-size: 30rpx;margin-top: 20rpx;">
                分享朋友圈
            </view>            
      </view> 

      <view style="display: flex;flex-direction: column;flex: 1;height: 100%;justify-content: space-around; align-items: center;">
          
            <button catchtap="showOrHideBDingMainShow" data-show="{{true}}"  class="b1">
