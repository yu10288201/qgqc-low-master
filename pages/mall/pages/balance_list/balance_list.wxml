<!--pages/balance_list/balance_list.wxml-->

<wxs module="filters" src="../../../module_discount/pages/ordersdetail/ordersdetail.wxs"></wxs>
<view class="bg-gray" style="width:100vw;height:100vh;">
  <view class='top' >
    <view class="title" >当前余额:{{mall_member_total_recharge_amount}}元</view>
    <view style="display: flex;flex-direction: row;width: 90%;">
      <view style="border: 1px solid #000;width: 30%;display: flex;flex-direction: row;justify-content: center;">
        <text>日期</text>
      </view>
      <view style="border: 1px solid #000;width: 25%;display: flex;flex-direction: row;justify-content: center;">
        <text>充值/消费</text>
      </view>
      <view style="border: 1px solid #000;width: 25%;display: flex;flex-direction: row;justify-content: center;">
        <text>余额</text>
      </view>
      <view style="border: 1px solid #000;width: 20%;display: flex;flex-direction: row;justify-content: center;">
        <text>状态</text>
      </view>
    </view>
    <scroll-view style="width: 90%;flex:1;overflow: auto;font-size: 30rpx;" scroll-y="true">
      <view class="prestoreList" wx:for="{{member_balance_array}}" bindtap="chooseList" wx:key="index" data-index="{{index}}">
        <view style='border: 1px solid #000;width: 30%;{{listIndex==index?"background-color:#519763;":""}}'>
          <view>{{item.create_time}}</view>
        </view>
        
        <view style='border: 1px solid #000;width: 25%;{{listIndex==index?"background-color:#519763;":""}}' wx:if="{{item.type == 2}}">
          <view style="color:#FF0000">-{{item.recharge_consumption_amount}}</view>
        </view>
        <view style='border: 1px solid #000;width: 25%;{{listIndex==index?"background-color:#519763;":""}}' wx:if="{{item.type == 1}}">
          <view style="color: #000;">+{{item.recharge_consumption_amount}}</view>
        </view>

        <view style='border: 1px solid #000;width: 25%;{{listIndex==index?"background-color:#519763;":""}}'>
          <view>{{item.mall_member_total_recharge_amount_after}}</view>
        </view>
        <view style='border: 1px solid #000;width: 20%;color:#FF0000;font-size: 28rpx;{{listIndex==index?"background-color:#519763;":""}}' wx:if="{{item.is_confirm == 0}}">
          <view>未确认</view>
        </view>
        <view style='border: 1px solid #000;width: 20%;font-size: 28rpx;{{listIndex==index?"background-color:#519763;":""}}' wx:elif="{{item.is_confirm == 1}}">
          <view>已确认</view>
        </view>
      </view>
    </scroll-view>
  

    <view class="prestoreListDetailButton">
      <view class="prestoreListDetailButton_1" bindtap="detailShow">详情</view>
    </view>

  </view>

</view>
<!--bg-gray-->


<view style="display:flex;flex-direction:column;position:fixed;justify-content:center;align-items:center;width:100vw;bottom:0;height:100vh;background-color:#00000055;left:0;right:0;top:0;margin:auto;z-index:9999;" wx:if="{{type_1&&recharge_item!=null}}">
    <view style="display: flex;flex-direction: column;justify-content: space-between;width: 90vw;border-radius: 20rpx; height: 50vh;background-color: #FFFFFF;" >
      <view style="display: flex;flex-direction: column;width: 100%;height: 100%;">
        <view style="margin: 0 20rpx 0 20rpx;font-size:18px;font-weight:bold;margin-top:20rpx;display: flex;flex-direction: row;justify-content: space-between;align-items: center;">
          <view>
            充值详情
          </view>
          <view bindtap="closePop">
            <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_close.png" style="width: 50rpx;height: 50rpx;"></image>
          </view>
        </view>

        <view style="overflow-x:scroll;margin: 40rpx 0 0 40rpx;">
        <view style="display: flex;flex-direction: column;">
          <view style="display: flex;flex-direction: row;">
            当前存入金额:{{recharge_item.recharge_amount}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            赠送:￥{{recharge_item.give_amount}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            存入方式:￥{{recharge_item.pay_type==1?'微信':''}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            当前余额:￥{{recharge_item.mall_member_total_recharge_amount_after}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            顾客编号:{{recharge_item.user_code}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            礼品编号:{{recharge_item.submit_gift}}
          </view>
          
          <view wx:if="{{recharge_item.is_gift_payed==0}}" style="display: flex;flex-direction: row;margin-top: 15rpx;">
            礼品领取:未领取
          </view>
          <view wx:if="{{recharge_item.is_gift_payed==1&&recharge_item.receive_type==0}}" style="display: flex;flex-direction: row;margin-top: 15rpx;">
            礼品领取:未知方式领取
          </view>
          <view wx:if="{{recharge_item.is_gift_payed==1&&recharge_item.receive_type==1}}" style="display: flex;flex-direction: row;margin-top: 15rpx;">
            礼品领取:现场领取
          </view>
          <view wx:if="{{recharge_item.is_gift_payed==1&&recharge_item.receive_type==2}}" style="display: flex;flex-direction: row;margin-top: 15rpx;">
            礼品领取:邮寄领取
          </view>
         
          

          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            存入日期:{{recharge_item.create_time}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            确认人:{{recharge_item.shop_confirm_operator}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            确认时间:{{recharge_item.is_shop_confirm==1?recharge_item.shop_confirm_time:''}}
          </view>
        
        </view>
        </view>
      </view>
  
    </view>
  </view>



  <view style="display:flex;flex-direction:column;position:fixed;justify-content:center;align-items:center;width:100vw;bottom:0;height:100vh;background-color:#00000055;left:0;right:0;top:0;margin:auto;z-index:9999;" wx:if="{{type_2==true&&consumption_item!=null}}">
    <view style="display: flex;flex-direction: column;justify-content: space-between;width: 90vw;border-radius: 20rpx; height: 50vh;background-color: #FFFFFF;" >
      <view style="display: flex;flex-direction: column;width: 100%;height: 100%;">
        <view style="margin: 0 20rpx 0 20rpx;font-size:18px;font-weight:bold;margin-top:20rpx;display: flex;flex-direction: row;justify-content: space-between;align-items: center;">
          <view>
            消费详情
          </view>
          <view bindtap="closePop">
            <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_close.png" style="width: 50rpx;height: 50rpx;"></image>
          </view>
        </view>

        <view style="overflow-x:scroll;margin: 40rpx 0 0 40rpx;">
        <view style="display: flex;flex-direction: column;">
          <view style="display: flex;flex-direction: row;">
            消费订单号:无
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            消费金额:￥{{consumption_item.consumption_total_amount}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            抵扣金额:￥{{consumption_item.deduction_amount}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            当前余额:￥{{consumption_item.mall_member_total_recharge_amount_after}}
          </view>
          <view style="display: flex;flex-direction: row;margin-top: 15rpx;">
            商家操作员:{{consumption_item.scan_operator}}
          </view>
          <view  style="display: flex;flex-direction: row;margin-top: 15rpx;">
            操作时间:{{consumption_item.is_customer_confirm==1?consumption_item.create_time:''}}
          </view>
        
        </view>
        </view>
      </view>
  
    </view>
  </view>