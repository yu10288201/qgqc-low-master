<view style="width: 100vw;height: 100vh;display: flex;flex-direction: column;align-items: center;justify-content: center;position: relative;background-color: #ccc;">
  <view style="width: 80%;height: 90%;position: relative;display: flex;flex-direction: column;align-items: center;">
          <image  style="width: 100%;height: 100%;" mode="aspectFill" src="{{img_url}}">
          </image>  
          <view wx:if="{{top_goods_name!=''||bottom_goods_name!=''}}" style="background-color: rgba(0,0,0,0.4);color: #fff;position: absolute;bottom: 20rpx;left: 15%;border-radius: 10rpx;padding: 5rpx 20rpx;">
            <view wx:if="{{top_goods_name!=''}}" style="font-size: 28rpx;margin-bottom: 5rpx;">上衣:{{top_goods_name}}</view>
            <view  wx:if="{{bottom_goods_name!=''}}" style="font-size: 28rpx;">下衣:{{bottom_goods_name}}</view>
          </view>

  </view>
  <view style="height: 10%;">

  </view>

  <view style="position: absolute;z-index: 9999;bottom: 40rpx;right: 0rpx;width: 100%;display: flex;flex-direction: row;justify-content: flex-end;">
    
    <view style="margin-right: 30rpx;">
          <view bind:tap="saveToAlbum" class="btn-green" style="font-size: 26rpx;">保存到相册</view> 
    </view>
    <view style="margin-right: 30rpx;">
          <button   open-type="share" class="b1" >
          <view class="btn-green" style="font-size: 26rpx;">转发</view> 
      </button>
    </view>

    <view style="margin-right: 30rpx;font-size: 26rpx;"  wx:if="{{top_goods_id>0||bottom_goods_id>0}}" class="btn-green" bind:tap="toMerchandise_details">购买</view>

      

  </view>

  
</view>





<view style="position: fixed;right: 0;left: 0;top:300rpx;margin: auto;height: 420rpx;width: 700rpx;background-color: #FFF;border-radius: 12px;display: flex;flex-direction: column;justify-content: center;align-items: center;z-index: 9999999;background-color: #ccc;border: #ccc 1rpx solid;" wx:if="{{buyDialogShow==true}}">
 <view style="font-size: larger;padding: 20rpx;color: rgb(134,76,2);font-weight: 900;">选择衣服</view>
 <view  catch:tap="buyDialogShowChange" class="badgecontent-close">X</view>
  <view style="display: flex;flex-direction: column;justify-content: center;width: 100%;align-items: center;flex: 1;background-color: #fff;overflow: hidden;border-bottom-left-radius: 12rpx;border-bottom-right-radius: 12rpx;">
  <view bind:tap="selectBuy" data-select_buy="1" style="display: flex;flex-direction: row;align-items: center;justify-content: flex-start;width: 100%;font-size: 28rpx;margin-bottom:40rpx;">
    <image wx:if="{{select_buy==1}}" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_select_img}}"></image>
    <image wx:else="" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_not_select_img}}"></image>
    上衣：{{top_goods_name}}
  </view>
  <view bind:tap="selectBuy"  data-select_buy="2" style="display: flex;flex-direction: row;align-items: center;justify-content: flex-start;width: 100%;font-size: 28rpx;margin-bottom:40rpx;">
    
    <image wx:if="{{select_buy==2}}" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_select_img}}"></image>
    <image wx:else style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_not_select_img}}"></image>

    下衣:{{bottom_goods_name}}
  </view>
  <view style="width: 100%;display: flex;flex-direction: row;align-items: center;justify-content: flex-end;">
        <view catch:tap="selectBuyConfirm" style="margin-top: 5rpx;margin-bottom: 10rpx;background-color: #52A76E;color: white;padding: 8rpx 20rpx;border-radius: 12rpx;font-size: 28rpx;display: flex;flex-direction: row;align-items: center;justify-content: center;margin-right: 30rpx;">
          确定
      </view>
  </view>
  </view>
</view>