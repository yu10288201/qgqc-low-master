<!--固定置顶条-->
<view style="display: flex;flex-direction: column;padding: 0; margin: 0;width: 100vw;height: 100vh;">

  <view class="top">
        <!--搜索条件-->
        <view style="margin-top:20rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;align-items: center;"> 
            <text style="margin-right: 20rpx;font-weight: 600;font-size: 26rpx;">日期:</text>
            <picker mode="date" value="{{begin_date}}" bindchange="bindBeginDateChange">
              <view class="date-picker">
                <text style='margin-left: 10rpx;'>{{begin_date}}</text>
              
                <text style='color:gray;margin-right: 10rpx;'>▼</text>
              </view>
            </picker>
            <text style="margin:0 20rpx;font-size: 26rpx;">至</text>
            <picker mode="date" value="{{end_date}}" bindchange="bindEndDateChange" >
              <view class="date-picker" >
                <text style='margin-left: 10rpx;'>{{end_date}}</text>
              <text style='color:gray;margin-right: 10rpx;'>▼</text>
              </view>
            </picker>
          </view>
        </view>
        
        <view style="margin-top:5rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;"> 
           
           <view style="display: flex;flex-direction: row;align-items: center;">
              <text style="margin-right: 20rpx;font-weight: 600;font-size: 26rpx;">区域:</text>
              <input model:value="{{region}}" style="background-color: #fff;width: 480rpx;border:1rpx solid #ccc;border-radius: 10rpx;height: 40rpx;font-size: 26rpx;" />
           </view>
          </view>
        </view>

        <view style="margin-top:5rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;"> 
           
           <view style="display: flex;flex-direction: row;align-items: center;">
              <text style="margin-right: 20rpx;font-weight: 600;font-size: 26rpx;">商家:</text>
              <input model:value="{{shop_name}}" style="background-color: #fff;width: 480rpx;border:1rpx solid #ccc;border-radius: 10rpx;height: 40rpx;font-size: 26rpx;" />
           </view>
          </view>
        </view>

        <!-- <view style="margin-top:5rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;"> 
           
           <view style="display: flex;flex-direction: row;align-items: center;">
