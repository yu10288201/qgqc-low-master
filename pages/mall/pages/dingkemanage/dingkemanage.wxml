                            </view>
                            <view class="flex-column flex-center">
                                <image style="width: 32rpx;height: 32rpx;margin-top: 5rpx;margin-right: 5rpx;" src="{{downSVGIcon}}"/>
                            </view>
                        </view>
                </picker>
                <text style="margin-right: 10rpx;font-weight: 600;font-size: 26rpx;margin-left: 100rpx;">分享范围:</text>
                <text wx:if="{{listIndex>=0&&current_item&&current_item.is_wx==1}}" style="font-size: 26rpx;margin-left: 10rpx;">微信</text>
