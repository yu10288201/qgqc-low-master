        <!--搜索按钮-->
        <view style="margin-bottom:15rpx;margin-top:15rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: flex-end;padding: 0rpx 5rpx;">
          <view catch:tap="reSetData" style="height: 52rpx; color: white;background-color:coral;;display: flex;align-items: center;justify-content: center;border-radius: 35rpx;padding: 0rpx 40rpx; font-size: 26rpx;">
            清空
          </view>
          <view catch:tap="selectData" style="height: 52rpx; color: white;background-color: #52A76E;display: flex;align-items: center;justify-content: center;border-radius: 35rpx;padding: 0rpx 40rpx; font-size: 26rpx;margin-left: 30rpx;">
            查询
          </view>
        </view>

        
        <!--导航栏-->
  </view>

  <view style="margin-top:10rpx;width: 95%;margin-left: 2.5%;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: space-between;"> 
              <view style="display: flex;flex-direction: row;align-items: center;">
                  <text style="font-weight: 600;font-size: 26rpx;margin-right: 10rpx;">日期:</text>
                  <text wx:if="{{current_item}}" style="font-size: 26rpx;">{{current_item.create_date_str}}</text>
              </view>
              
          </view>
  </view>

  <!--查询结果-->
  <view class='form' style='flex:1;display: flex;flex-direction: column;overflow: hidden;'>
      <view class='form_tittle'>
        <view class='th-head' style="text-align: center;width:15%;">
          <text  class='text'>编码</text>
        </view>
        <view class='th-center' style="text-align: center;width:15%;">
          <text class='text' >类别</text>
        </view>
        <view class='th-center' style="text-align: center;width:45%;">
          <text class='text' >商家</text>
        </view>
        <view class='th-end' style="text-align: center;width:25%;">
          <text class='text'>区域</text>
        </view>
      </view>
      <scroll-view scroll-y='true' style='width:100%;flex:1;overflow: hidden;'
      bindscrolltolower="scrollToLower">
        <view class='for' wx:for='{{items}}' wx:key='index' data-index='{{index}}' catch:tap='itemClick'>
          <view class='td-head' style='width:15%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
            <text>{{item.use_code}}</text>
          </view>
          <view class='td-center' style='width:15%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
          <text wx:if="{{item.ding_type==1}}">叮客</text> 
          <text wx:if="{{item.ding_type==2}}">叮友</text> 
          <text wx:if="{{item.ding_type==3}}">份数</text> 
          </view>				
          <view class='td-center' style='width:45%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
           <text class="td-center1">{{item.shop_name}}</text>
          </view>
          <view class='td-end' style='width:25%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
              <text class="td-center1">{{item.region}}</text>
          </view>
        </view>

      </scroll-view>

    <!--按钮-->
    

  </view>

  <view class="bottom-bar">
    <view style="margin-top:5rpx; margin-left:20rpx;margin-right:20rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;width: 100%;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;"> 
           <view style="display: flex;flex-direction: row;align-items: center;">
              <text style="margin-right: 20rpx;font-weight: 600;font-size: 26rpx;">叮客:</text>
              <text style="font-size: 26rpx;" >{{items.length}} 人</text>
              <text style="margin-right: 20rpx;font-weight: 600;font-size: 26rpx;margin-left:100rpx">区域:</text>
              <text style="font-size: 26rpx;" >{{region_count}} 个</text>
           </view>
          </view>
    </view>
   
  </view>
</view>



	










 	
    

	



