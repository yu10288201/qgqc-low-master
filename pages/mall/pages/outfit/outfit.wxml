<!--上衣名称-->
<view style="position: fixed;right: 0;left: 0;top:300rpx;margin: auto;height: 480rpx;width: 700rpx;background-color: #FFF;border-radius: 12px;display: flex;flex-direction: column;justify-content: center;align-items: center;z-index: 9999999;background-color: #ccc;border: #ccc 1rpx solid;" wx:if="{{topGoodsNameDialogShow==true}}">
 
 <view style="font-size: larger;padding: 20rpx;color: rgb(134,76,2);font-weight: 900;">上衣名称</view>
 <view  catch:tap="topGoodsNameDialogShowChange" class="badgecontent-close">X</view>

  <view style="display: flex;flex-direction: column;justify-content: center;width: 100%;align-items: center;flex: 1;background-color: #fff;overflow: hidden;border-bottom-left-radius: 12rpx;border-bottom-right-radius: 12rpx;">
  <view  style="display: flex;flex-direction: row;align-items: center;width: 100%;margin-top:15rpx;font-size: 28rpx;margin-bottom:40rpx;margin-top:10rpx;">
    <view style="margin-right: 20rpx;margin-left: 30rpx;">上衣名称</view><input model:value="{{tmp_top_goods_name}}" placeholder="" style="width: 100%;background-color: #fff;border: 1rpx solid #f2f2f2;width: 300rpx;"/>
  </view>

  <!--tmp_outfit_type-->
  <view bind:tap="selectTmpTopOutfitType" data-tmp_top_outfit_type="1" style="display: flex;flex-direction: row;align-items: center;justify-content: flex-start;width: 100%;font-size: 28rpx;margin-bottom:40rpx;">
   
    <image wx:if="{{tmp_top_outfit_type==1}}" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_select_img}}"></image>
    <image wx:else="" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_not_select_img}}"></image>
    上衣
  </view>
  <view bind:tap="selectTmpTopOutfitType" data-tmp_top_outfit_type="3" style="display: flex;flex-direction: row;align-items: center;justify-content: flex-start;width: 100%;font-size: 28rpx;margin-bottom:40rpx;">
    <image wx:if="{{tmp_top_outfit_type==3}}" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_select_img}}"></image>
    <image wx:else="" style="width: 40rpx;height: 40rpx;margin-left:30rpx;margin-right: 10rpx;" src="{{ding_not_select_img}}"></image>
    连衣裙
  </view>
  <view style="width: 100%;display: flex;flex-direction: row;align-items: center;justify-content: flex-end;">
        <view catch:tap="topGoodsNameConfirm" style="margin-top: 5rpx;margin-bottom: 10rpx;background-color: #52A76E;color: white;padding: 8rpx 20rpx;border-radius: 12rpx;font-size: 28rpx;display: flex;flex-direction: row;align-items: center;justify-content: center;margin-right: 30rpx;">
          保存
      </view>
  </view>
  
  </view>
</view>

