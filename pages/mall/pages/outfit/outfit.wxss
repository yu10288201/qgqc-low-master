/* pages/mall/pages/outfit.wxss */
.content_box{
  height: 100vh;
  width: 100vw;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: auto;
  background-color: rgb(234, 235, 230);
}
.flex_one{
  display: flex;
  position: relative;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  overflow: auto;
  height: 25vh;
  width: 100%;
  
}

.btn{
    background-color: #52A76E;
    color: white;
    padding: 8rpx 20rpx;
    border-radius: 10rpx;
}

.badgecontent-close{
  position:absolute;
  color: white;
  top:  10rpx;
  right: 20rpx;
  padding: 10rpx 20rpx;
  border-radius: 50%;
  background-color: red;
}
.home-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 94%;
  margin-left: 3%;
  margin-right: 3%;
  border-radius: 20rpx;
  border: 0.5rpx solid #dadada;
  flex-direction: row;
  background-color: rgb(254,250,245);    
  margin-top:20rpx;
  padding: 10rpx;
}


.loading {
  position: absolute;
  z-index: 999;
  top: 10rpx;
  right: 55%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100%; /* 让容器占据视口的全高 */
  width: 200rpx;
}

.loading-spinner {
  width: 30px;
  height: 30px;
  border: 8px solid rgba(0, 0, 0, 0.1);
  border-top-color: #52A76E;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}