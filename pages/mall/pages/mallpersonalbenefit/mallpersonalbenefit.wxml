<!--固定置顶条-->
<view style="display: flex;flex-direction: column;padding: 0; margin: 0;width: 100vw;height: 100vh;">

  <view class="top">
        <!--搜索条件-->
        <view style="margin-top:20rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;align-items: center;"> 
            <text style="margin-right: 20rpx;font-weight: 600;font-size: 29rpx;">日期:</text>
            <picker mode="date" value="{{begin_date}}" bindchange="bindBeginDateChange">
              <view class="date-picker">
                <text style='margin-left: 10rpx;'>{{begin_date}}</text>              
                <text style='color:gray;margin-right: 10rpx;'>▼</text>
              </view>
            </picker>
            <text style="margin:0 20rpx;font-size: 29rpx;">至</text>
            <picker mode="date" value="{{end_date}}" bindchange="bindEndDateChange" >
              <view class="date-picker" >
                <text style='margin-left: 10rpx;'>{{end_date}}</text>
              <text style='color:gray;margin-right: 10rpx;'>▼</text>
              </view>
            </picker>
          </view>
        </view>
        
        <view style="margin-top:15rpx; margin-left:20rpx;margin-right:20rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;"> 
           
           <view style="display: flex;flex-direction: row;">
              <text style="margin-right: 20rpx;font-weight: 600;font-size: 29rpx;">商家:</text>
              <view class="shop-picker">
                <input model:value="{{query_shop_name}}" style="background-color: #fff;font-size: 29rpx;flex:1;" />
                <view catch:tap="btnShopSelectClick" style="height: 42rpx;background-color: #eee;display: flex;align-items: center;justify-content: center;border-radius: 35rpx;padding: 0rpx 20rpx; font-size: 28rpx;margin-right: 10rpx;">
                  <image style="width: 32rpx;height: 32rpx;margin-top: 5rpx;margin-right: 5rpx;" src="{{downSVGIcon}}"/>选择
          </view>
              </view>
              
           </view>
          </view>
        </view>

        <view style="margin-top:15rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;padding: 0rpx 5rpx;">
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;"> 
           
           <view style="display: flex;flex-direction: row;align-items: center;">
              <text style="margin-right: 20rpx;font-weight: 600;font-size: 29rpx;">收益:</text>
                <picker   bindchange="bindQueryBenefitPickerChange" value="{{index}}" range="{{query_benefit_array}}" style="background-color: #fff;width: 530rpx;">
                        <view class="income-picker"  style="width: 100%;font-size: 29rpx;display: flex;flex-direction: row;align-items: center;justify-content: space-around;">
                            <view style="flex: 1;height: 100%;font-size: 29rpx;padding-left: 10rpx;">
                                {{query_benefit_name}}
                            </view>
                            <view class="flex-column flex-center" style="width: 40rpx;">
                                <image style="width: 32rpx;height: 32rpx;margin-top: 5rpx;margin-right: 5rpx;" src="{{downSVGIcon}}"/>
                            </view>
                        </view>
                </picker>
                
           </view>

          </view>
        </view>
        

        <!--搜索按钮-->
        <view style="margin-bottom:15rpx;margin-top:15rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: flex-end;padding: 0rpx 5rpx;">
          <view catch:tap="reSetData" style="height: 52rpx; color: white;background-color:coral;;display: flex;align-items: center;justify-content: center;border-radius: 35rpx;padding: 0rpx 40rpx; font-size: 29rpx;">
            清空
          </view>
          <view catch:tap="selectData" style="height: 52rpx; color: white;background-color: #52A76E;display: flex;align-items: center;justify-content: center;border-radius: 35rpx;padding: 0rpx 40rpx; font-size: 29rpx;margin-left: 30rpx;">
            查询
          </view>
        </view>

        
        <!--导航栏-->
  </view>

  <view style="margin-top:20rpx;width: 95%;margin-left: 2.5%;display: flex;flex-direction: row; align-items: center;justify-content: center;font-weight: 600;color: #52A76E;font-size: 29rpx;">
