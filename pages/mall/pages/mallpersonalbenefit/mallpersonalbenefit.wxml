<!--查询结果-->
<view class='form' style='flex:1;display: flex;flex-direction: column;overflow: auto;'>
    <view class='form_tittle'>
      <view class='th-head' style="text-align: center;width:25%;">
        <text  class='text'>日期</text>
      </view>
      <view class='th-center' style="text-align: center;width:40%;">
        <text class='text' >商家</text>
      </view>
      <view class='th-center' style="text-align: center;width:20%;">
        <text class='text' >收益项</text>
      </view>
      <view class='th-end' style="text-align: center;width:15%;">
        <text class='text'>数量</text>
      </view>
    </view>
    <scroll-view scroll-y='true' style='width:100%;flex:1;overflow: auto;'
    bindscrolltolower="scrollToLower">
      <view wx:if="{{benefit_array&&benefit_array.length>0}}" class='for' wx:for='{{benefit_array}}' wx:key='index' data-index='{{index}}'>
        <view class='td-head' style='width:25%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
          <text>{{item.benefit_date}}</text>
        </view>

        <view class='td-center' style='width:40%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
          <text >{{item.shop_name}}</text>
        </view>
        <view class='td-center' style='width:20%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
          <text>{{item.benefit_name}}</text> 
        </view>				
        <view class='td-end' style='width:15%;{{listIndex==index?"background-color:#52A76E;color:#fff":""}}'>
          <text>{{item.benefit_amount}} </text>
        </view>
      </view>
      <view wx:if="{{benefit_array&&benefit_array.length==0}}" style="display: flex;flex-direction: row;align-items: center;justify-content: center;width: 100%;padding: 10rpx 20rpx;font-size: 29rpx;font-weight: bold;">
              无收益记录
      </view>
     

    </scroll-view>

  <!--按钮-->
  

</view>

