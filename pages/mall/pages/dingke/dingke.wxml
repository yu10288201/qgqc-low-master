<view class="return_out" style="height: {{return_out_height}}px;top: {{return_out_top}}px;border-bottom: #eeeeee 1rpx solid;" >
    <view style="width: 100rpx;" bindtap="returnBack">
      <image bindtap="returnBack" class="return" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/mine/jiantou1.png" />
    </view>
    

	
  
      <view style="width: 160rpx;margin-left:100rpx;">
        <view wx:if="{{pageIndex==0}}">叮聊</view>
        <view wx:if="{{pageIndex==1}}">通讯录</view>
        <view wx:if="{{pageIndex==2}}">群聊</view>
        <view wx:if="{{pageIndex==3}}">我</view>
      </view>

      <view style="width: 80rpx;padding-top: 10rpx;margin-right: 120rpx;">
      <image wx:if="{{pageIndex==0||pageIndex==1}}" bindtap="toDingKeSearch" class="return" style="width: 30rpx;height: 30rpx;" src="{{search_svg}}" />
      </view>
      
   
    
	<!-- <image class="return" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/mine/jiantou1.png" /> -->
	<view class="return" style="color:#FFF">0</view>
</view>
<!-- <view style="margin-top: {{swiperTop}}px;height: {{swiperHeight}}px;width: 100%;"> -->
<swiper style="margin-top: {{swiperTop}}px;height: {{swiperHeight}}px;width: 100%;" current="{{pageIndex}}" bindchange="pageChangeEvent">
	<swiper-item style="height: 100%;width: 100%;">
		<scroll-view style="height: 100%;width: 100%;" scroll-y bindscrolltolower="loadMoreDingChat">
			<block wx:if="{{chatCustomerList.length > 0}}">
        <view wx:for="{{chatCustomerList}}" data-item="{{item}}" bindtap="toDingKeChat" style="height: 140rpx;display: flex;flex-direction: row;justify-content: center;align-items: center;" wx:key="index">
					<view style="width: 140rpx;height: 100%;display: flex;justify-content: center;align-items: center;">
                        <view style="position: relative;">
                            
                            <view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].not_read_count>99}}" class="badgecontent">99+</view>
                            <view wx:elif="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].not_read_count>0}}" class="badgecontent">{{item.lstDingMsgRecord[0].not_read_count}}</view>
                            <image style="height: 80rpx;width: 80rpx;border-radius: 12rpx;" src="{{item.avatar_url?item.avatar_url:def_avatar_url}}" />
                        </view>
						
					</view>
					<view style="border-bottom: #eeeeee 1rpx solid;flex: 1;height: 100%;display: flex;flex-direction: column;align-items: flex-start;justify-content: space-evenly;">
						<view style="display: flex;justify-content: space-between;align-items: center;width: 100%;height: 70rpx;">
							<view style="margin-top: 20rpx;font-weight: 400;font-size: 32rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
								{{item.customer_name}}
							</view>
							<view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0}}" style="padding: 0 20rpx;font-size: 26rpx;color: #aeaeae;">
								{{item.lstDingMsgRecord[0].send_time}}
							</view>
						</view>
						<view style="display: flex;justify-content: flex-start;align-items: center;width: 100%;height: 70rpx;">
							<view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].msg_type==1}}" style="margin-bottom: 20rpx;font-size: 26rpx;width: 550rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
                
								{{item.lstDingMsgRecord[0].msg}}

							</view>
              <view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].msg_type==2}}" style="margin-bottom: 20rpx;font-size: 26rpx;width: 550rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
                
								[图片]

							</view>
              <view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].msg_type==3}}" style="margin-bottom: 20rpx;font-size: 26rpx;width: 550rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
                
								[语音]{{item.lstDingMsgRecord[0].duration}}″

							</view>
              <view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].msg_type==4}}" style="margin-bottom: 20rpx;font-size: 26rpx;width: 550rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
								[视频]
							</view>

              <view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].msg_type==5}}" style="margin-bottom: 20rpx;font-size: 26rpx;width: 550rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
								[卡片] {{item.lstDingMsgRecord[0].msg}}
							</view>
              
						</view>
					</view>
				</view>

			</block>
		</scroll-view>
	</swiper-item>
	<swiper-item style="height: 100%;width: 100%;">
		<scroll-view style="height: 100%;width: 100%;" scroll-y bindscrolltolower="loadMoreDingYou">
			 <block wx:if="{{dingYouList.length > 0}}">
        <view wx:for="{{dingYouList}}" data-item="{{item}}" bindtap="toDingKeChat" style="height: 140rpx;display: flex;flex-direction: row;justify-content: center;align-items: center;" wx:key="index">
					<view style="width: 140rpx;height: 100%;display: flex;justify-content: center;align-items: center;">
                        <view style="position: relative;">
                            
                            <view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].not_read_count>99}}" class="badgecontent">99+</view>
                            <view wx:elif="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].not_read_count>0}}" class="badgecontent">{{item.lstDingMsgRecord[0].not_read_count}}</view>
                            <image style="height: 80rpx;width: 80rpx;border-radius: 12rpx;" src="{{item.avatar_url?item.avatar_url:def_avatar_url}}" />
                        </view>
						
					</view>
					<view style="border-bottom: #eeeeee 1rpx solid;flex: 1;height: 100%;display: flex;flex-direction: column;align-items: flex-start;justify-content: space-evenly;">
						<view style="display: flex;justify-content: space-between;align-items: center;width: 100%;height: 70rpx;">
							<view style="margin-top: 20rpx;font-weight: 400;font-size: 32rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
								{{item.customer_name}}
							</view>
							
						</view>
						<view style="display: flex;justify-content: flex-start;align-items: center;width: 100%;height: 70rpx;">
							<view wx:if="{{item.lstDingMsgRecord&&item.lstDingMsgRecord.length>0&&item.lstDingMsgRecord[0].msg_type==1}}" style="margin-bottom: 20rpx;font-size: 26rpx;width: 550rpx;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">
								{{item.lstDingMsgRecord[0].msg}}
							</view>
						</view>
					</view>
				</view>

			</block>
		</scroll-view>
	</swiper-item>
  <swiper-item style="height: 100%;width: 100%;">
      
	</swiper-item>
	<swiper-item style="height: 100%;width: 100%;">
	    
		<scroll-view style="height: 100%;width: 100%;" scroll-y>
				<view style="height: 140rpx;margin-top: 10rpx;margin-left: 10rpx;padding-top: 10rpx;padding-bottom: 10rpx;border-bottom-width: 15rpx;" class="flex-row flex-center bottom-line">
					<button  class="me_avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
						<image class="me_avatar" src="{{avatarUrl}}"></image>
  					</button> 
					<view class="flex-column" style="flex: 1;justify-content: space-between;height: 100%;padding-left: 10rpx;" >
						
						<view class="flex-row" >
                            <view wx:if="{{nickname&&nickname!=''}}" style="font-weight: bold;">{{nickname}}</view>
                            <view wx:else class="flex-row">
                                
                                <input type="nickname" style="margin-top: 8rpx;"  placeholder="请输入昵称" model:value="{{tmp_nick_name}}"/>
							    <view class="flex-row flex-center saveBtn" bindtap="saveNickName">设置昵称</view>
                            </view>
						</view>
						<view class="flex-row" style="height: 60rpx;">
							<view wx:if="{{phone&&phone!=''}}" class="flex-row flex-center" style="height: 100%;">{{phone}}</view>
							<button wx:else class="flex-row flex-center" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber" style="width: 200rpx;height: 100%;font-size: small;">获取手机号</button>
						</view>

					</view>
				</view>	
                <view class="me_list">
                    <view class="me_list_head" >
						<image class="me_service_img"  />
					</view>
                    <view class="me_list_middle">
                            
                            <view class="me_list_content">
                            服务
                            </view>
                            <view class="me_list_last">
                                <image class="me_list_last_img" />
                            </view>
                    </view>
                </view>
                <view class="me_list">
                    <view class="me_list_head" >
						<image class="me_collect_img"  />
					</view>
                    <view class="me_list_middle">
                            
                            <view class="me_list_content">
                            收藏
                            </view>
                            <view class="me_list_last">
                                <image class="me_list_last_img" />
                            </view>
                    </view>
                </view>
                <view class="me_list">
                    <view class="me_list_head" >
						<image class="me_set_img"  />
					</view>
                    <view class="me_list_middle">
                            
                            <view class="me_list_content">
                            设置
                            </view>
                            <view class="me_list_last">
                                <image class="me_list_last_img" />
                            </view>
                    </view>
                </view>
               
				
		
		</scroll-view>
	</swiper-item>
</swiper>


<view style="background-color: #f7f7f7;position: fixed;bottom: 0;width: 100%;display: flex;flex-direction: row;align-items: center;border-top: #eeeeee 1rpx solid; font-size: 26rpx;height: {{50 + tabBarHeight}}px;">
	<view bindtap="pageChangeEvent" data-current="0" style="display: flex;flex-direction: column;justify-content: center;align-items: center;flex: 1;height: 100%;">
        <view style="position: relative;">
            <view wx:if="{{total_not_read_count>99}}" class="badgecontent">99+</view>
            <view wx:elif="{{total_not_read_count>0}}" class="badgecontent">{{total_not_read_count}}</view>
            <view class="{{pageIndex == 0 ? 'onlymefillImg' : 'onlymeImg'}}">
        
            </view>
        </view>
        

		<view style="color: {{pageIndex == 0 ? '#0099A2' : '#000'}};">叮聊</view>
	</view>
	<view bindtap="pageChangeEvent" data-current="1" style="display: flex;flex-direction: column;justify-content: center;align-items: center;flex: 1;height: 100%;">
		<view class="{{pageIndex == 1 ? 'onlyshopfillImg' : 'onlyshopImg'}}"></view>
		<view style="color: {{pageIndex == 1 ? '#0099A2' : '#000'}};">通讯录</view>
	</view>
    <view bindtap="pageChangeEvent" data-current="2" style="display: flex;flex-direction: column;justify-content: center;align-items: center;flex: 1;height: 100%;">
		<view class="{{pageIndex == 2 ? 'onlyshopfillImg' : 'onlyshopImg'}}"></view>
		<view style="color: {{pageIndex == 2 ? '#0099A2' : '#000'}};">群聊</view>
	</view>
	<view bindtap="pageChangeEvent" data-current="3" style="display: flex;flex-direction: column;justify-content: center;align-items: center;flex: 1;height: 100%;">
		<view class="{{pageIndex == 3 ? 'meFillImg' : 'meImg'}}"></view>
		<view style="color: {{pageIndex == 3 ? '#0099A2' : '#000'}};">我</view>
	</view>
</view>