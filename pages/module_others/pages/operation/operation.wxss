/* pages/module_others/pages/operation/operation.wxss */
.btn {
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/btn/button_mid_yellow3.png")no-repeat;
  width: 170rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 10rpx;
  font-size: 26rpx;
  height: 44rpx;
  color: white;
  font-weight: bold;
}

.chooseSmallType {
  width: 21%;
  margin: 3% 5%;
  box-shadow: 3px 3px 6px rgba(0, 0, 0, .62), 0 4px 6px rgba(0, 0, 0, .3);
  background: #d8b070;
  padding: 1%;
  border-radius: 5rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.chooseType {
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  width: 100%;
  /* border: 1px solid#000; */
  height: 6%;
  flex-wrap: wrap;
}

.choose {
  position: absolute;
  top: 10%;
  z-index: 2;
  width: 100%;
  background-color: #fff;
}

.tips {
  width: 100%;
  text-align: center;
  font-weight: 800;
  color: #d8b070;
}

.listRow {
  display: flex;
  margin: 15rpx 0 15rpx 0;
  height: 100rpx;
  align-items: center;
  border-top: 1rpx solid #000;
  border-bottom: 1rpx solid #000;
}

.boxOrder {
  /* margin-top: 15rpx; */
  text-align: center;
  width: 45%;

}

.list {
  border-radius: 5rpx;
  color: #fff;
  margin-top: 50rpx;
  margin-left: 5%;
  width: 90%;
  border: 1rpx solid #d8b070;
  background-color: rgb(63, 93, 112);
}