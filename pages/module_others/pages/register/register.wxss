.page {
  width: 100vw;
  height: 100vh;
  background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/background.png');
  background-size: 100% 100%;
  position: fixed;
  display: flex;
  flex-direction: column;
  align-items: center;
  /*垂直居中*/
}

.logos {
  width: 50rpx;
  height: 50rpx;
  margin-right: 15rpx;
}

checkbox .wx-checkbox-input {
  width: 30rpx;
  height: 30rpx;
}

.top-mode {
  height: 230rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.userAvatarUrl {
  border-radius: 50%;
  height: 80px;
  width: 80px;
}

.userName {
  font-size: 42rpx;
  color: white;
}

.register-mode {
  display: flex;
  width: 100%;
  background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/filter.png');
  background-size: 100% 100%;
  justify-content: center;
  padding-bottom: 45rpx;
}

/* 表单 */

.div {
  display: flex;
  margin-left: 10rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.itemLeft {
  width: 23%;
}

.itemRight {
  display: flex;
}

.text {
  font-size: 26rpx;
}

.cityPickerView {
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  padding-right: 20rpx;
  padding-left: 20rpx;
  font-size: 28rpx;
  background-color: #fff7f5;
  height: 50rpx;
  line-height: 50rpx;
}

.nabla {
  font-size: 32rpx;
  color: rgb(175, 169, 169);
  border-top-right-radius: 25rpx;
  border-bottom-right-radius: 25rpx;
  border-right: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  margin-right: 10rpx;
  background-color: #fff7f5;
  height: 50rpx;
}

.nameInput {
  font-size: 32rpx;
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  text-align: center;
  width: 230rpx;
  margin-right: 10rpx;
  margin-left: 12rpx;
  background-color: #fff7f5;
  height: 50rpx;
}

.gender {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-left: 20rpx;
  font-size: 32rpx;
}

.phoneText {
  height: 50rpx;
  font-size: 32rpx;
  color: white;
  background-color: #519763;
  border: 2rpx solid #519763;
  border-top-right-radius: 25rpx;
  border-bottom-right-radius: 25rpx;
  padding-right: 10rpx;
  width: 160rpx;
  text-align: center;
  padding-left: 10rpx;
  margin-right: 10rpx;
  margin-left: 20rpx;
}

.phoneButton {
  background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/buttom.png');
  background-size: 100% 100%;
  border: none;
  color: white;
  height: 70rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  width: 180rpx;
  text-align: center;
  padding: 0;
  margin: 0;
}

.phoneButton::after {
  border: none;
}

.phoneInput {
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  background-color: #fff7f5;
  text-align: center;
  width: 220rpx;
  height: 50rpx;
  min-height: 50rpx;
}

.pc {
  font-size: 32rpx;
  text-align: center;
}

.sureCodeInput {
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  background-color: #fff7f5;
  text-align: center;
  width: 195rpx;
  height: 50rpx;
  min-height: 50rpx;
}

.sureCodeText {
  font-size: 32rpx;
  color: white;
  background-color: #519763;
  border: 2rpx solid #519763;
  border-top-right-radius: 25rpx;
  border-bottom-right-radius: 25rpx;
  padding-right: 20rpx;
  text-align: right;
  padding-left: 20rpx;
  margin-right: 10rpx;
  margin-left: 20rpx;
}

/* 出生日期 */

.birthday {
  width: 290rpx;
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  text-align: center;
  line-height: 50rpx;
  height: 50rpx;
  font-size: 32rpx;
  background-color: #fff7f5;
}

.passwordInput {
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  text-align: center;
  width: 320rpx;
  height: 50rpx;
  margin-right: 10rpx;
  background-color: #fff7f5;
}

.registerButton {
  background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/registerButton.png');
  background-size: 100% 100%;
  width: 500rpx;
  border: none;
  height: 120rpx;
  line-height: 90rpx;
  font-size: 40rpx;
  color: white;
}

.registerButton::after {
  border: none;
}

.star {
  width: 13rpx;
  height: 12rpx;
  margin-bottom: 36rpx;
}

.return_out {
  width: 40rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.return {
  width: 17rpx;
  height: 31rpx;
}

.mask {
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
  background: #000;
  z-index: 9000;
  opacity: 0.7;
}

.modalDlg {
  width: 580rpx;
  height: 620rpx;
  position: fixed;
  top: 50%;
  left: 0;
  z-index: 9999;
  margin: -370rpx 85rpx;
  background-color: #fff;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.showNeedClose {
  width: 100%;
  height: 80%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.exitButton {
  width: 40%;
  background-color: #e4393c;
  color: white;
  font-weight: bold;
  font-size: 36rpx;
  height: 81rpx;
  border-radius: 10rpx;
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  padding-left: 14px;
  padding-right: 14px;
  box-sizing: border-box;
  text-align: center;
  text-decoration: none;
  line-height: 81rpx;
  -webkit-tap-highlight-color: transparent;
  overflow: hidden;
}

.window-bg {
  position: fixed;
  left: 0px;
  top: 0px;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 88;
  display: flex;
  justify-content: center;
  align-items: center;
}

.window-item {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-evenly;
  align-items: center;
  align-items: center;
}

.window-item-title {
  font-size: 35rpx;
  display: flex;
  justify-content: center;
}



.btn-bar {
  display: flex;
  width: 100%;
}

.cancelBtn {
  margin: 0%;
  padding: 0;
  background-color: rgba(255, 60, 0, 0.76);
  width: 25%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #ffffff;
}

.confirmBtn {
  margin: 0%;
  padding: 0;
  background-color: #2bca52;
  width: 25%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: white;
}

.window {


  width: 94%;
  height: 37%;
  background: white;
  border-radius: 15rpx;
}

.window-item-content {
  font-size: 38rpx;
  /* 宋体 */
  font-family: SimSuncss;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
}

.window-item-title {
  font-size: 70rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
}

.jump {
  width: 100%;
  display: flex;
}

.exitButton1 {
  width: 40%;
  background-color: #33ff00;
  color: white;
  font-weight: bold;
  font-size: 36rpx;
  height: 81rpx;
  border-radius: 10rpx;
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  padding-left: 14px;
  padding-right: 14px;
  box-sizing: border-box;
  text-align: center;
  text-decoration: none;
  line-height: 81rpx;
  -webkit-tap-highlight-color: transparent;
  overflow: hidden;
}