      </view>
    </block>
  </view>

  <!-- <view class="fix-navbar" wx:if="{{fixTop<scrollTop}}" > -->
  <!-- <block wx:for="{{navbarTitle}}" wx:key="index">
      <view class="navbar-item {{navbarActiveIndex === index ? 'navbar-item-active' : ''}}" data-navbar-index="{{index}}" catchtap="onNavBarTap">
        <text>{{item}}</text>
      </view>
    </block> -->



  <!-- <scroll-view style='height:{{pop_window}}px' scroll-y="true"> -->

  <view class='tabs-view'>
