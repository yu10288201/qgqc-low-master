        {{item.title}}
      </button>
    </view>
    <view class='drop_down'>
      <image class='dropImage' src='https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/drop_down.png' />
    </view>

