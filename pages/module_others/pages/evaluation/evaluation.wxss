body {
  padding: 0;
  margin: 0;
}

page {
  background-color: #f0f0f0;
}

.movie-container {
  display: flex;
  flex-direction: column;
}

.btn {
  display: flex;
  justify-content: center;
  min-width: 150rpx;
  height: 60rpx;
  font-size: 25rpx;
  border: 1px solid black;
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 10rpx 0 20rpx;
  font-weight: bold;
  align-items: center;
}

.btn-selected {
  border: 1px solid red;
  color: red;
}

.navbar {
  display: flex;
  position: absolute;
  left: 0;
  top: 0;
  z-index: 500;
  width: 100%;
  height: 50px;
  flex-direction: row;
  text-align: center;
  color: #a8a8a8;
  font-size: 15px;
  box-sizing: border-box;
  background-color: #fff;
  border-bottom: 1rpx solid #dfdfdf;
}

.fix-navbar {
  display: flex;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 500;
  width: 100%;
  height: 50px;
  flex-direction: row;
  text-align: center;
  color: #a8a8a8;
  font-size: 15px;
  box-sizing: border-box;
  background-color: #fff;
  border-bottom: 1rpx solid #dfdfdf;
}

.navbar-item {
  flex: 1;
  padding: 26rpx 0px;
}

.navbar-item-active {
  transition: all 0.3s;
  border-bottom: 10rpx solid #494949;
  color: #494949;
}

.movie-content-wrapper {
  /* min-height: 2000rpx; */
  background-color: #fff;
  margin-top: 15rpx;
  padding-left: 20rpx;
}

.swiper {
  /* height: 765rpx; */
  overflow: hidden;
}

.movie-content-wrapper .title {
  height: 70rpx;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  border-bottom: 0.5px solid #a8a8a8;
}

.tabs-view {
  margin-top: 51px;
  min-height: 150rpx;
  width: 99%;
  border-bottom: 1rpx solid #dfdfdf;
  background-color: #fff;
  margin-bottom: 10rpx;
}

.tabs {
  display: -webkit-flex;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  /* 如果需要进行自动换行，且执行左右或者等间距布局可以对justify-content属性进行控制，此外可以给定子盒子一定的宽度，就能实现float流式布局的效果 */
}

.tabs .tab1 {
  display: flex;
  justify-content: center;
  height: 40rpx;
  min-width: 160rpx;
  border: 1rpx solid black;
  font-size: 25rpx;
  border-radius: 20rpx;
  margin: 10rpx 10rpx 0 10rpx;
}

.tabs .tab2 {
  display: flex;
  justify-content: center;
  height: 40rpx;
  color: #a8a8a8;
  min-width: 160rpx;
  border: 1rpx solid #a8a8a8;
  font-size: 25rpx;
  border-radius: 20rpx;
  margin: 10rpx 10rpx 0 10rpx;
}

.drop_down {
  display: flex;
  justify-content: center;
  margin-top: 15rpx;
  margin-bottom: 10rpx;
}

.dropImage {
  height: 30rpx;
  width: 40rpx;
}

.review {
  height: 80rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 99%;
  border-bottom: 1rpx solid #dfdfdf;
  background-color: #fff;
}

.review .review-text {
  margin-left: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.evaluations {
  margin: 1rpx;
  width: 99%;
  border-bottom: 1rpx solid #a8a8a8;
  padding-top: 10rpx;
  display: flex;
}

.avatar {
  height: 100%;
  width: 170rpx;
}

.avatar_Image {
  height: 150rpx;
  width: 150rpx;
  border-radius: 75rpx;
  margin: 20rpx 10rpx 0 10rpx;
}

.main_view {
  height: 100%;
  width: 100%;
}

.main_view .row1 {
  height: 7%;
  width: 97%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.main_view .row1 .nickname {
  margin-left: 10rpx;
  font-size: 32rpx;
}

.main_view .row1 .date {
  font-size: 30rpx;
  color: #a8a8a8;
}

.main_view .row2 {
  height: 5%;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.main_view .row2 .star {
  margin-left: 10rpx;
}

.main_view .row2 .isConsumption {
  margin-right: 20rpx;
  font-size: 30rpx;
  color: #a8a8a8;
}

.main_view .text {
  /* height: 30%; */
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.main_view .text .text-view {
  width: 90%;
  /* height:80%; */
  margin-left: 5%;
  margin-top: -5%;
  font-size: 28rpx;
  /* letter-spacing:2px;

  text-align:justify; */
  text-indent: 2em;
  line-height: 15pt;
  /* 通过以下四行实现收缩功能 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  text-overflow: ellipsis;
  overflow: hidden;
}

/* 最多显示3行 */

/* 透明度75% */

.ellipsis {
  /* height:30%; */
  -webkit-line-clamp: 4;
  opacity: 0.75;
  color: #888;
}

/* 全部显示 */

.unellipsis {
  -webkit-line-clamp: 0;
  /* 不透明 */
  opacity: 1;
  color: black;
}

.text3 {
  margin: 15rpx;
}

.main_view .text .text-all {
  font-size: 24rpx;
  margin: 10rpx;
  color: blue;
}

.main_view .pictures {
  height: 50%;
  width: 103%;
  /* display: flex; */
}

.main_view .pictures .picture {
  width: 180rpx;
  height: 180rpx;
  margin: 7rpx;
}

.main_view .support {
  height: 5%;
  font-size: 32rpx;
  width: 100%;
}

.loadMore {
  height: 50rpx;
  display: flex;
  justify-content: center;
  background-color: #fff;
  margin-top: 10rpx;
}

.loadCompleted {
  display: flex;
  justify-content: center;
}

