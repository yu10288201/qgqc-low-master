.top {
  /* background-color: #009AA2; */
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/weixinpay/bg3.png") no-repeat;
  background-size: 100% 100%;
  width: 100%;
  height: 95%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.titleImg {
  display: flex;
  justify-content: center;
  padding-bottom: 20rpx;
}

.titleImage {
  width: 100rpx;
  height: 100rpx;
}

.return_out {
  position: fixed;
  top: 40px;
  left: 5px;
  width: 75rpx;
  height: 75rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.return {
  width: 17rpx;
  height: 31rpx;
}

.title {
  width: 80%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  font-size: 32rpx;
  margin: 15rpx;
  border: 1rpx solid rgb(81, 59, 38);
  padding: 15rpx;
}

.Ttitle {
  width: 95%;
  display: flex;
  border: 1rpx solid rgb(81, 59, 38);
  /* margin: 15rpx 15rpx 0rpx 15rpx; */
  justify-content: center;
  align-content: center;
  /* padding-left: 15rpx; */
  /* padding-right: 15rpx;  */
}

.pop {
  position: absolute;
  width: 100vh;
  height: 100vh;
  background-color: #000;
  opacity: 0.4;
  top: 0;
  left: 0;
  z-index: 5;
}

.Thead {
  display: flex;
  font-size: 32rpx;
  /* margin: 10rpx; */
  border-right: 1rpx solid rgb(81, 59, 38);
  /* padding: 10rpx; */
  justify-content: center;
  width: 33%;
}

.Tbody {
  display: flex;
  border-left: 1rpx solid rgb(81, 59, 38);
  border-right: 1rpx solid rgb(81, 59, 38);
  border-bottom: 1rpx solid rgb(81, 59, 38);
  justify-content: center;
  align-content: centet;
  width: 100%;
}

.text {
  font-size: 30rpx;
  font-weight: 700;
}

.text1 {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
}

.text2 {
  font-size: 30rpx;
  font-weight: 500;
}

.body {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-direction: column;
  padding: 0rpx 15rpx 0rpx 15rpx;
  height: 65vh;
  width: 95%;
  margin: -1rpx 15rpx 0rpx 15rpx;
  /* border: 1rpx solid  rgb(81,59,38); */
}

.detail {
  width: 80%;
  height: 50%;
  background-color: white;
  position: absolute;
  z-index: 5;
  display: flex;
  flex-direction: column;
  border-radius: 10rpx;
  justify-content: center;
  
}

.detail_1 {
  display: flex;
  flex-direction: row;
  justify-content: center;
  font-size: 42rpx;
  height: 100rpx;
  align-items: center;
}

.detail_2 {
  display: flex;
  flex-direction: row;
  justify-content: left;
  height: 60rpx;
  align-items: center;
  font-size: 34rpx;
  margin-left: 60rpx;
}

.prestoreList {
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: center;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
}

.prestoreListDetailButton {
  width: 90%;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: flex-end;
}

.prestoreListDetailButton_1 {
  width: 20%;
  background-color: #519763;
  text-align: center;
  color: white;
  border-radius: 10rpx;
}