.page {
  width: 100%;
  height: 100%;
  background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/background.png');
  background-size: 100% 100%;
  position: fixed;
  display: flex;
  flex-direction: column;
  align-items: center; /*垂直居中*/
}

.logos {
  width: 50rpx;
  height: 50rpx;
  margin-right: 15rpx;
}

.top-mode {
  position: fixed;
  margin-top: 8%;
  height: 230rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.userAvatarUrl {
  border-radius: 50%;
  overflow: hidden;
  height: 80px;
  width: 80px;
  display: flex;
}

.userName {
  font-size: 42rpx;
  color: white;
  margin-bottom: 10rpx;
}

.register-mode {
  margin-top: 45%;
  display: flex;
  width: 100%;
  height: 65%;
  /* background-color: #fffdfa; */
  background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/filter.png');
  background-size: 100% 100%;
  justify-content: center;
}

/* 表单 */

.div {
  display: flex;
  margin-left: 10rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.itemLeft {
  width: 23%;
}

.itemRight {
  display: flex;
  width: 65%;
}

.text {
  font-size: 26rpx;
}

.cityPickerView {
  border-top-left-radius: 25rpx;
  border-bottom-left-radius: 25rpx;
  border-left: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  padding-right: 20rpx;
  padding-left: 20rpx;
  font-size: 28rpx;
  background-color: #fff7f5;
  height: 50rpx;
  line-height: 50rpx;
}

.nabla {
  font-size: 32rpx;
  color: rgb(175, 169, 169);
  border-top-right-radius: 25rpx;
  border-bottom-right-radius: 25rpx;
  border-right: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  margin-right: 10rpx;
  background-color: #fff7f5;
  height: 50rpx;
}

.nameInput {
  font-size: 32rpx;
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  text-align: center;
  width: 230rpx;
  margin-right: 10rpx;
  margin-left: 12rpx;
  background-color: #fff7f5;
  height: 50rpx;
}

.gender {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-left: 20rpx;
  font-size: 32rpx;
}

.phoneText {
  height: 50rpx;
  font-size: 32rpx;
  color: white;
  background-color: #519763;
  border: 2rpx solid #519763;
  border-top-right-radius: 25rpx;
  border-bottom-right-radius: 25rpx;
  padding-right: 10rpx;
  width: 160rpx;
  text-align: center;
  padding-left: 10rpx;
  margin-right: 10rpx;
  margin-left: 20rpx;
}

.phoneButton {
  background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/buttom.png');
  background-size: 100% 100%;
  border: none;
  color: white;
  height: 70rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  width: 180rpx;
  text-align: center;
  padding: 0;
  margin: 0;
}

.phoneButton::after {
  border: none;
}

.phoneInput {
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  background-color: #fff7f5;
  text-align: center;
  width: 220rpx;
  height: 50rpx;
  min-height: 50rpx;
}

.pc {
  font-size: 32rpx;
  text-align: center;
}

.sureCodeInput {
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  background-color: #fff7f5;
  text-align: center;
  width: 195rpx;
  height: 50rpx;
  min-height: 50rpx;
}

.sureCodeText {
  font-size: 32rpx;
  color: white;
  background-color: #519763;
  border: 2rpx solid #519763;
  border-top-right-radius: 25rpx;
  border-bottom-right-radius: 25rpx;
  padding-right: 20rpx;
  text-align: right;
  padding-left: 20rpx;
  margin-right: 10rpx;
  margin-left: 20rpx;
}

/* 出生日期 */

.birthday {
  width: 290rpx;
  border-top-left-radius: 25rpx;
  border-bottom-left-radius: 25rpx;
  border-left: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  text-align: center;
  line-height: 50rpx;
  height: 50rpx;
  font-size: 32rpx;
  background-color: #fff7f5;
}

.passwordInput {
  border-radius: 25rpx;
  border: 2rpx solid #d6d6d6;
  text-align: center;
  width: 300rpx;
  height: 50rpx;
  margin-right: 10rpx;
  background-color: #fff7f5;
}

.registerButton {
  background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/register/registerButton.png');
  background-size: 100% 100%;
  width: 500rpx;
  border: none;
  height: 120rpx;
  line-height: 90rpx;
  font-size: 40rpx;
  color: white;
}

.registerButton::after {
  border: none;
}

.star {
  width: 13rpx;
  height: 12rpx;
  margin-bottom: 36rpx;
}

.return_out {
  position: fixed;
  top: 40px;
  left: 15px;
  width: 40rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.return {
  width: 17rpx;
  height: 31rpx;
}
