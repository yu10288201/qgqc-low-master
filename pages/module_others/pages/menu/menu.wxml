                选择口味</view>
            </view>
            <!-- 客人备注 -->
            <!--2020-11-19 多拼粥重写备注框 -->
            <view id="d" style="width:95%;margin-left:15rpx;margin-top:14rpx">
              <s-remarkView_new readOnly="{{false}}" lock="{{lock}}" onHide="{{showRemarkList || showTaste || showMaterial || showpeicai || showMultipleEatMethodView}}" remarkTitle="客人备注：" style="width: 92%;" tastesRemark="{{tastesRemark}}" remarkValue="{{remark}}" spec_type="{{spec_type1}}" bind:hideRemark="hideRemark" bind:remarkBack="remarkBack" bind:showRemarkList="showRemarkList_new" quickRemark="{{quickRemark}}" />
            </view>
            <!-- 确认保存、修改保存 -->
            <view class='oneline' style='height: 7%;font-size:26rpx;flex-direction: row-reverse;justify-content:space-around;width:100%;margin-top: 70rpx;'>
              <view class='btn_small_d' style='width:150rpx;' bindtap='addToCartMorePoridge'>确定</view>
            </view>
          </view>
        </scroll-view>
        <view style="height:10rpx;width:100%;border-top:2rpx"></view>
      </view>
    </van-popup>
  </view>

  <!-- 多规格菜品 选择弹窗-选择规格 -->
