    <s-multipleEatMethodAndWeightSideDishesView SideDishList="{{SideDishList}}" eatMethodRemark="{{eatMethodRemark}}" eatMethodTastesRemark="{{eatMethodTastesRemark}}" dishesInfo="{{dishes}}" dishes_type="{{dishes_type}}" eatMethodArray="{{eatMethodArray}}" tasteList="{{tasteList}}" quickRemarkList="{{quickRemarkList}}" eatMethodChooseIndex="{{eatMethodChooseIndex}}" SideDishList_choose="{{sideDishList_choose}}" bind:submitA="submitSpecAndTaste" bind:showpeicai="showpeicaiAndTaste" model:sideDishIndex="{{sideDishIndex}}" isTable="{{flase}}" />
  </van-popup>

  <!-- 菜品介绍弹窗 -->
  <van-popup show="{{showIntroduction}}" custom-style="{{dishes.spec_type==10?'height:80%':(dishes.spec_type==9 || dishes.spec_type==91)?'height:80%':'height:20%'}};width: 90%;" closeable="{{true}}" bind:close="showIntroduction" round="{{true}}">
    <s-remarkView spec_type="{{dishes.spec_type}}" readOnly="{{true}}" remarkTitle="菜品介绍：" remarkValue="{{goodsIntroduce}}" isIntroduction="{{true}}" />
  </van-popup>

</view>

<view style='width:100%'>
  <!-- 左侧菜单 -->
  <view class="list-left-menu" style='margin-top: 70rpx; padding: 0; height:{{windowHeight - 35 - marginBottom - 40}}px; display: flex; flex-direction: column;justify-content: start;'>
    <view class='goindex-btn' bindtap='goindex'>
      <image style='width:40rpx;height:30rpx' src='https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_left_white.png'></image>
      <view style='color:#fff'>首页</view>
    </view>
    <!-- 左侧菜单-滚动 -->
    <scroll-view class="list-left-menu-scroll" scroll-y style='height:{{windowHeight - 35 - marginBottom - 40 - 40}}px;'>
      <!-- 在切瓜切菜的一级菜单上不再显示超值菜品和临时菜品，也不再显示超级套餐，所以把原来的套餐改成普通套餐，底下的二级菜单只保留普通套餐，把超级套餐去掉-->
      <block wx:for="{{menuList}}" wx:key="index">
        <view wx:if="{{item.class_i_id !='4434' && item.class_i_id !='4421' && item.mainType != '超值菜品' && item.mainType != '临时菜品' && item.mainType != '套餐'}}" 
            class="list-menu-name {{c1Idx==index?'list-left-menu-box-selected':'list-left-menu-box-unselect'}}" data-c1-idx="{{index}}" bindtap="tapClassify1">{{item.mainType}}</view>
