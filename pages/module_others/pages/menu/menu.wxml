          <view class='oneline' style='font-size:30rpx;padding:8rpx 0rpx'>{{dishes.dishes_name}}</view>
          <view class='oneline' style="padding: 10rpx 0rpx;align-items: baseline;">

            <text style="width:50%">总数量：{{eatMethodArrayNumber}}</text>
            <text>总金额：{{eatMethodArraySum}}</text>
          </view>

        </view>
      </view>
    </view>
    <scroll-view scroll-y="true" style="height:83%;margin-left:2rpx">
      <!-- 做法 -->
      <view style="height:30%;width:98%;margin-left:2rpx">
        <s-multipleEatMethodView bind:submitEatMethod="submitEatMethod" style="height:25%;margin-top: 2%;" bind:showMultipleEatAndSpecView="showMultipleEatAndSpecView" needRemain="{{needRemain}}" xdswidth="{{xdswidth}}" eatMethodArray="{{eatMethodArray}}" em_arry="{{em_arry}}" eamChoose="{{eamChoose}}" dishesInfo="{{dishes}}" isTable="{{true}}" isType10="{{dishes.spec_type == 10 ? true: false}}" binddmev="dmev" bindclickEatAndMethod="clickEatAndMethod" EatmethodAndSpec="{{dishes.spec_type == 10 ? EatmethodAndSpec: ''}}" />
      </view>
      <view wx:if="{{dishes.sideDishes!=0}}" style="height: 30%;margin-bottom: 3%;width: 98%;margin-left: 2rpx;margin-top: 2%;">
        <s-sideDishesView wx:if="{{dishes.sideDishes!=0}}" SideDishList="{{SideDishList}}" SideDishList_choose="{{SideDishList_choose}}" bind:submitSideDish="submitSideDish" bind:changeBoxNum="changeBoxNum" isTable="{{true}}" />
      </view>

      <view wx:if="{{!shrinkIntrIntroduction}}" style="border: 2rpx solid #888;margin-top: 20rpx;width:98%;margin-bottom:2%">
        <view style='font-size:26rpx;font-weight:bold'>菜品介绍：</view>
        <text wx:if="{{showRemarkList || showTaste || showpeicai || showMultipleEatAndSpecView}}" style="font-size:24rpx;height:150rpx;" disabled='true' cursor-spacing="100" fixed class='textarea' value='{{dishes.dishes_introduce}}'></text>
        <textarea style="font-size:24rpx;height:150rpx;" disabled='true' cursor-spacing="100" fixed class='textarea' value='{{dishes.dishes_introduce}}'></textarea>
      </view>

      <view class="oneline" style="width: 100%;justify-content: space-around;">
        <view class='btn_small_brown' wx:if="{{shrinkIntrIntroduction}}" style='width:150rpx;' bindtap='showIntroduction'>菜品介绍
        </view>

        <view class='btn_small_brown' style='width:150rpx;' wx:if="{{dishes.sideDishes==0&&dishes.flavor==1}}" bindtap='chooseTaste'>选择口味
        </view>

        <view class='btn_small_brown' style='width:200rpx;height:50rpx' wx:if="{{dishes.sideDishes!=0}}" bindtap='showpeicaiAndTaste'>选择配菜和口味</view>
      </view>

      <!-- 多做法客人备注 -->
      <!--2020-11-19 多做法重写备注框 -->
      <view style="margin-top: 3%;border-radius:5rpx;width:98%;margin-left:2rpx">
        <s-remarkView_new readOnly="{{false}}" spec_type="{{dishes.spec_type}}" onHide="{{showRemarkList || showTaste || showpeicai || showMultipleEatAndSpecView}}" remarkTitle="客人备注：" style="width: 92%;" tastesRemark="{{tastesRemark}}" remarkValue="{{remark}}" bind:hideRemark="hideRemark" bind:remarkBack="remarkBack" bind:showRemarkList="showRemarkList_new" quickRemark="{{quickRemark}}" />
      </view>

      <view class='oneline' style='margin-top:20rpx;font-size:26rpx;flex-direction: row-reverse;justify-content:space-around;width:100%'>
        <view class='btn_small_brown' wx:if="{{selectInfovv_flag}}" style='width:150rpx' bindtap='addToCart4'>确定</view>
        <view class='btn_small_brown' wx:else style='width:150rpx' bindtap="{{dishes.spec_type == 10 ? 'addToCartBySpecAndMethod':'addToCart3'}}">确定</view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 选择菜品弹窗 -->
<view class='popup-window-bg' wx:if="{{showChooseDishesModel}}" style="flex-direction:column;z-index:999">
  <view class='popup-window-dishes' style="height:auto;align-items: center;" wx:if="{{showChooseDishesModel}}">
    <text style="font-size:32rpx;width:100%;color:red;margin-left: 20rpx;margin-top:25px;font-weight:bold;">选择菜品：</text>
    <view class="modal-title dishes-mod-1" style="width:90%;height:60%;margin-bottom: 25rpx;">
      <scroll-view scroll-y='true' style='width:100%;height: 300rpx;' class="dishes_scroll">
        <label class="radio dishes-lab" data-type="0" bindtap="chooseChangeDishes" wx:for="{{newList}}" data-index="{{index}}" data-item="{{item}}" style="border-bottom: 0.5px solid green;padding-bottom: 2px;width:100%;height:auto;">
          <view class="box" style="border-right:1rpx solid green;width:20%;height:80rpx;margin-bottom: -2rpx;">
            <radio value="r1" checked="{{index == chooseDishesIndex ? 'true':''}}" />
          </view>
          <view class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
            <text style="font-size:32rpx;">{{item.disher_weight_ceiling}}斤</text>
          </view>
          <view class="box" style="width:50%;height:80rpx;margin-bottom: -2rpx;">
            <text style="font-size:32rpx;">{{item.name}}</text>
          </view>
        </label>
      </scroll-view>
    </view>

    <image style='width:60rpx;height:60rpx;float:right;position: absolute;right: 10px;top:10px' src='{{i_close_img_url}}' bindtap='chooseDishes'></image>

  </view>
</view>


<!-- 视频简介弹窗 -->
<view bindtap='videoInfo' catchtouchmove="aaa" class='popup-window-bg' wx:if='{{video_open}}'></view>
<view class='popup-window' catchtouchmove="aaa" wx:if='{{video_open}}' style="height: auto;padding: 0 0 40rpx;top: 20%;">
  <view style="height:600rpx">
    <image style='width:60rpx;height:60rpx;float:right;position: absolute;right: 20px;top:20px' src='{{i_close_img}}' bindtap='closeWindow_video'></image>
    <view class="video_text" style="margin-top:5%">{{video_name}}</view>
    <view class="video_text">视频简介:</view>
    <view class="video_style">
      <video wx:if="{{is_video_show==1}}" src="{{video_src}}"></video>
    </view>
  </view>
</view>

<!-- 购物车菜篮子 -->
<view class="drawer_screen" bindtap="showCartList" id="s3" data-statu="close" wx:if="{{showCart}}"></view>
<view class="cartlist-float" wx:if="{{showCart}}">
  <view style='background:#F0F0F0;height:60rpx'>
    <label class='label-cart-bar'>
      <label style='padding:10rpx;color:orange;font-weight:bold'>已选菜品</label>
    </label>
    <label class='icon-clear' bindtap='clearCartList'>
      <i class="iconfont icon-lajitong"></i>
      <label class="label-clear">清空菜品篮</label>
    </label>
  </view>

</view>

