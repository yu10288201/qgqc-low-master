<wxs module="Menu">
  function getCartListTotal(cartList) {
    var total = 0
    var total1 = 0
    cartList.forEach(function (item) {
      if (item.spec_type == 100 || item.spec_type == 101) {
        total1 = total1 + (item.sum1 ? item.sum1 : 0)
      } else {
        total = total + (item.sum)
      }
    })
    return { "total": toFixed(total), "total1": toFixed(total1) }
  }

  function getCartListCount(cartList) {
    if (!cartList) { return '' }
    var count = 0
    cartList.forEach(function (item) {
      // if (item.item_type != 1) {
      // 	if (item.countNum) {
      // 		count = parseInt(item.countNum) + count
      // 	} else {
      if ((item.dishes_spec_type == 8 || item.dishes_spec_type == 2)) {
        if (item.en_index || item.em_index) {
          count = (item.en_index.length || item.em_index.length) + count
        } else {
          count = parseInt(item.item_number) + count
        }
      } else {
        count = parseInt(item.number) + count
      }
      // 	}
      // }
      // if ((item.dishes_spec_type == 0 || item.dishes_spec_type == 21 || item.dishes_spec_type == 23 || item.dishes_spec_type == 25
      // 	|| item.dishes_spec_type == 26 || item.dishes_spec_type == 27) && item.specal_type != 6 && item.item_type == 1) {
      // 	count = parseInt(item.item_number) + count
      // }
    })
    return count
  }
  function getCountNum(cartList, id) {
    if (cartList.length && id) {
      var countNum = 0
      cartList.forEach(function (item) {
        if (item.dishes_id === id) {
          if (((item.dishes_spec_type == 8) || item.dishes_spec_type == 2) && item.dishes_status != 20) {
            if (item.en_index || item.em_index) {
              countNum += (item.en_index.length || item.em_index.length)
            } else {
              countNum += parseInt(item.item_number)
            }
          } else {
            countNum = countNum + parseInt(item.number)
          }
        }
      })
      return countNum === 0 ? '' : countNum
    } else {
      return ''
    }
  }
  function getCountNum2(cartList, id) {
    if (cartList.length && id) {
      var countNum = 0
      cartList.forEach(function (item) {
        if (item.uuid === id) {
          countNum = countNum + parseInt(item.number)
        }
      })
      return countNum === 0 ? '' : countNum
    } else {
      return ''
    }
  }
  function toFixed(num, len) {
    if (len == undefined) {
      len = 2
    }
    return parseFloat(num).toFixed(len)
  }
  function getTotalBySum(cartList, id) {
    var total = 0
    cartList.forEach(function (item) {
      // if (id === item.dishes_id && item.dishes_status != 20) {
      if (id === item.dishes_id) {
        total = total + item.sum
      }
    })
    return total > 0 ? total.toFixed(2) : ''
  }
  function getTotalBySumS(cartList, id) {
    var total = 0
    cartList.forEach(function (item) {
      if (id === item.dishes_id) {
        total = total + item.sum
      }
    })
    return total
  }
  function getDishesStatus(cartList, id) {
    var f = false
    cartList.forEach(function (item) {
      if (id === item.dishes_id && item.dishes_status == 9) {
        f = true
      }
    })
    return f;
  }
  function getDishesPrice(cartList, id) {
    var msg = ''
    var type = ''
    if (cartList.length && id) {
      cartList.forEach(function (item) {
        if (item.dishes_id === id) {
          if (item.dishes_spec_type == 8 && item.dishes_status != 20) {
            if ((item.en_index && item.en_index[0].em_name == '全部位') || (item.lstOrderEmBlockEating && item.lstOrderEmBlockEating[0].em_block_name == '全部位')) {
              type = item.dishes_metering_type ? item.dishes_metering_type : item.spec_type
              msg = item.dishes_price
            } else {
              msg = '分部位'
            }
          } else {
            msg = item.dishes_price
            type = item.dishes_metering_type ? item.dishes_metering_type : item.spec_type
          }
        }
      })
      return type != '' ? (msg + "\n\n元/" + type) : msg
    } else {
      return ''
    }
  }
  function quxiao(cartList, id) {
    if (cartList.length && id) {
      var msg = ''
      cartList.forEach(function (item) {
        if (item.dishes_id === id) {
          if (item.item_type == 1) {
            msg = '已取消'
          }
        }
      })
    }
    return msg
  }
  function plus(cartList, id) {
    if (cartList.length && id) {
      var beforeCount = 0
      var afterCount = 0
      cartList.forEach(function (item) {
        if (item.dishes_id === id) {
          if (!item.id && item.dishes_status != 20) {
            afterCount += parseInt(item.number)
          }
        }
      })
    }
    return afterCount > 0
  }
  module.exports = {
    getCountNum: getCountNum,
    getCountNum2: getCountNum2,
    toFixed: toFixed,
    getCartListCount: getCartListCount,
    getCartListTotal: getCartListTotal,
    getTotalBySum: getTotalBySum,
    getDishesPrice: getDishesPrice,
    quxiao: quxiao,
    plus: plus
    , getDishesStatus: getDishesStatus
    , getTotalBySumS: getTotalBySumS
  }
</wxs>
<wxs module="filters" src="menu.wxs"></wxs>
