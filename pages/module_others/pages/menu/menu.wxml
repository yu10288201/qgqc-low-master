          <image style='width:30rpx;height:30rpx' src='https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_like_on.png '></image>
          <view style='font-size:35rpx '>：{{dishes.praise_points}}</view>
