            </view>
            <!-- 菜品介绍 -->
            <view id="f" wx:if="{{!shrinkIntrIntroduction}}" style="height:88%;width:95%;margin-top:3%;margin-left:15rpx;margin-bottom:30rpx;border:solid 2rpx #888">
              
              <view style='font-size:26rpx;font-weight:bold'>菜品介绍：</view>
