<supercall id="supercall" bind:callBZ="callBZ" bind:callFWY="callFWY" wx:if="{{toMenu != 100}}"></supercall>
<view class="popupView-window">
  <view id="c">
    <!-- 多拼粥弹窗 -->
    <van-popup show="{{show}}" custom-style="height: 90%;width: 90%;top: 47%;" bind:close="onClose" round="{{true}}">
