                <text disabled='true' class='textarea' style="font-size: 24rpx;height:150rpx" value='{{goodsIntroduce}}'></text>
              </scroll-view>
            </view>
            <view id="b" wx:if="{{dishes.sideDishes!=0}}" style="height:100%;width:95%;margin-top:3%;margin-left:15rpx;margin-bottom:12rpx">
              
