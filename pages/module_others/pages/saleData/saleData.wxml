<view class="body">
    <view class="return_out" style="height: {{return_out_height}}px;top: {{return_out_top}}px;" bindtap="returnBack">
        <image class="return" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/mine/jiantou1.png" />
        <view>朋友互绑</view>
    </view>
    <view class="title-bg">
        <view class="titleimg">
            <view class="titleimgone">
                <image class="top-image1" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/binding/Bindingimg8.png"></image>
            </view>
            <view class="titleimgtwo">
                <image class="top-image2" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/binding/Bindingimg10.png"></image>
            </view>
        </view>
    </view>
    <view class="content">
        <view style="width: 100%;height: 300rpx;">
        </view>
        <view class='form'>
            <view style="width: 100%;display: flex;flex-direction: row;justify-content: space-between;align-items: center;z-index: 99;">
                <view style="display: flex;flex-direction: row;z-index: 2;margin-left: 20rpx;padding: 10rpx 0;">
                    <view class='th1' data-id="0" bindtap="changeToadyData" style="width: 100rpx;padding: 0 10rpx;margin-right: 0;background-color: {{todayData ? '#e7c7a8' : '#cecece'}};border-radius: 20rpx; background-image: none;">
                        <view class="text">当日</view>
                    </view>
                    <view class='th1' data-id="1" bindtap="changeToadyData" style="width: 100rpx;padding: 0 10rpx;margin-right: 0;margin-left: 20rpx;background-color: {{!todayData ? '#e7c7a8' : '#cecece'}};border-radius: 20rpx;background-image: none;">
                        <view class="text">当月</view>
                    </view>
                </view>
                <view class='th1' data-id="1" bindtap="toBindingCustomerDetail" style="width: 150rpx;padding: 0 10rpx;margin-right: 20rpx;background-color: #0099A2;border-radius: 20rpx;background-image: none;">
                    <view class="text" style="color: #FFF;">绑客详情</view>
                </view>
            </view>
            <image style="width: 100%;position: absolute;z-index: 1;" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/binding/Bindingimg11.png"></image>
            <view style="z-index: 3;border: 1rpx solid;border-radius: 10rpx;display: flex;flex-direction: row;align-items: center;font-size: 28rpx;">
                <view style="display: flex;flex-direction: column;justify-content: space-between;flex: 1;">
                    <view style="margin: 10rpx;font-weight: bolder;">提成奖励总数: </view>
                    <view style="margin: 10rpx;font-weight: bolder;">平台星盾: <text style="font-weight: 400;">0个</text></view>

                </view>
                <view style="display: flex;flex-direction: column;justify-content: space-between;flex: 1;">
                    <view style="margin: 10rpx;font-weight: bolder;">现金: <text style="font-weight: 400;">0元</text></view>
                    <view style="margin: 10rpx;font-weight: bolder;">商家星盾: <text style="font-weight: 400;">0个</text></view>

                </view>
                <!-- <view style="display: flex;flex-direction: row;align-items: center;">
                </view>
                <view style="display: flex;flex-direction: row;align-items: center;justify-content: flex-start;width: 100%;margin-bottom: 10rpx;">
                </view> -->
            </view>
            <view style="z-index: 3;font-size: 28rpx;">
                <view style="border: 1rpx solid;border-radius: 10rpx;margin-top: 10rpx;">
                    <view style="margin: 10rpx;"><text style="font-weight: bolder;">平台绑定朋友: </text>{{saleDataInf.platform_bind_count}}个</view>
                    <view style="margin: 10rpx;margin-top: 0;"><text style="font-weight: bolder;">商家绑定朋友: </text>{{saleDataInf.shop_bind_count}}个</view>
                    <view style="margin: 10rpx;margin-top: 0;"><text style="font-weight: bolder;">商家+餐品绑定: </text>{{saleDataInf.meals_bind_count}}个</view>
                </view>
                <view style="border: 1rpx solid;border-radius: 10rpx;margin-top: 10rpx;">
                    <view style="margin: 10rpx;"><text style="font-weight: bolder;">平台提成奖励: </text>现金: {{saleDataInf.platform_customer_bind_give_amount_total}}元 星盾: {{saleDataInf.platform_customer_bind_give_star_total}}个</view>
                    <view style="margin: 10rpx;margin-top: 0;"><text style="font-weight: bolder;">商家提成奖励: </text>现金: {{saleDataInf.shop_customer_bind_give_amount_total}}元 星盾: {{saleDataInf.shop_customer_bind_give_star_total}}个</view>
                    <view style="margin: 10rpx;margin-top: 0;"><text style="font-weight: bolder;">商家+餐品提成奖励: </text></view>
                    <view style="margin: 10rpx;margin-top: 0;">平台现金: {{saleDataInf.meals_platform_give_amount_total}}元 平台星盾: {{saleDataInf.meals_platform_give_star_total}}个</view>
                    <view style="margin: 10rpx;margin-top: 0;">商家现金: {{saleDataInf.meals_shop_give_amount_total}}元 商家星盾: {{saleDataInf.meals_shop_give_star_total}}个</view>
                </view>
            </view>
            <view class="thtd" style="align-items: flex-start;margin: 0;padding: 0;border: 1rpx solid;border-radius: 10rpx;margin-top: 10rpx;">
                <!-- <view class='th1' style="width: 200rpx;padding: 0 10rpx;margin-right: 0;background-color: #eed6ba;background-image: none;"> -->
                    <text class='text' style="margin-left: 10rpx;margin-top: 10rpx;font-size: 28rpx;">选中绑定餐品名称:</text>
                <!-- </view> -->
                    <view style="margin-left: 65rpx;margin-bottom: 10rpx;font-size: 28rpx;">{{canPinList[canPinListIndex].setMealName ? canPinList[canPinListIndex].setMealName : canPinList[canPinListIndex].coupon_name ? canPinList[canPinListIndex].coupon_name : '请选择'}}</view>
                <!-- <view class='td1' style="width: 100%;border-radius: 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;justify-content: unset;">{{canPinList[canPinListIndex].setMealName ? canPinList[canPinListIndex].setMealName : canPinList[canPinListIndex].coupon_name ? canPinList[canPinListIndex].coupon_name : '请选择'}}</view> -->
            </view>
            <view style="display: flex;flex-direction: row;justify-content: space-between;width: 100%;margin-top: 20rpx;">
                <view class="thtd" style="width: 100%;margin: 0 0 10rpx 0;padding: 0;">
                    <view class='th1' style="width: 100%;justify-content: space-between;margin-right: 0;background-color: #eed6ba;background-image: none;">
                        <text class='text' style="margin-left: 20rpx;font-size: 28rpx;">绑定餐品
                        </text>
                        <view style="display: flex;flex-direction: column;align-items: center;margin-right: 20rpx">
                            <view style="display: flex;flex-direction: row;align-items: center;margin-bottom: 10rpx;">
                                <view style="height: 30rpx;width: 30rpx;background-color: #d01510;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">平台现金提成</text>
                                <view style="height: 30rpx;width: 30rpx;background-color: #009aa2;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">平台星盾提成</text>
                            </view>
                            <view style="display: flex;flex-direction: row;align-items: center;">
                                <view style="height: 30rpx;width: 30rpx;background-color: #fe9b02;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">商家现金提成</text>
                                <view style="height: 30rpx;width: 30rpx;background-color: #3e5d71;margin-left: 10rpx;"></view>
                                <text style="margin-left: 10rpx;font-size: 20rpx;">商家星盾提成</text>
                            </view>
                        </view>
                    </view>
                </view>
            </view>
            <view style="width: 100%;display: flex;flex-direction: row;justify-content: center;align-items: center;">
                    <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;flex: 3;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;">餐品名称</text>
                    <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;flex: 1;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;">单位</text>
                    <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;flex: 1;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;">价格</text>
                    <text class='text' style="display: flex;flex-direction: row;justify-content: center;align-items: center;height: 50rpx;font-size: 28rpx;flex: 2;text-align: center;border-bottom: 2rpx solid #9b4c3c;border-right: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-top: 2rpx solid #9b4c3c;">提成/奖励</text>
            </view>
            <scroll-view class='td1' style="width: 100%;flex: 1;max-height: 300rpx;border: none;" scroll-y="true" bindscrolltolower="bindscrolltolower_setmeal">
                <block wx:for="{{canPinList}}" wx:key="index">
                    <view style="width: 100%;display: flex;flex-direction: row;justify-content: center;align-items: center;background-color: {{canPinListIndex == index ? 'yellow' : ''}}" data-index="{{index}}" data-item="{{item}}" bindtap="selectCanPin">
                        <text class='text' style="font-weight: unset;height: 60rpx;display:flex;flex-direction: row;align-items: center;justify-content: center;font-size: 28rpx;flex: 3;text-align: center;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{item.setMealName?item.setMealName:item.coupon_name}}</text>
                        <text class='text' style="font-weight: unset;height: 60rpx;display:flex;flex-direction: row;align-items: center;justify-content: center;font-size: 28rpx;flex: 1;text-align: center;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;">{{item.dishes_unit?item.dishes_unit:'张'}}</text>
                        <text class='text' style="font-weight: unset;height: 60rpx;display:flex;flex-direction: row;align-items: center;justify-content: center;font-size: 28rpx;flex: 1;text-align: center;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;">{{item.price?item.price:item.coupon_original?item.coupon_original:0}}</text>
                        <view class='text' style="font-weight: unset;height: 60rpx;display:flex;flex-direction: row;align-items: center;justify-content: center;font-size: 28rpx;flex: 2;text-align: center;border-right: 2rpx solid #9b4c3c;border-left: 2rpx solid #9b4c3c;border-bottom: 2rpx solid #9b4c3c;">
                            <text style="color: #d01510;">{{item.customer_platform_commission_amount}}</text>
                            <text>/</text>
                            <text style="color: #009aa2;">{{item.customer_platform_commission_star}}</text>
                            <text>/</text>
                            <text style="color: #fe9b02;">{{item.customer_shop_commission_amount}}</text>
                            <text>/</text>
                            <text style="color: #3e5d71;">{{item.customer_shop_commission_star}}</text>
                        </view>
                    </view>
                </block>
            </scroll-view>
        </view>
        <view class='alertQRcode'>
            <view style="display: flex;flex-direction: row;justify-content: center;align-items: center;border-radius: 50rpx;font-weight: bolder;height: 50rpx;font-size: 24rpx;width: 20%;text-align: center;color: #FFF;background-color: #009aa2;border: #e5e5e5 1px solid;background-image: none;" bindtap="toFriBindRule">
                朋友互绑规则
            </view>
            <!-- <button class="QRcodebtn" style="font-weight: bolder;" bindtap="showQRCode">
                我的二维码
            </button> -->
            <view bindtap="showQRCode" style="font-weight: bolder;font-size: 26rpx;border-radius: 50rpx;height: 80rpx;text-align: center;display: flex;align-items: center;width: 30%;justify-content: center;background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/binding/Bindingimg5.png') no-repeat;background-size: 100% 100%; ">
                我的二维码
            </view>
            <view style="display: flex;flex-direction: row;justify-content: center;align-items: center;border-radius: 50rpx;font-weight: bolder;height: 50rpx;font-size: 24rpx;width: 20%;text-align: center;color: #FFF;background-color: #009aa2;border: #e5e5e5 1px solid;background-image: none;" bindtap="toHelp">
                关于星盾
            </view>
            <!-- <button class="QRcodebtn" style="font-weight: bolder;height: 60rpx;font-size: 24rpx;width: 28%;text-align: center;color: #FFF;background-color: #009aa2;border: #e5e5e5 1px solid;background-image: none;" bindtap="showQRCode">朋友互绑规则</button> -->
            
            <!-- <button class="QRcodebtn" style="font-weight: bolder;height: 60rpx;font-size: 24rpx;width: 28%;text-align: center;color: #FFF;background-color: #009aa2;border: #e5e5e5 1px solid;background-image: none;" bindtap="showQRCode"></button> -->
        </view>
    </view>



    <view catchtouchmove="true" class="popup-window-bg" wx:if="{{showDishesDetail}}"></view>
    <view class='popup-window' style="display: flex;flex-direction: column;justify-content: space-around;" catchtouchmove="true" wx:if="{{showDishesDetail}}">
        <canvas style="width:200px; height: 200px;" canvas-id='myQrcode'></canvas>
        <view style='font-weight: bolder;font-size: 13px;border-radius: 26px;height: 41px;text-align: center;display: flex;align-items: center;width: 30%;justify-content: center;background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/binding/Bindingimg5.png") no-repeat;background-size: 100% 100%;' bindtap="offalert">关闭</view>
    </view>
</view>