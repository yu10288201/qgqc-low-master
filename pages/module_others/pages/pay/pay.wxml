      <view style='font-size:32rpx;margin-left:40rpx'></view>
      <view class='content go-center'>
          <image  src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/pay/bg2.png" style='font-size:28rpx;background:#ffffff;margin:20rpx;border: 1rpx solid rgb(53,156,112);height:180rpx'></image>
