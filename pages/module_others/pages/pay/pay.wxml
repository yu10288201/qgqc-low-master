<!--pages/pay/pay.wxml-->
<view class='wrap'>
    <view class='pay'>
      <text class='storename' style="color: rgb(3,82,86);font-size: 40rpx;font-weight: 600;margin-top: 20rpx;">{{shop_name}}</text>
      
      <text class='money' style="color: rgb(255,150,0);;margin: 60rpx 0rpx;">￥{{total_amount}}</text>
     
      <view class='payrec'>
          <text class='text1'>收款方：</text>
           <text class='text2'>{{shop_name}}</text>
      </view>
      <view class='paynum'>
          <text class='text1'>订单号：</text>
           <text class='text2'>{{order_code}}</text>
      </view>
       <!-- <button class='payBtn' type="primary" bindtap='pay'>立即支付</button> -->
       <button style='margin-top:60rpx' class='payBtn' type="primary" bindtap='pay2'>付 款</button>
   
    </view>
