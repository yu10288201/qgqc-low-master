/* pages/orders/orders.wxss */
page{
  
background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/help/bg1.png');
background-repeat: no-repeat;
background-size: 100% 100%;
}
.page{
    background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/book/bg3.png');
  position: fixed;
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  /* justify-content: center; */
  background-size: 100% 100%;
}
.active-color {
  background: #ff9c35;
}

.unactive-color {
  background: #999;
}

.start-btn {
  width: 200rpx;
  height: 60rpx;
  background: rgb(255, 0, 0);
  font-size: 28rpx;
  color: white;
  align-items: center;
}

.note-btn {
  font-size: 28rpx;
  color: grey;
  margin-top: 60rpx;
}

.dingdan-i {
  font-size: 200rpx;
  color: grey;
}

.tab-box {
  width: 100%;
  display: flex;
  font-size: 28rpx;
  color: white;
  justify-content: center;
}

.hide {
  display: none;
}

.show {
  display: block;
}

.content-list {
  margin-top: 10rpx;
  margin-right: 7%;
  margin-left: 10%;
  border-bottom: 2rpx solid #e3e3e3;
  font-size: 26rpx;
  padding-bottom: 15rpx;
}

.item {
  font-size: 26rpx;
  display: flex;
  flex-direction: row-reverse;
}

.orderstime {
  color: rgb(130, 130, 130);
  font-size: 24rpx;
}

.btn1 {
  width: 170rpx;
  background: #fcaf17;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 10rpx;
  font-size: 26rpx;
  height: 44rpx;
  color: white;
  font-weight: bold;
}

.btn-bar {
  display: flex;
  margin-top: 10rpx;
  margin-bottom: 20rpx;
}

.price {
  position: relative;
  top: 240rpx;
  left: 60rpx;
}
.top-image{
  position: fixed;
  z-index: -1;
  width: 100%;
  height: 500rpx;
  top: 0;
}
.popup-window-bg {
  position: fixed;
  left: 0rpx;
  top: 0rpx;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  justify-content: center;
}

.popup-window {
  background: white;
  position: fixed;
  top: 15%;
  left: 7%;
  width: 86%;
  z-index: 1000;
  border-radius: 5%;
}

.window-btn {
  width: 25%;
  background: #fcaf17;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 10rpx;
  font-size: 26rpx;
  height: 44rpx;
  color: white;
}

.popup-window-top {
  margin: 20rpx;
  border: black solid 2rpx;
  font-size: 30rpx;
}

.popup-window-bottom {
  margin: 20rpx;
  border: black solid 2rpx;
  font-size: 30rpx;
}

.popup-window-btn {
  /* width: 20%; */
  width: 90%;
  display: flex;
  justify-content: center;
  background: #ff9c35;
  align-items: center;
  height: 50rpx;
  color: white;
  border-radius: 5px;
  font-size: 30rpx;
}

.top-head-right {
  font-size: 28rpx;
  width: 50rpx;
  height: 50rpx;
  /* position: absolute; */
  right: 15rpx;
  top: 20rpx;
}

.qr_view {
  flex-direction: column;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
}

.bg2{ 
background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/orders1/bg2.png');
background-repeat: no-repeat;
background-size: 100% 100%;
height: 150rpx;
display: flex;
justify-content: center;
align-items: center;
flex-direction: column;
margin-top: 30rpx;
padding: 20rpx 20rpx;
}

.btn{
  background-image: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/orders1/btn1.png');
  background-repeat: no-repeat;
  background-size: 100% 100%;
  padding: 10rpx 40rpx;
  color: #fff;
}

.return_img{
	width: 70rpx;
	height: 70rpx;
	display: flex;
	justify-content: center;
  align-items: center;	
  position: absolute
}
.return {
  width: 17rpx;
  height: 31rpx;
}

