}

/* 选择商区 */

.section__title{
  size: 36rpx;
  margin: 20rpx 0 20rpx 0;
  width: 30%;
}
.picker{
  width: 30%;
}


.hiddenStore{
  text-align:center;
  border:1rpx solid #eee;
  width:80%;
