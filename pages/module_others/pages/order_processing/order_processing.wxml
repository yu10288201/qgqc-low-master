<!-- 打印机弹窗页面 -->
<view class='popup-window-bg' wx:if="{{showPrint}}" style="flex-direction:column;">
<view class='popup-window-print' style="height:{{windowHeight*0.92}}px;align-items: center;margin-top: 5%" wx:if="{{showPrint}}" >
			<text style="font-size:32rpx;width:100%;color:red;margin-left: 20rpx;margin-top:25px;font-weight:bold;">选择打印机：</text>
			<view class="modal-title print-mod-1" style="width:90%;">
				<scroll-view  scroll-y='true' style='width:100%;height: {{windowHeight*0.75}}px;' class="print_scroll">
				<label class="radio print-lab" data-type="0" style="border-bottom: 0.5px solid green;padding-bottom: 2px;width:100%;height:auto;">
				<view class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
						<text style="font-size:32rpx;">编号</text>
					</view>
					<view class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
						<text style="font-size:32rpx;">状态</text>
					</view>
					<view class="box" style="width:40%;height:80rpx;margin-bottom: -2rpx;">
						<text style="font-size:32rpx;">名称</text>
					</view>
				</label>
				<label class="radio print-lab" data-type="0" bindtap="chooseOnePrint" wx:for="{{printShowArray}}" data-index="{{index}}" data-item="{{item}}" wx:key="index" style="border-bottom: 0.5px solid green;padding-bottom: 2px;width:100%;height:auto;">
					<view class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
						<radio value="r1" checked="{{item.check}}"/>
						<text style="font-size:32rpx;">{{item.num}}</text>
					</view>
					
						<view wx:if="{{item.paper_state!=0}}" class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
							<text style="font-size:32rpx;" wx:if="{{item.connect_status==0}}">未连接</text>
							<text style="font-size:32rpx;color:green" wx:if="{{item.connect_status==1}}">正常</text>
							<text style="font-size:32rpx;" wx:if="{{item.connect_status==2}}">脱机</text>
						</view>
					
						<view wx:if="{{item.paper_state==0}}" class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
							<text style="font-size:32rpx;color:red">{{item.paper_state==0?'缺纸':''}}</text>
						</view>
				
					<view class="box" style="width:40%;height:80rpx;margin-bottom: -2rpx;">
						<text style="font-size:32rpx;">{{item.name}}</text>
					</view>
				</label>
			</scroll-view>
			</view>
			
				<image style='width:60rpx;height:60rpx;float:right;position: absolute;right: 10px;top:10px' src='{{i_close_img_url}}'
					bindtap='showPrint'></image>
				<view class="print_btn" style="margin-top:50rpx;padding-left: 34%;" >
					<button class="btn_mid_y" bindtap="{{showPrint?'submitTheOrder':''}}" style="height: 25px;">确认</button>
				</view>
		</view>
</view>

<!--订单选项-->
<view class="modal-mask" catchtouchmove="preventTouchMove" wx:if="{{showModalQR}}"></view>
<view class="modal-dialog" wx:if="{{showModalQR}}" style='background-color: #eeeeee;height: {{windowHeight*0.85}}px;top: 10%;'>
	<view style="height:100rpx;width:100%;align-items: center;display: flex;">
		<view style='width: 80%;text-align: center;'>{{cart_item.name}}</view>
		<image style='width:60rpx;height:60rpx;float:right' src='{{i_close_img_url}}' bindtap='noycts'></image>
	</view>

	<form bindsubmit='buxiBindsubmit_order' style='width:100%;height:90%;'>
		<scroll-view scroll-y='true'
					 style='width:100%;height:80%;border-top: 1rpx solid black;border-bottom: 1rpx solid black;'>
			<checkbox-group name="checkbox_value">
				<!-- 2020-11-13 把赠送显示出来 item.value != '赠送' &&-->
				<view class="nameList" wx:for="{{listData}}" wx:key="index"
					  wx:if="{{item.value != '转单' &&  item.value != '寄存'}}">
					<label class='nameItems'>
						<checkbox wx:if="{{item.value == '先出单'}}" name="checkbox_value" style="display:{{permission.judge(permission.convert(item.value),levellist)? 'none':'flex'}}" bindtap="buxiCheckBoxChange" value="{{item.value}}" data-item="{{item}}"
								  data-idx="{{index}}" checked="{{item.checked}}" disabled="{{true}}"/>
						<checkbox wx:elif="{{item.value != '催单' && item.value != '分席' && item.value != '不分席'}}" name="checkbox_value" style="display:{{permission.judge(permission.convert(item.value),levellist)? 'none':'flex'}}" bindtap="buxiCheckBoxChange" value="{{item.value}}" data-item="{{item}}"
								  data-idx="{{index}}" checked="{{item.checked}}" />
					</label>
					<view class='nameItemsValue' style="color:black;display:flex;flex-direction: row;">
						<text>{{item.value}}</text>
					
					</view>
				</view>
			</checkbox-group>
		</scroll-view>
		<view style="width:100%;justify-content: center;display: flex;margin-top: 15rpx;">
			<button class='btn_mid_y' style="height: 50rpx;" form-type='submit'>确认</button>
		</view>
	</form>
</view>

<!-- 赠送菜品弹框 -->
<view class="modal-mask" catchtouchmove="preventTouchMove" wx:if="{{showPresentation}}"></view>
<view class="modal-dialog" wx:if="{{showPresentation}}" style="background-color:#205321;color:white">
	<view class="modal-title" style="color:white">
		<text style="margin-left: 20%;">赠送理由</text>
		<image style='width:60rpx;height:60rpx;float:right;margin-right: 5%;' src='{{i_close_img_url}}'
			   bindtap='freeDishCancel'></image>
	</view>
	<!--下拉框  -->
	<view class='list-msg2' bindtap='bindShowMsg_free' style="border: 1rpx solid white;">
		<text>{{presentation}}</text>
		<image style='height:20rpx;width:20rpx;margin: 15rpx;' src='https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/image/down.png'>
		</image>
	</view>
	<!-- 下拉需要显示的列表 -->
	
	<scroll-view scroll-y class=" " wx:if="{{select_free}}" style="width: 80%;margin-left: 10%;height: 250rpx;">
		<block wx:for="{{ListOfPresentation}}" wx:key="index">
			<view class="select_one" bindtap="mySelect_free" data-name="{{item.value}}">{{item.value}}</view>
		</block>
	</scroll-view>
	<view class="modal-content" style="height: 225rpx;">
		<view class="modal-textarea" wx:if="{{presentation == '其他原因'&&!select_free}}">
			<textarea class="modal-text" style="border: 1rpx solid white;" wrap="hard" placeholder="请输入赠送菜品的原因。"
					  bindinput="freeDishRemark"> </textarea>
		</view>
	</view>

	<view class="modal-footer" style="width:100%;justify-content: center;display: flex;margin-top: 15rpx;">
		<button class='btn_mid_y' style="height: 50rpx;" bindtap="freeDishConfirm">确认</button>
	</view>
</view>