.return_out {
    position: fixed;
    top: 100rpx;
    width: 100%;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 2;
}

.return {
    width: 17rpx;
    height: 31rpx;
    margin-right: 15rpx;
    margin-left: 15rpx;
}
page{
	background-color: #ededed;
}

.keyboardUp{
    animation: upEvent 0.3s;
	animation-fill-mode: forwards;
}
@keyframes upEvent {
    from {
		bottom: var(--tabBarHeight--);
	}

	to {
		bottom: var(--keyboardHeight--);
	}
}

.keyboardDown{
    animation: downEvent 0.3s;
	animation-fill-mode: forwards;
}
@keyframes downEvent {
    from {
		bottom: var(--keyboardHeight--);
	}

	to {
		bottom: var(--tabBarHeight--);
	}
}

.keyboardNormal{

}

.utilUp{
    animation: utilUpEvent 0.3s;
	animation-fill-mode: forwards;
}

@keyframes utilUpEvent {
    from {
		bottom: -200px;
	}

	to {
		bottom: var(--tabBarHeight--);
	}
}

.utilDown{
    animation: utilDownEvent 0.3s;
	animation-fill-mode: forwards;
}

@keyframes utilDownEvent {
    from {
		bottom: var(--tabBarHeight--);
	}

	to {
		bottom: -200px;
	}
}

.utilNormal{

}

.longtapRecord{
    background-color: #6e6e6e;
}

