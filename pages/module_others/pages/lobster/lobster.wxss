} */

::-webkit-scrollbar{
    width: 0;
    height: 0;
    color: transparent;
}
/* 弹出框样式1 */
.hiddenview {
  position: fixed;
  left: 0px;
  top: 0px;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  justify-content: center;
}
/* 弹出框样式2 */
.hiddenview2 {
  background-color: white;
  position: fixed;
  top: 15%;
  left: 7%;
  width: 86%;
  height: 65%;
  border-radius: 15rpx;
  border-top-left-radius: 15rpx;
  border-top-right-radius: 15rpx;
}
.modalView1{
  border: 1rpx rgb(167, 167, 167) solid;
  border-radius: 15rpx;
  margin: 10rpx;
  padding: 10rpx;
  margin-top:5%;
  height:25%;
}
.modalBtn {
  /* 按钮样式 */
  background-color: #519763;
  height: 50rpx;
  display: flex;
  color: white;
  font-size: 28rpx;
  justify-content: center;
  margin-top: 5%;
  font-weight: 900;
  align-items: center;
  width: 30%;
}
.modalBtnView{
  width: 100%;
  height: 20%;
  display: flex;
  justify-content: flex-end;
  align-content: center;
}
.exitTable {
  position: absolute;
  top: 11rpx;
  right: 11rpx;
  color: #fff;
  border-radius: 50%;
  width: 45rpx;
  height: 45rpx;
  z-index: 2;
  line-height: 45rpx;
  text-align: center;
  background-color: #f00;
  font-size: 40rpx;
  padding-bottom: 5rpx;
}
.ModalHeadText {
  /* 顶端文字 */
  font-family: "宋体";
  color: rgb(0, 0, 0);
  font-size: 35rpx;
  font-weight: 900;
  width: 100%;
  border-radius: 15rpx;
  background-color: white;
  height: 10%;
  display: flex;
  justify-content: center;
  align-items: center;
}
/* 弹出框文字行样式 */
.modalTextView{
height:25%;
width: 100%;
display: flex;
align-items: center;
justify-content: flex-start;
}
/* 弹出框文左侧字行样式 */
.modalTextView1{
height:100%;
width: 28%;
text-align: right;
}
/* 弹出框文右侧字行样式 */
.modalTextView2{
height:100%;
width: 72%;
text-align: left;
}