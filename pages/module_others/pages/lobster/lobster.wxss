/**discount.wxss**/
/**index.wxss**/

page {
  background-color: #fff;
}

.userinfo {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.userinfo-avatar {
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  border-radius: 50%;
}

.userinfo-nickname {
  color: #aaa;
}

.usermotto {
  margin-top: 200px;
}

.headView {
  /* 头部设置 */
  position: relative;
  width: 100%;
  height: 5%;
  background-color: #214785;
}
/* E4393C */
.headText {
  /* 顶端文字 */
  font-family: "宋体";
  color: rgb(0, 0, 0);
  font-size: 35rpx;
  font-weight: 900;
  width: 95%;
  border-radius: 15rpx;
  background-color: white;
  top: 5rpx;
  position: absolute;
  margin-left: 20rpx;
  margin-right: 20rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.cut {
  width: 100%;
  height: 25rpx;
  background-color: #f4f4f4;
  margin-bottom: 40rpx;
}

.bodyView {
  /* 主体样式 */
  width: 100%;
}

.picker {
  /* 日期格式 */
  width: 250rpx;
  font-size: 28rpx;
  height: 35rpx;
  font-weight: 600;
  color: rgb(0, 0, 0);
  border: 1rpx rgb(87, 87, 87) solid;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 15rpx;
}

.smallView {
  /* 一行两个的view */
  display: flex;
  align-items: center;
  margin-top: 3%;
  height: 9%;
}

.input {
  /* 输入框样式 */
  border: 1rpx rgb(87, 87, 87) solid;
  border-radius: 15rpx;
  width: 400rpx;
  color: rgb(0, 0, 0);
  font-size: 26rpx;
  text-align: center;
  margin-left: 15rpx;
  min-height: 35rpx;
  height: 8%;
}

.input2 {
  /* 小输入框样式 */
  width: 100rpx;
  text-align: center;
  font-size: 26rpx;
  color: rgb(0, 0, 0);
  border: 1rpx rgb(87, 87, 87) solid;
  border-radius: 15rpx;
  margin-left: 15rpx;
  min-height: 35rpx;
  align-items: center;
  justify-content: center;
  height: 8%;
}

.text {
  /* 左边字体样式 */
  font-family: "宋体";
  color: rgb(0, 0, 0);
  font-size: 28rpx;
  font-weight: 900;
  text-align: right;
  margin-left: 25rpx;
  align-items: center;
  width: 175rpx;
}

.text1 {
  /* 获取数据的字体样式 */
  font-family: "宋体";
  color: rgb(0, 0, 0);
  font-size: 28rpx;
  font-weight: 900;
  margin-left: 25rpx;
  text-align: left;
  align-items: center;
  width: 100rpx;
}

.text2 {
  /* 右边字体样式 */
  font-family: "宋体";
  color: rgb(0, 0, 0);
  font-size: 28rpx;
  font-weight: 900;
  text-align: left;
  align-items: center;
}

.div-list {
  /* 一整行的文字与输入框 */
  display: flex;
  justify-content: flex-start;
  height: 6%;
  width: 100%;
  margin-top: 2%;
  align-items: center;
}

.div-list1 {
  /* 靠左文字与输入框 */
  display: flex;
  justify-content: flex-start;
  height: 100%;
  width: 63%;
  align-items: center;
}

.div-list2 {
  /* 右侧文字与输入框 */
  display: flex;
  justify-content: flex-start;
  height: 100%;
  width: 15%;
  text-align: right;
  align-items: center;
}

.div-list3 {
  /* 靠右文字与输入框 */
  display: flex;
  justify-content: flex-start;
  height: 100%;
  width: 10%;
  text-align: right;
  align-items: center;
}

.from {
  width: 100%;
  height: 100%;
}

.bottomView {
  /* 底部样式 */
  top: 20rpx;
  width: 60%;
  height: 8%;
  display: flex;
  position: relative;
  bottom: 25rpx;
  justify-content: center;
  align-items: center;
  border: 1rpx rgb(167, 167, 167) solid;
  margin-left: 20%;
  border-radius: 15rpx;
  margin-bottom: 10rpx;
}

.btn {
  /* 按钮样式 */
  background-color: #519763;
  height: 50rpx;
  display: flex;
  color: white;
  font-size: 28rpx;
  justify-content: center;
  font-weight: 900;
  align-items: center;
}

.textarea {
  /* 大输入框 */
  width: 80%;
  margin-left: 10%;
  height: 330rpx;
  /* display: flex;
  justify-content: center; */
  border: 1rpx rgb(167, 167, 167) solid;
  border-radius: 15rpx;
  padding: 5rpx;
}

.text3 {
  /* 输入框格式 */
  width: 75%;
  height: 90%;
  /* overflow-y:hidden; */
  font-size: 28rpx;
}

.btnView {
  /* ‘首发人报名’按钮和‘进入店铺’按钮外框样式 */
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 5%;
  margin-left: 5%;
  width: 90%;
  border-radius: 15rpx;
  height: 10%;
}

