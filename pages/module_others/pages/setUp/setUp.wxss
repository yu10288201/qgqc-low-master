/* pages/mine/mine.wxss */

.top-mode {
  background: #009AA2;
  height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/*第一第二句让方形的头像变圆*/

.userAvatarUrl {
  border-radius: 50%;
  overflow: hidden;
  height: 150rpx;
  width: 150rpx;
  margin-top: 60rpx;
  display: flex;
}

.btn-bar {
  display: flex;
  font-size: 24rpx;
  font-weight: bold;
  height: 120rpx;
}

.btn-image {
  height: 36rpx;
  width: 36rpx;
}

.btn-image-bg {
  height: 60rpx;
  width: 60rpx;
  border-radius: 50%;
  background: #e4393c;
  display: flex;
  justify-content: center;
  align-items: center;
}

.btn {
  padding: 5rpx;
  text-align: center;
  height: 80rpx;
  width: 25%;
}

.content {
  display: flex;
  align-items: center;
  width: 100%;
  height: 80rpx;
  border-bottom: #e5e5e5 solid 2rpx;
}

.content-image {
  width: 30rpx;
  height: 30rpx;
  margin-left: 5%;
}

.content-text {
  font-size: 26rpx;
  font-weight: bold;
  margin-left: 25rpx;
}

.right {
  position: absolute;
  right: 10rpx;
  width: 24rpx;
  height: 24rpx;
}

.version-scroll {
  width: 80%;
  height: 90%;
}

.exit {
  position: fixed;
  bottom: 4%;
  width: 100%;
  height: 90rpx;
}

.exitButton {
  width: 40%;
  background-color: #e4393c;
  color: white;
  font-weight: bold;
  font-size: 36rpx;
  height: 81rpx;
  border-radius: 10rpx;
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  padding-left: 14px;
  padding-right: 14px;
  box-sizing: border-box;
  text-align: center;
  text-decoration: none;
  line-height: 81rpx;
  -webkit-tap-highlight-color: transparent;
  overflow: hidden;
}

.tr {
  width: 95%;
  height: 70rpx;
  align-items: center;
  font-size: 32rpx;
}

.td {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
}

.td1 {
  font-size: 30rpx;
  margin-left: 8rpx;
}

.popup-window-bg {
  position: fixed;
  left: 0rpx;
  top: 0rpx;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 997;
  display: flex;
  justify-content: center;
}

.popup-window-update{
  background: white;
  position: fixed;
  height: 45%;
  top: 22%;
  left: 5%;
  width: 90%;
  z-index: 998;
  border-radius: 5%;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.div {
  display: flex;
  margin-bottom: 30rpx;
  width:100%;
}

.div2 {
  margin-top: 70rpx;
  display: flex;
}

.input {
  display: flex;
  border: 6rpx solid #ebf5ff;
  border-radius: 15rpx;
  font-size: 30rpx;
  width: 300rpx;
  text-align: center ;
}

.changePwd{
  display: flex;
  overflow: hidden;
  width: 260rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #009AA2;
  border-radius: 42rpx;
  justify-content: center;
  color: #fff;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  font-size: 40rpx;
}