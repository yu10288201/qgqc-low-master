              <i class="iconfont icon-jiahao2fill activity-color2 font20" wx:if="{{item.dishes_status==3}}" data-index='{{index}}'></i>
              <i class="iconfont icon-jiahao2fill activity-color font20" wx:else data-index='{{index}}' bindtap='adddishesnum'></i>
