          <view class='content-item down-center'>
            <view style='width:60%'>
              <view wx:if="{{(item.item_type==1&&item.operator!='')||(item.dishes_status==12&&item.operator!='')||(item.dishes_status==13&&item.operator!='')}}" style='color:red;margin-left:4rpx'>确认部长:{{item.operator}}</view>
              <view wx:elif="{{item.dishes_status==11&&item.operator!=''}}" style='color:green;margin-left:4rpx'>确认部长:{{item.operator}}</view>
            </view>
            <view wx:if="{{item.item_type==1||item.dishes_status==12||item.dishes_status==13}}" class='oneline' style='width:100%;color:red;flex-direction: row;'>{{item.operation_time}}</view>
            <view wx:elif="{{item.dishes_status==11&&item.operator!=''}}" class='oneline' style='width:100%;color:green;flex-direction: row;'>{{item.operation_time}}</view>
          </view>
        </view>
      </view>
      <view wx:else>
        <view class='content' style='display:block'>
          <view class='oneline'>
            <image src='{{item.dishes_img}}' style='width:150rpx;height:100rpx;margin-top:10rpx'></image>
            <view style='width:80%'>
              <view class='content-item oneline' style='margin-left:20rpx;'>
                <view class='oneline' style='width:85%'>
                  <view style='font-weight:bold;width:60%'>{{item.dishes_name}}</view>
                  <view class='oneline' style='width:40%;flex-direction: row-reverse;'>

                    <!-- 订单详情列表中的详情 -->
                    <view class='part2-btn' style='margin-right:40rpx' data-index='{{index}}' bindtap='opendetail' data-item='{{item}}'>详情</view>
                  </view>
                </view>
                <image class='icon' src="{{item.praise_flag==1?'https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_like_on.png':'https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_like_off.png'}}" data-id='{{item.id}}' bindtap='changelike'></image>
              </view>
              <view class=' content-item oneline' style='margin-top:10rpx'>
                <view style='width:25%'>单位:{{item.dishes_metering_type}}</view>
                <view class='oneline' style='width:60%'>
                  <view wx:if="{{item.item_type==2}}" style='color:green'>加　菜</view>
                  <view wx:if="{{item.item_type!=1}}" class='part2-btn' style="width:120rpx;margin-right:20rpx;background:{{item.measurement_value==0?'gray':''}}" data-item='{{item}}' bindtap='sureweight'>确认称重</view>
                  <view class='part2-btn' style='margin-right:50rpx' data-index='{{index}}' bindtap='canceldishes'>取消</view>
                </view>
                <image class='icon' src='https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_zhuanfa.png' data-dishesid='{{item.dishes_id}}' bindtap='share'></image>
              </view>
            </view>
          </view>
          <view class='oneline' style='font-size:26rpx;margin-left:10rpx;margin-top:20rpx;width:100.2%'>
            <view style='margin-left:10rpx;width:50%;color:orange'>{{item.item_price}}元/{{item.dishes_metering_type}}</view>
            <view style='color:red;margin-left:10rpx;width:50%'>订:{{item.item_number}}{{item.dishes_metering_type}}</view>
            <view style='color:green;margin-left:10rpx;width:50%'> 称:{{item.measurement_value}}{{item.dishes_metering_type}}</view>
            <view class='oneline' style='margin-left:10rpx;width:50%;color:orange;flex-direction: row-reverse;'>￥{{item.item_subtotal}}元</view>
          </view>
        </view>
      </view>
    </view>
  </view>

</template>
