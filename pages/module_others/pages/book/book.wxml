    <view style="border-radius:10rpx;top:35%;" class='popup-window' catchtouchmove="true" wx:if='{{noteshows}}'>
        <view class='note' style='margin-bottom:100rpx;'>
            <view style='font-size:26rpx;font-weight:bold'>订单备注:</view>
            <textarea cursor-spacing="100" fixed placeholder='如有口味要求，请输入备注' value='{{remark}}' bindinput='addremarks' class='note-text'></textarea>
        </view>
        <view class='select-dishes' style="margin-left:280rpx;">
            <view class='btn1' bindtap='closeWindow' style="margin-bottom:12rpx;">确定</view>
        </view>
    </view>

    <!-- 订房提交- -->
    <view bindtap='dishesInfo' catchtouchmove="true" class='popup-window-bg' wx:if='{{bookingroom}}'></view>
    <view style="border-radius:10rpx;top:35%;" class='popup-window' catchtouchmove="true" wx:if='{{bookingroom}}'>
        <view class='note' style='margin-bottom:100rpx;'>
            <view style='font-size:26rpx;font-weight:bold'>订单备注:</view>
            <textarea cursor-spacing="100" fixed placeholder='如有口味要求，请输入备注' model:value='{{orderRemark}}' bindinput='addremarks' class='note-text'></textarea>
        </view>
        <view class='select-dishes' style="display: flex;flex-direction: row;justify-content: space-between;width: 70%;align-items: center;margin: 0 auto;">
            <view class='btn1' bindtap='closeBooking' style="margin-bottom:12rpx;">取消</view>
            <view class='btn1' bindtap='booking' style="margin-bottom:12rpx;">确定</view>
        </view>
    </view>



    <view wx:if="{{showAuthorize}}" class='window-bg'>
        <view class='window' style="background:#fff;background-size:100% 100%;-moz-background-size:100% 100%;">
            <view class='window-item' style="border: none;">
                <view class='window-item-title' style="color: black;">欢迎关注</view>
                <view class='window-item-content' style="color:black">申请授权</view>
                <view class='window-item-content' style="margin-left:5%;color: black;">现需获取您的手机号码。是否同意？</view>
            </view>
            <view class='btn-bar'>
                <button class='cancelBtn' bindtap='refused'>否</button>
                <button class='confirmBtn' open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">是</button>
            </view>
        </view>
    </view>
