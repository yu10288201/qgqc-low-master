                <view class='btn' data-model='0' style="background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/book/btn3.png');background-size: 100% 100%;" bindtap='changehelporder'>请部长点餐
                    <text decode="{{true}}" space="{{true}}"></text>
