            </view>
                <view class='oneline toTop1' style="flex-direction: column;">
                    <view style="margin-top: 10rpx;"><text class='text'>包房名称：</text>{{thisroom.field_name}}</view>
                    <view style="margin-top: 10rpx;"><text class='text'>桌子编号：</text>{{locationNum}}</view>
                    <view style="margin-top: 10rpx;"><text class='text'>类型：</text>{{thisroom.size_type}}</view>
                    <view style="margin-top: 10rpx;"><text class='text'>可坐人数：</text>{{thisroom.user_num}}</view>
                    <view style="margin-top: 10rpx;"><text class='text'>低消：</text>{{thisroom.field_price}}</view>
                    <view style="margin-top: 10rpx;"><text class='text'>设施：</text>{{thisroom.field_parameter}}</view>
                </view>
                <view class='oneline toTop1'>
                    <view class='text'>备注:</view>
                    <view class='remark'>
                        <view style='margin:10rpx;'> {{thisroom.bei_zhu}}</view>
