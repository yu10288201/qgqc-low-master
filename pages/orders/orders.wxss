/* pages/orders/orders.wxss */

.active-color {
  background: #ff9c35;
}

.unactive-color {
  background: #999;
}
.btn_small_green {
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/btn/button_small_green.png") no-repeat;
  background-size: 100% 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-top: 5rpx;
  color: white;
  padding-left: 0;
  padding-right: 0;
  margin-right: 15rpx;
  margin-left: 0rpx;
  height: 50rpx;
  width: 100rpx;
  text-align: center;
  line-height: 50rpx;
  border-radius: 10rpx;
}
.btn_big_green {
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/btn/button_big_green.png") no-repeat;
  background-size: 100% 100%;
  font-weight: bold;
  height: 90rpx;
  font-size: 36rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 10rpx;
  margin-top: 5rpx;
  color: white;
  padding-left: 0;
  padding-right: 0;
  margin-left: 0;
  margin-right: 0;
}

.start-btn {
  width: 200rpx;
  height: 60rpx;
  background: rgb(255, 0, 0);
  font-size: 28rpx;
  color: white;
  align-items: center;
}

.note-btn {
  font-size: 28rpx;
  color: grey;
  margin-top: 60rpx;
}

.dingdan-i {
  font-size: 200rpx;
  color: grey;
}

.tab-box {
  width: 50%;
  display: flex;
  font-size: 28rpx;
  color: white;
  /* margin-left: 46rpx; */
}

.hide {
  display: none;
}

.show {
  display: block;
}

.content-list {
  margin-top: 10rpx;
  margin-right: 7%;
  margin-left: 7%;
  border-bottom: 2rpx solid #e3e3e3;
  font-size: 26rpx;
  padding-bottom: 15rpx;
}

.item {
  font-size: 26rpx;
  display: flex;
  flex-direction: row-reverse;
}

.orderstime {
  color: rgb(130, 130, 130);
  font-size: 24rpx;
}

.btn1 {
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/btn/button_mid_yellow3.png");
  width: 160rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 10rpx;
  font-size: 26rpx;
  height: 44rpx;
  color: white;
  font-weight: bold;
}

.btn-bar {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  margin-bottom: 20rpx;
}

.price {
  position: relative;
  top: 240rpx;
  left: 60rpx;
}

.popup-window-bg {
  position: fixed;
  left: 0rpx;
  top: 0rpx;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  justify-content: center;
}

.popup-window {
  background: white;
  position: fixed;
  top: 15%;
  left: 7%;
  width: 86%;
  z-index: 1000;
  border-radius: 5%;
}

.window-btn {
  width: 25%;
  background: #fcaf17;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 10rpx;
  font-size: 26rpx;
  height: 44rpx;
  color: white;
}

.popup-window-top {
  margin: 20rpx;
  border: black solid 2rpx;
  font-size: 30rpx;
}

.popup-window-bottom {
  margin: 20rpx;
  border: black solid 2rpx;
  font-size: 30rpx;
}

.popup-window-btn {
  /* width: 20%; */
  width: 90%;
  display: flex;
  justify-content: center;
  background: #ff9c35;
  align-items: center;
  height: 50rpx;
  color: white;
  border-radius: 5px;
  font-size: 30rpx;
}

.top-head-right {
  font-size: 28rpx;
  width: 50rpx;
  height: 50rpx;
  position: absolute;
  right: 15rpx;
  top: 20rpx;
}
