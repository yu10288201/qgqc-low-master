<view style="width: 100vw;height: 100vh;display: flex;flex-direction: column;align-items: center;background-color: #f7f7f7;">
  <view style="width: 100%;position: relative;font-weight: bold;display: flex;justify-content: center;align-items: center;padding: 20rpx 0 40rpx;background-color: white;">
    <view style="font-size: 36rpx;">{{index == 1 ? '新增' : '修改'}}收货地址</view>
    <view wx:if="{{index == 2}}" style="position: absolute;right: 20rpx;display: flex;align-items: center;" bindtap="delete">
      <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/Trash.png" style="width: 50rpx;height: 50rpx;"></image>
    </view>
  </view>

  <view style="flex: 1;width: 100%;position: relative;display: flex;flex-direction: column;align-items: center;">
    <map id="myMap" style="width: 100%;height: 30%;" wx:if="{{!inf}}" enable-zoom="{{false}}" enable-scroll="{{false}}" show-location="true"></map>
    
    <map id="myMap" wx:else style="width: 100%;height: 30%;" latitude="{{inf.latitude}}" enable-zoom="{{false}}" enable-scroll="{{false}}" longitude="{{inf.longitude}}" show-location="true"></map>

    <view style="width: 92%;position: absolute;top: 200rpx;display: flex;flex-direction: column;">
      <view style="width: 100%;padding: 40rpx 0;display: flex;flex-direction: column;align-items: center;border-radius: 20rpx;background-color: white;">
        <view class="first-box">
          <view class="font1">地址</view>
          <view class="first-box-inner" bindtap="chooseLocation">
            <view style="width: 90%;display: flex;flex-direction: column;min-width: 0;">
              <view wx:if="{{inf}}" style="width: 430rpx;text-overflow: ellipsis;white-space: nowrap;overflow: hidden;">{{inf.address}}</view>
              <view style="width: 430rpx;color: gray;font-size: 26rpx;text-overflow: ellipsis;white-space: nowrap;overflow: hidden;">{{inf ? inf.addressDetail : '请选择配送地址'}}</view>
            </view>

            <view style="display: flex;align-items: center;">
              <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/qgqc/right.png" style="width: 50rpx;height: 50rpx;"></image>
            </view>
          </view>
        </view>
        <view class="first-box">
          <view class="font1">门牌号</view>
          <view class="first-box-inner">
            <input type="text" placeholder="填写详细地址，例：1层101" placeholder-style="font-size: 28rpx" bindinput="inputHouseNum"/>
          </view>
        </view>
        <view class="first-box">
          <view class="font1">标签</view>
          <view class="first-box-inner" style="border: 0;">
            <view class="{{labelIndex == 1 ? 'label color' : 'label'}}" bindtap="selectLable" data-labelindex="1">家</view>
            <view class="{{labelIndex == 2 ? 'label color' : 'label'}}" bindtap="selectLable" data-labelindex="2">公司</view>
            <view class="{{labelIndex == 3 ? 'label color' : 'label'}}" bindtap="selectLable" data-labelindex="3">学校</view>
          </view>
        </view>
      </view>

      <view style="width: 100%;padding: 40rpx 0;display: flex;flex-direction: column;align-items: center;border-radius: 20rpx;background-color: white;margin-top: 30rpx;">
        <view class="first-box">
          <view class="font1">联系人</view>
          <view class="first-box-inner">
            <view>
              <input style="width: 240rpx;" type="text" bindinput="inputContacts" value="{{userInf ? userInf.contacts : ''}}"/>
            </view>
            <radio-group style="font-size: 28rpx;display: flex;justify-content: flex-end;flex: 1;" bindchange="selectSex">
              <radio value="1" checked="{{index == 1 ? true : userInf ? (userInf.sex == 1) : true}}">
                <view style="height: 32rpx;line-height: 32rpx;">先生</view>
              </radio>
              <radio value="0" style="margin-left: 10rpx;" checked="{{index == 1 ? false : userInf ? (userInf.sex == 0) : false }}">
                <view style="height: 32rpx;line-height: 32rpx;">女士</view>
              </radio>
            </radio-group>
          </view>
        </view>

        <view class="first-box">
          <view class="font1">手机号</view>
          <view class="first-box-inner">
            <view>
              <input style="width: 400rpx;" value="{{userInf ? userInf.phone : ''}}" type="text" bindinput="inputPhone"/>
            </view>
          </view>
        </view>

        <view style="width: 92%;height: 75rpx;line-height: 75rpx;background-color: #009aa2;color: white;font-weight: bolder;display: flex;justify-content: center;border-radius: 50rpx;margin-top: 30rpx;" bindtap="{{index == 1 ? 'save' : 'update'}}">保存</view>
      </view>
    </view>
  </view>
</view>