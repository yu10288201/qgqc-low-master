<!--pages/order/order.wxml-->
<wxs module="filters" src="../package_details_buy/addmul.wxs" />

<view class='top' style="background:url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/store/store_black.png');background-size: 100% 100%">
  <view class='search-view'>
    <text wx:if="{{id==0}}" wx:for="{{setMeal}}" style="margin-left:20rpx">{{filters.people(item.typeForSetMeal)}}:{{item.setMealName}}</text>
    <text wx:if="{{id == 1}}" style="margin-left:20rpx">{{CouponList.coupon_name}}</text>
    <text wx:if="{{distribution == '1'}}" style="margin-left:20rpx">{{distributionFoodInfo[0].dishesName}}</text>
  </view>
</view>

<view wx:if="{{setMeal&&setMeal.length>0}}" class="model" style="margin-top:90rpx" wx:if="{{id==0}}">
  <view wx:if="{{setMeal[0].pageUrl&&setMeal[0].pageUrl.length>0}}" class="menu_image">
    <image src="{{setMeal[0].pageUrl[0].pageURL}}?x-oss-process=image/resize,m_fill,h_75,w_82" mode="aspectFill" bindtap='bigimg2' data-src="{{setMeal[0].pageUrl[0].pageURL}}"></image>
    <image wx:if="{{id == 1}}" src="https://timgsa.baidu.com/timg?image&quality=80&size=b9999_10000&sec=1587805769388&di=544565d1bd934f788e3e09b6379c8762&imgtype=0&src=http%3A%2F%2Fpic24.nipic.com%2F20121021%2F5978971_103436687000_2.jpg"></image>
  </view>
  <view class="menu_right">
    <view class="model_title" wx:for="{{setMeal}}">
      <text wx:if="{{item.refund ==1}}">可退款</text>
      <text wx:else>不可退款</text>
      <text wx:if="{{item.appointment == 1}}" style="margin-left: 12rpx;">需预约</text>
      <text wx:else style="margin-left: 12rpx;">免预约</text>
      <text wx:if="{{item.pastRefund == 1}}" style="margin-left: 12rpx;">过期可退款</text>
      <text wx:else style="margin-left: 12rpx;">过期不退款</text>
      <text wx:if="{{item.pickOneself == 1}}" style="margin-left: 12rpx;">可自提</text>
      <text wx:else style="margin-left: 12rpx;">不可自提</text>
    </view>
    <view class="model_title" wx:for="{{setMeal}}">
      <text wx:if="{{item.holidays == 1}}">节假日可用</text>
      <text wx:else>节假不可用</text>
      <text wx:if="{{item.privateRoom == 1}}" style="margin-left: 12rpx;">包间可用</text>
      <text wx:else style="margin-left: 12rpx;">包间不可用</text>
      <!-- <text>不可叠加</text>
			<text style="margin-left: 12rpx;">全店通用</text> -->
    </view>
    <view style="display:flex;flex-direction:row" wx:if="{{setMeal[0].startUsing3 != 1}}">
      <view style="width:100%">
        <view class="menu_time" style="margin-top: 8rpx;">
          <text style="margin-left: 12rpx;">{{startTime}} ~ {{endTime}}</text>
        </view>
        <view class="menu_time" style="margin-top: 8rpx;">
          <text style="margin-left: 12rpx;">{{usefulDateText}}</text>
        </view>
        <view class="menu_time" style="margin-top: 4rpx;">
          <view style="margin-left:12rpx">
            <text style="text-align:right" wx:for="{{timeList}}">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{setMeal[0].startUsing3 == 1}}" style="margin-left: 10rpx;margin-top: 10rpx;">
      <view wx:if="{{setMeal[0].activityDate.time}}">{{filters.formatDate(setMeal[0].activityDate.time)}}</view>
      <radio-group bindchange="radioChange" style="display:flex;flex-direction:row;width:90%;justify-content: space-between;flex-wrap:wrap;" wx:if="{{!setMeal[0].activityDate.time}}">
        <view wx:for="{{useTimeList}}">
          <radio value="{{item}}">{{item}}</radio>
        </view>
      </radio-group>
    </view>
  </view>

</view>

