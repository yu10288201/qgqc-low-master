  </view>
</view>
<view wx:if="{{quick_remark!=''}}" style="display: flex;flex-direction: column;padding: 20rpx 20rpx;background-color: #f2f2f2;">
  <view>常用备注:</view>
  <view style="display: flex;margin-top: 10rpx;">
      <view style="flex: 1;border: 2rpx solid gray;border-radius: 20rpx;padding: 10rpx 10rpx;background-color: white;">
