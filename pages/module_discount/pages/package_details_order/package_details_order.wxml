<view class="num" style="border-bottom:2rpx solid #dadada;padding-bottom:20rpx;display: flex;flex-direction: row;justify-content: space-between;align-items: center;" wx:if="{{setMeal!=''||CouponList!=''||distributionFoodInfo != ''}}">
  <view>数量</view>
  <view style="display: flex;flex-direction: row;align-items: center;justify-content: center;height: 75rpx;">
    <image src="https://test.fsmbdlkj.com/wx_official/web/images/image/delete.png" class='{{minusStatus}}' style="height: 80rpx;width: 80rpx;transform: scale(1.2);" type='number' bindtap='bindMinus'></image>
    <input bindinput='' disabled value='{{num}}' style="width: 70rpx;text-align: center;"></input>
    <!-- bindManual -->
    <image src="https://test.fsmbdlkj.com/wx_official/web/images/image/add.png" style="height: 80rpx;width: 80rpx;transform: scale(1.2);" bindtap='bindPlus'></image>

  </view>
</view>

<view style="width:100%;margin-top:50%;text-align:center" wx:if="{{setMeal==''&&id==0}}">
  该套餐已下架
</view>

<view class="num" style="border-bottom:2rpx solid #dadada;padding-bottom:20rpx" wx:if="{{setMeal!=''||CouponList!=''||distributionFoodInfo != ''}}">
  <text >单价</text>
  <text style="width:140rpx;text-align:right;color:#F89600;font-size:32rpx;padding-right:20rpx" wx:if="{{setMeal&&setMeal.length>0}}">￥{{setMeal[0].price}}</text>
  <text style="width:140rpx;text-align:right;text-decoration:line-through;color: #5a5a5a;font-size:26rpx;" wx:if="{{setMeal&&setMeal.length>0}}">￥{{setMeal[0].originalPrice}}</text>
</view>

<view class="num" style="border-bottom:2rpx solid #dadada;padding-bottom:20rpx" wx:if="{{setMeal!=''||CouponList!=''||distributionFoodInfo != ''}}">
  <text style="width:50%">支付金额</text>
  <text style="width:50%;text-align:right;color:#F89600;font-size:32rpx;padding-right:20rpx">￥{{actualSum}}</text>
</view>

<view style="border-bottom:2rpx solid #dadada;padding-bottom:20rpx;display: flex;flex-direction: column;" wx:if="{{setMeal[0].wayOfUseStarDust != 0}}">
  <view style="display: flex;margin-left: 20rpx;margin-top: 20rpx;align-items: center;" wx:if="{{false}}">
    <checkbox-group bindchange="useStarDustChange">
      <checkbox value="1" checked="{{isUseStarDust}}"></checkbox>
    </checkbox-group>
    <text bindtap="changIsUseStar">使用星盾</text>
    <view style="margin-left: 36rpx;display: flex;align-items: center;" wx:if="{{isUseStarDust && setMeal[0].wayOfUseStarDust == 1}}">{{isUseStarDustCount}}个【平台星盾】</view>
    <view style="margin-left: 36rpx;display: flex;align-items: center;" wx:if="{{isUseStarDust && setMeal[0].wayOfUseStarDust == 2}}">{{isUseStarDustCount}}个【店铺星盾】</view>
    <view style="margin-left: 36rpx;display: flex;align-items: center;" wx:if="{{isUseStarDust && setMeal[0].wayOfUseStarDust == 3}}">{{isUseStarDustCount}}个【平台星盾】【店铺星盾】</view>
    <view style="margin-left: 36rpx;display: flex;align-items: center;" wx:if="{{isUseStarDust && setMeal[0].wayOfUseStarDust == 4}}">{{isUseStarDustCount}}个【领盾购买】</view>
  </view>
  <view class="num" wx:if="{{isUseStarDust}}">
    <text style="width:50%">实付金额</text>
    <text style="width:50%;text-align:right;color:#F89600;font-size:32rpx;padding-right:20rpx">￥{{filters.toFix2(actualOfUsingStar)}}</text>
  </view>
</view>
<view style="width:95%;border-bottom:2rpx solid #dadada;padding-bottom:20rpx;display: flex;flex-direction: column;" wx:if="{{setMeal[0].startUsing3 == 3}}">
  <view style="display: flex;margin-top: 20rpx;align-items: center;justify-content: space-between;">
    <view style="display: flex;margin-left: 20rpx;margin-top: 20rpx;align-items: center;">
      <text>家长：</text>
      <input style="width: 50rpx;font-size: 28rpx;padding-left: 20rpx;padding-right: 20rpx;text-align: center;margin-left: 10rpx;border-radius: 14rpx; height: 42rpx; border: 0.5rpx solid #dadada;" model:value="{{parents}}" />
      <text decode="true">&nbsp;&nbsp;人</text>
    </view>


    <view style="display: flex;margin-top: 20rpx;align-items: center;">
      <text>学生：</text>
      <input style="width: 50rpx;font-size: 28rpx;padding-left: 20rpx;padding-right: 20rpx;text-align: center;margin-left: 10rpx;border-radius: 14rpx; height: 42rpx; border: 0.5rpx solid #dadada;" model:value="{{students}}" />
      <text decode="true">&nbsp;&nbsp;人</text>
    </view>
  </view>
</view>


