  <view>自定义备注:</view>
  <view style="display: flex;margin-top: 10rpx;">
       <textarea bindinput="remarkInput" value="{{goods_remark}}" maxlength="200" style="flex: 1;border: 2rpx solid gray;border-radius: 20rpx;padding: 10rpx 10rpx;height: 180rpx;background-color: white;"></textarea>
  </view>
</view> 


