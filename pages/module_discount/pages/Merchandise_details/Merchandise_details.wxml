      <view style="font-size: large;color:#F89600;margin-bottom: 10rpx;width: 100%;margin-left: 1em;font-weight: bold;">请按以下步骤操作:</view>
      <text decode='true' style="font-size: large;color:#F89600;margin-bottom: 10rpx;word-break: break-all;text-align: left;text-indent:2em;margin: 0rpx 20rpx;">"立即购买" -&gt; 选择"用作礼品" -&gt; "确定" -&gt; 进入"确认订单"页面(如果还没填写收货地址就填写) -&gt; "提交支付" -&gt; "返回首页"</text>
      
     
    </view>
</view>







<!-- 底部弹窗 已完成模板查询 -->
<view wx:if="{{b_article_template_main_show}}" style="height: 100%;"  class="popup-dlg-background-mask">
	<view  class="popup-dlg-bottom mall-font-family-YaHei mall-font-size-default" style="width:100%;height: 92vh;display: flex;flex-direction: column;align-items: center;justify-content: center;">
    <view style="flex:1;"></view>
    <view style="width: 98%;margin-bottom: 10rpx;">
      <view style="font-weight: 800;font-size: 34rpx;">
        已有模板
      </view>
    </view>
    <view style="width:98%;margin-bottom:15rpx;margin-top:10rpx; margin-left:20rpx;margin-right:20rpx;height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: center;border-radius: 50rpx;border: 2rpx solid grey;padding: 0rpx 5rpx;">
        <view style="flex: 1;"> 
          <input model:value="{{s_template_key_word}}" placeholder="   搜索已完成模板" style="width: 100%; font-size: 25rpx;"/>
        </view>
    </view>
    <view style="width:98%;margin-bottom:0rpx;margin-top:0rpx; height:60rpx;display: flex;flex-direction: row; align-items: center;justify-content: flex-end;border-radius: 50rpx;">
        <view catch:tap="clearSTemplateKeyWord" class="bottom_btn" style="background-color: #FF5722;margin-right: 50rpx;">
          清空
        </view>

        <!--data-article_type="2"-->
        <view data-article_type="2" catch:tap="selectMallBaseArticleTemplateMainData" class="bottom_btn" style="margin-right: 30rpx;">
          图片
        </view>
        <view data-article_type="3" catch:tap="selectMallBaseArticleTemplateMainData" class="bottom_btn" style="margin-right: 30rpx;">
          视频
        </view>
        <view data-article_type="0" catch:tap="selectMallBaseArticleTemplateMainData" class="bottom_btn" style="margin-right: 20rpx;">
          搜索
        </view>
    </view>
    <view class='form_tittle'>
			<view class='th-head' style="text-align: center;width:24%;">
				<text class='text' style="font-size: 26rpx;">创建日期</text>
			</view>
			<view class='th-center' style="text-align: center;width:10%;">
				<text class='text' style="font-size: 26rpx;">类型</text>
			</view>
      <view class='th-center' style="text-align: center;width:56%;">
				<text class='text' style="font-size: 26rpx;">标题</text>
			</view>
			<view class='th-end' style="text-align: center;width:10%;">
				<text class='text' style="font-size: 26rpx;">次数</text>
			</view>
		</view>
    <scroll-view scroll-y="true" style="height:65vh;overflow: scroll;overflow: auto;" bindscrolltolower="scrollToLowerArticleTemplateMain" >
        <view class='for' wx:for='{{s_article_template_main_array}}' wx:key='index' data-index='{{index}}' catch:tap='itemClickArticleTemplateMain'>
          <view class='td-head' style='width:24%;{{listIndexArticleTemplateMain==index?"background-color:#52A76E;color:#fff":""}}'>
          {{item.create_date_str}}
          </view>
          <view class='td-center' style='width:10%;{{listIndexArticleTemplateMain==index?"background-color:#52A76E;color:#fff":""}}'>
            <text wx:if="{{item.article_type==1}}">文章</text>
            <text wx:if="{{item.article_type==2}}">图片</text>
            <text wx:if="{{item.article_type==3}}">视频</text>
          </view>	
          <view class='td-center' style='width:56%;{{listIndexArticleTemplateMain==index?"background-color:#52A76E;color:#fff":""}}'>
           {{item.name}}
          </view>		
          <view class='td-end' style='width:10%;{{listIndexArticleTemplateMain==index?"background-color:#52A76E;color:#fff":""}}'>
            {{item.use_count}}
          </view>
        </view>
      </scroll-view>
    <view style="display: flex;flex-direction: row;align-items: center;justify-content: flex-end;width: 100%;padding: 10rpx 0rpx;">
     
   
      <view catch:tap="hideBArticleTemplateMainShow" class="bottom_btn" style="background-color: #FF5722;margin-right: 50rpx;">
          关闭
        </view>
      <view catchtap="confirmArticleTemplateMain" class="bottom_btn" style="margin-right: 50rpx;">确定</view>
    </view>	
	</view>
</view>



