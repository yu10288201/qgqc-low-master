				<block wx:for="{{multi_media}}" wx:key='index' style="width: 100%;">
					<swiper-item style="width: 100%;" class="img_box">						
						<image wx:if="{{item.multimedia_type == 1}}" style="height:{{height}}px; width:100%; border-radius: 30rpx;"  mode="aspectFill" src="{{item.url}}" />

            <view wx:if="{{item.outfit_type==1}}" data-outfit_type="{{item.outfit_type}}" data-goods_img_url="{{item.url}}" bindtap="toOutfit" class="img_box_absolute">
