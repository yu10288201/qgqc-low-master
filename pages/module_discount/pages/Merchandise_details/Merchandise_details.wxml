			</view>     
			<view class="sub_section">              
				<text class="sub_title">保障</text>		
				<view class="property_group" style="width: 85%;">
					<text class="properties" wx:if="{{is_seven_without_reason == 1}}">七天无理由退货</text>
          <text class="properties" wx:if="{{is_seven_without_reason == 0}}">不支持七天无理由退货</text>
					<text class="properties" wx:if="{{is_provide_invoices == 1}}">提供发票</text>

