<view style="display: flex;flex-direction: column;justify-content: center;align-items: center;height: 100%;width: 100%;top: 0;z-index: 999999; position: fixed;background-color: #00000066;" wx:if="{{showCustomise}}" bindtap="closeCustomiseDialog">
</view>
<view style="position: fixed;top: 0;right: 0;left: 0;bottom: 0;margin: auto;height: 700rpx;width: 700rpx;background-color: #FFF;border-radius: 20px;display: flex;flex-direction: column;justify-content: center;align-items: center;z-index: 9999999; padding: 20rpx" wx:if="{{showCustomise}}">
  <scroll-view>
    <view wx:for="{{infotips}}" >
      <view style="display: flex; flex-direction: row;">
        <checkbox style="margin-top: 10rpx;margin-bottom: 10rpx; width: 7%; margin-left: 1%;" data-id="{{index}}" checked="" bindtap="changeCustomise"/>
        <view style="display: flex; flex-direction: column;">
          <view style="font-weight: bolder;">{{item.title}}</view>
          <image src="{{item.img}}" style="width: 300rpx; height: 300rpx;"/>
          <view style="font-size: 28rpx">{{item.content}}</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

<view catchtouchmove="true" class="popup-window-bg" wx:if="{{showQR}}"></view>
<view class='popup-window' style="display: flex;flex-direction: column;justify-content: space-around;" catchtouchmove="true" wx:if="{{showQR}}">
	<canvas style="width:200px; height: 200px;" canvas-id='productQrcode'></canvas>
	<view style='font-weight: bolder;font-size: 13px;border-radius: 26px;height: 41px;text-align: center;display: flex;align-items: center;width: 30%;justify-content: center;background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/binding/Bindingimg5.png") no-repeat;background-size: 100% 100%;' bindtap="closeQRCode">关闭</view>
</view>

<!--固定置顶条-->
<view class="top">
	<!--搜索条-->
	<!--导航栏-->
	<view class="bottom-row" >
		<view class="{{currentTab == 'basics' ? 'active' : 'inactive'}}" data-tab="basics" bindtap="scrollToSection">商品</view>
		<view class="{{currentTab == 'comments' ? 'active' : 'inactive'}}" data-tab="comments" bindtap="scrollToSection">评价</view>
		<view class="{{currentTab == 'details' ? 'active' : 'inactive'}}" data-tab="details" bindtap="scrollToSection">详情</view>

    <view class="{{currentTab == 'search' ? 'active' : 'inactive'}}" data-tab="search" bindtap="scrollToSection">
      <image   style="width: 30rpx;height: 30rpx;margin-top: 4rpx;" src="{{search_svg}}" />
    </view>
    <view class="{{currentTab == 'shop' ? 'active' : 'inactive'}}" data-tab="shop" bindtap="scrollToSection">店铺</view>

	</view>
</view>

<scroll-view scroll-y="{{!showAddtoCart}}" scroll-into-view="{{currentTab}}" bindscroll="scroll">
	<view id="basics">
