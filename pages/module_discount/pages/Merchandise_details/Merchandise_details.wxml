		</view>	
	</view>

	<!--商品评价-->
	<view id="comments">
		<view class="model" style="height: {{comments_num>0?450:100}}rpx" >
			<view style="display: flex;flex-direction: row;" >
        <text style="width:70%;" class="section_title">商品评价({{comments_num}})</text>         
				<text wx:if="{{comments_num>0}}" style="width:30%; font-size: 23rpx; color:grey; margin-top: 35rpx;">下滑看更多评价</text>
			</view>	
			<view wx:if="{{comments_num>0}}" style="display: flex;flex-direction: column; margin-top: 20rpx;">  
