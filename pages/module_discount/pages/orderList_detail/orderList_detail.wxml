<!--pages/orderList_detail/orderList_detail.wxml-->
<view class='top' style="background:url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/store/store_black.png');background-size: 100% 100%">
	<view class='search-view'>
		<!-- <image src="http://img3.imgtn.bdimg.com/it/u=2064794736,2436845779&fm=26&gp=0.jpg"></image> -->
		<text style="margin-left:20rpx">订单待使用</text>
	</view>
</view>
<view class="deline"></view>

<view class="ListDetail" style="margin-top:20rpx">
	<text style="font-size:30rpx;margin-top:20rpx;margin-left:20rpx;font-weight:600">感谢您使用切瓜切菜平台，期待下次光临</text>
	<view class="ListDetail_buttom">
		<view class="Detail_button" bindtap="callsever">
			<image src="https://test.fsmbdlkj.com/wx_official/web/images/image/kefu.png"></image>
			<text>联系客服</text>
		</view>
		<view class="Detail_button">
			<image src="https://test.fsmbdlkj.com/wx_official/web/images/image/dianhua.png"></image>
			<text bindtap="callshop">致电商家</text>
		</view>
		<view wx:if="{{SelectTicketOrderInfo[0].order_remark ==0}}" bindtap="assess" class="Detail_button">
			<image src="https://test.fsmbdlkj.com/wx_official/web/images/image/pingjia.png"></image>
			<text>订单评价</text>
		</view>
		<view wx:else class="Detail_button">
			<image src="https://test.fsmbdlkj.com/wx_official/web/images/image/pingjia.png" style="margin-left:24rpx"></image>
			<text>已评价</text>
		</view>
	</view>
</view>

<view class="advertisement" style="margin-top:26rpx">
	<image wx:if="{{id == 0}}" src="https://ss0.bdstatic.com/70cFvHSh_Q1YnxGkpoWK1HF6hhy/it/u=1746490956,1268878758&fm=26&gp=0.jpg"></image>
	<image wx:if="{{id == 1}}" src="https://ss0.bdstatic.com/70cFvHSh_Q1YnxGkpoWK1HF6hhy/it/u=1927043287,4212262611&fm=15&gp=0.jpg"></image>
</view>

<view class="orderList_Detail" style="margin-top:20rpx" wx:for="{{orderList_detail}}">

	<view class="order_menu">
		<view class="order_menu_left" wx:if="{{id==0}}">
			<image src="{{mealList.pageUrl[0].pageURL}}"></image>
		</view>
		<view class="order_menu_right">
			<text wx:if="{{id==0}}">{{mealList.setMealName}} x1</text>
			<text wx:else>{{SelectTicketOrderInfo[0].order_name}} x1</text>
			<text style="font-size:26rpx;color:#777777">在线支付 | {{create_date}}</text>
		</view>
		<view style="width:27%;text-align:right" wx:if="{{id==0}}">
			<text wx:if="{{item.appointment==0&&item.appointmentOnShop==0&&item.ticket_status==0}}" style="font-size:30rpx;border:1rpx solid #dadada;padding:6rpx 24rpx 6rpx 24rpx;border-radius:8rpx" wx:for-index="index" data-index="{{index}}" bindtap="subscribe">预约</text>
			<text wx:elif="{{item.appointment==2&&item.ticket_status==0}}" style="font-size:30rpx;background:red;color:#ffffff;padding:6rpx 24rpx 6rpx 24rpx;border-radius:8rpx" wx:for-index="index" data-index="{{index}}" bindtap="modalChange3">预约失败</text>
			<text wx:elif="{{item.appointmentOnShop==1&&item.ticket_status==0}}" style="font-size:30rpx;padding:6rpx 24rpx 6rpx 24rpx;background:green;color:#ffffff;border-radius:8rpx" wx:for-index="index" data-index="{{index}}" bindtap="modalChange2">预约成功</text>
				<text wx:elif="{{item.ticket_status==0&&item.appointmentOnShop==0&&item.appointment==1}}" style="font-size:30rpx;padding:6rpx 24rpx 6rpx 24rpx;background:green;color:#ffffff;border-radius:8rpx">等待确认</text>
				<text wx:elif="{{item.ticket_status==1}}" style="font-size:30rpx;padding:6rpx 24rpx 6rpx 24rpx;background:green;color:#ffffff;border-radius:8rpx">已使用</text>
		</view>
	</view>
	<view wx:if="{{id==0}}" class="order_menu" style="margin-left:15%;border-top:1rpx dashed #dadada;width:83%;padding-top:20rpx">
		<text style="width:75%;font-weight:900">{{item.ticket_code}}</text>
		<text catchtap="getcode" style="font-size:28rpx;border:1rpx solid #dadada;padding:6rpx 16rpx 6rpx 16rpx;border-radius:8rpx" wx:for-index="index" data-index="{{index}}">查看券码</text>
	</view>
	<view wx:if="{{id==1}}" class="order_menu" style="margin-left:5%;border-top:1rpx dashed #dadada;width:91%;padding-top:20rpx">
		<text style="width:77%;font-weight:900">{{item.ticket_code}}</text>
		<text catchtap="1" style="font-size:28rpx;border:1rpx solid #dadada;padding:6rpx 16rpx 6rpx 16rpx;border-radius:8rpx">查看券码</text>
	</view>
</view>

<view class="orderList_Detail" style="margin-top:20rpx" wx:if="{{shop!=''}}">
	<view class="orderList_Detail_shop" style="border-bottom:1rpx dashed #dadada">
		<text style="font-size:30rpx;width:67%">商家信息</text>
		<text bindtap="shoptap" style="font-size:28rpx;border:1rpx solid #dadada;padding:6rpx 16rpx 6rpx 16rpx;border-radius:8rpx">{{shop.length}}家门店通用</text>
	</view>
	<view bindtap="goshop" class="orderList_Detail_shop" style="border-bottom:1rpx dashed #dadada;flex-direction:row;padding-top:20rpx">
		<view>
			<image style="width:70rpx;height:70rpx;border-radius:8rpx" src="{{shopList.shop_img}}"></image>
		</view>
		<view style="display:flex;flex-direction:column;margin-left:10rpx;margin-bottom:10rpx">
			<text style="text-align:left;width:100%;font-size:30rpx">{{shopList.shop_name}}</text>
			<text style="text-align:left;width:100%;font-size:26rpx;color:#777777">{{shopList.shop_address}}</text>
		</view>
	</view>
	<view class="orderList_Detail_shop" style="padding-top:20rpx">
		<text style="text-align:left;width:73%;font-size:26rpx;color:#777777">咨询订座、发票、菜品、使用规则...</text>
		<text bindtap="callshop" style="font-size:28rpx;border:1rpx solid #dadada;padding:6rpx 16rpx 6rpx 16rpx;border-radius:8rpx">联系商家</text>
	</view>
</view>
<view class="orderList_Detail" style="margin-top:20rpx" wx:if="{{shop==''}}">
	<view class="orderList_Detail_shop" style="border-bottom:1rpx dashed #dadada">
		<text style="font-size:30rpx;width:67%">商家信息</text>
	</view>
	<view class="orderList_Detail_shop" style="border-bottom:1rpx dashed #dadada;">
		<text style="text-align:center;width:100%">暂无商家信息</text>
	</view>
</view>

<view class="orderList_Detail" style="margin-top:20rpx;margin-bottom:20rpx">
	<view style="font-size:32rpx;color:#000000" class="Information">
		<text>订单信息</text>
	</view>
	<view class="Information">
		<text style="width:20%">订单号</text>
		<text style="width:68%;text-align:right;letter-spacing: 2rpx;">{{ordernum}} | </text>
		<text style="width:12%;text-align:right;color:#F89600" bindtap="longTap">复制</text>
	</view>
	<view class="Information">
		<text style="width:50%">支付方式</text>
		<text wx:if="{{orderList_detail[0].ticket_type ==1}}" style="width:50%;text-align:right">在线支付</text>
		<text wx:else style="width:50%;text-align:right">在线支付</text>
	</view>
	<view class="Information">
		<text style="width:50%">下单时间</text>
		<text style="width:50%;text-align:right">{{create_date[0]}}</text>
	</view>
</view>
<view catchtouchmove="true" hidden="{{actionSheetHidden1}}" class="modelview" bindtap="modalChange"></view>
<view catchtouchmove="true" hidden="{{actionSheetHidden1}}" class="model">
	<image style="width:500rpx;height:540rpx" src='data:image/png;base64,{{codeImage}}'></image>
</view>

<view hidden="{{actionSheetHidden}}" class="modelview" bindtap="modalChange1"></view>
<view hidden="{{actionSheetHidden}}" class="model">
	<view class="modelTitle">
		<text style="width:100%;text-align:center;padding-left:20rpx">预约</text>
		<icon style="position: absolute;right: 25rpx;top: 15rpx" type="clear" size="20" bindtap="modalChange1" />
	</view>
	<view class="menu_name">
		<text>预约时间：</text>
		<view style="display:flex;flex-direction:column;width:60%">
			<picker style="width:80%;border:1rpx solid #dadada;height:42rpx;border-radius: 8rpx;font-size:28rpx;text-align:center" mode="date" value="{{startdate}}" bindchange="startDateChange">
				<view class="picker">
					<view class="picker_view">{{startdate}}
						<image style="width:30rpx;height:30rpx;margin-top:6rpx;float:right;margin-right:10rpx" src='https://test.fsmbdlkj.com/wx_official/web/images/image/donwn.png'></image>
					</view>
				</view>
			</picker>
			<picker style="width:50%;margin-top:10rpx;border:1rpx solid #dadada;height:42rpx;border-radius: 8rpx;font-size:28rpx;text-align:center" mode="time" value="{{starttime}}" bindchange="startTimeChange">
				<view class="picker">
					<view class="picker_view">{{starttime}}
						<image style="width:30rpx;height:30rpx;margin-top:6rpx;float:right;margin-right:10rpx" src='https://test.fsmbdlkj.com/wx_official/web/images/image/donwn.png'></image>
					</view>
				</view>
			</picker>
		</view>
	</view>
	<view class="menu_name" style="margin-top:40rpx">
		<text style="font-size:30rpx;font-weight:100;color:#777777;margin-top:-10rpx">*使用时间段：</text>
		<text style="font-size:30rpx;font-weight:100;color:#777777;margin-top:-10rpx" wx:for="{{timeList}}">{{item}}</text>
	</view>
	<view class="menu_name">
		<text style="width:90%;font-size:30rpx;font-weight:100;color:#777777;margin-top:-10rpx">*请在使用时间段内预约</text>
	</view>
	<view class="modelTitle1" bindtap="gosubscribe">确定预约</view>
</view>

<view catchtouchmove="true" class="modelview" hidden="{{Successful_appointment}}"></view>
<view class="model" hidden="{{Successful_appointment}}">
	<view class="modelTitle">
		<text style="width:100%;text-align:center;padding-left:20rpx;color:#009AA2">预约成功</text>
		<icon class='clear' type="clear" size="20" bindtap="modalChange2" />
	</view>
	<view class="menu_name" style="display:flex;flex-direction:column;" wx:for="{{orderList_detail}}">
		<text style="font-size:28rpx;color:#009AA2;font-weight:300">{{item.ticket_code}}套餐预约时间：</text>
		<text style="font-size:28rpx;color:#009AA2;float:right;width:100%;text-align:right">{{item.appointment_time}}</text>
	</view>
	<view class="modelTitle1" bindtap="modalChange2" >确认</view>
</view>

<view catchtouchmove="true" class="modelview" hidden="{{fail_appointment}}"></view>
<view class="model" hidden="{{fail_appointment}}">
	<view class="modelTitle">
		<text style="width:100%;text-align:center;padding-left:20rpx;color:#009AA2">预约失败</text>
		<icon class='clear' type="clear" size="20" bindtap="modalChange2" />
	</view>
	<view class="menu_name" style="display:flex;flex-direction:column;" wx:for="{{orderList_detail}}">
			<text style="font-size:28rpx;color:#009AA2;font-weight:300">{{item.ticket_code}}套餐预约失败原因：</text>
		<text style="font-size:28rpx;color:#009AA2;font-weight:300">{{item.ticket_remark}}</text>
	</view>
	<view class="modelTitle1" bindtap="subscribe" >重新预约</view>
</view>