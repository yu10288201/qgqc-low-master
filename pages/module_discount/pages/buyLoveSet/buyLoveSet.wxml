<wxs module="filters" src="format.wxs" />

<scroll-view scroll-y="true" style="height: 100vh;background-color: rgb(226, 226, 226)">
  <view style="width: 95%;display: flex;flex-direction: column;justify-content: start;margin: 0 auto;margin-top: 20rpx;background-color: rgb(226, 226, 226);padding-bottom: 10rpx;">
    <view style="width: 100%;display: flex;flex-direction: column;justify-content: start;margin: 0 auto;background-color: #fff;" wx:for="{{foodList}}">
      <view style="width: 100%;height: 10rpx;background: #fff"></view>
      <view style="width: 712rpx;height: 380rpx;margin: 0 auto;" wx:if="{{isFoodOrCombo}}">
        <swiper style="width: 100%;height: 380rpx; background-color: #fff" data-index="{{index}}" bindtap="toDetail" data-item="{{item}}" data-isFoodOrCombo="{{isFoodOrCombo}}" autoplay="true" interval="1600" duration="0">
          <swiper-item wx:for="{{item.pageUrl}}">
            <image style="width: 712rpx;height: 380rpx;border-top-right-radius: 30rpx;border-top-left-radius: 30rpx;border-bottom-right-radius: 15rpx;border-bottom-left-radius: 15rpx;" mode="scaleToFill" src="{{item}}?x-oss-process=image/resize,m_fill,h_190,w_356"></image>
          </swiper-item>
        </swiper>
        <!-- 优惠券卡片 -->
      </view>
      <view style="width: 98%;height: 40rpx;margin: 0 auto;display: flex;flex-direction: column;">
        <view style="font-size: 32rpx;font-weight: bold;" bindtap="toDetail" data-item="{{item}}">{{item.setMealName}}</view>
      </view>
      <view style="width: 98%;margin: 0 auto;display: flex;flex-direction: column;margin-top: 10rpx;" wx:if="{{item.setMealAbout != ''}}">
        <view style="text-indent:48rpx;font-size: 24rpx;display:-webkit-box;-webkit-box-orient: vertical;overflow:hidden;-webkit-line-clamp:2;font-weight: bold;">{{item.setMealAbout}}</view>
      </view>
      <view style="margin: 0 auto;width: 99%;display: flex;flex-direction: row;justify-content: space-between;margin-top: 10rpx;">
        <view style="display: flex;flex-direction: row;justify-content: flex-start;">
          <view><text style="color: rgb(255,153,0);font-weight: bold;">￥{{item.price}}元</text></view>
          <view style="margin-left: 20rpx;font-size: 20rpx;line-height: 44rpx;color: #777;text-decoration: line-through;margin-left: 10rpx;">￥{{item.originalPrice}}元</view>
        </view>
      </view>
      <view style="margin-left: 10rpx;margin-top: 6rpx;display: flex;justify-content: flex-start;font-weight: bold;font-size: 27rpx;">
        <view style="color: rgb(135,71,1);">男士价:{{item.manPrice}}元/人</view>
        <view style="color: rgb(255,153,0);margin-left: 8rpx;">返佣:{{item.commission_manPrice}}元</view>
        <view style="color: rgb(135,71,1);margin-left: 20rpx;">女士价:{{item.ladyPrice}}元/人</view>
        <view style="color: rgb(255,153,0);margin-left: 8rpx;">返佣:{{item.commission_ladyPrice}}元</view>
      </view>
      <view style="margin-left: 10rpx;margin-top: 6rpx;display: flex;justify-content: flex-start;font-weight: bold;font-size: 27rpx;">
        <view>用餐活动日期:{{filters.formatDate(item.activityDate)}}</view>
        <!-- <button class="dnlm" style="position: absolute;right: 64rpx;font-size: 32rpx;line-height: 0;display: flex;flex-direction: row;align-items: center;border-radius: 20rpx;background-color: rgb(255,153,0);height: 39rpx;" data-item="{{item}}" data-indexShare="{{index}}" bindtap="onShare" wx:if="{{item.coupon_id == null}}">
          <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/qgqc/00586bfc2184c33493da987da652235.png" style="width: 34rpx;height: 18rpx;"></image>
        </button> -->
      </view>
      <view style="display: flex;flex-direction: row;justify-content: space-between;align-items: flex-start;padding-bottom: 15rpx;width: 95%;">
        <view style="margin-left: 20rpx;font-size: 24rpx;line-height: 44rpx;color: #777;font-weight: bold;">销量：{{item.setMealSales}}</view>
        <view style="margin-left: 20rpx;font-size: 24rpx;line-height: 44rpx;color: #777;font-weight: bold;">库存：{{item.spreads}}</view>
        <view style="margin-left: 20rpx;font-size: 24rpx;line-height: 44rpx;color: #fff;font-weight: bold;">分享人次：{{item.share_num}}</view>
      </view>
      <view style="width: 100%;height: 20rpx;background: rgb(226, 226, 226);"></view>
    </view>
  </view>
</scroll-view>