<!--pages/module_discount/pages/refund/refund.wxml-->
<view class="top">
      <view class="topView">
            <text>订单号：</text>
            <text class="minText">{{orderCode}}</text>
      </view>
         <view class="topView">
            <text>退还金额：</text>
            <text class="minText">{{orderTotal/100}}元</text>
      </view>
      <view class="topView">
            <text>退款商品：</text>
            <text class="minText">{{orderName}}</text>
      </view>
        <view class="topView">
            <text>退款方：</text>
            <text class="minText">{{shopName}}</text>
      </view>
      <view class="topView">
            <text>退还方式：</text>
            <text class="minText">原路退还（1-3个工作日内退款到原支付方）</text>
      </view>
      <view class="topView" style="border:none">
            <text>退款说明：</text>
            <text class="minText">退款成功后获取的优惠将会收回</text>
      </view>
</view>
<view class="centre">
      <view class="centreView">
            退款原因（至少选择一项）
      </view>
      <checkbox-group bindchange="checkboxChange" style="height:100%">
            <checkbox value="{{item}}" wx:for="{{CauseList}}" class="checkbox-group">
            {{item}}
            </checkbox>
      </checkbox-group>
</view>
<view class="bottom" bindtap="AddPayMentRefund" >
      申请退款
</view>

