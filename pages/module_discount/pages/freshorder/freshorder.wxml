
<view class="page">
    <view style="background: #52A76E;">
      <view class="content-box flex-row">
      <image class="head-image" src="{{pageURL}}?x-oss-process=image/resize,m_fill,h_72,w_82" mode="aspectFill" bindtap='bigimg2' data-src="{{pageURL}}"></image>
      <view class="flex-column" style="justify-content: space-between; margin-left: 12rpx;">
          <view class="content-title" style="margin-top: 10rpx;">
            <text >{{setMealName}}</text>
          </view>

            <view style="margin-bottom: 10rpx;" class="flex-row" wx:if="{{is_set_meal_weight==0}}">
              <text class="content-title">单价：</text>
              <text style="color:#F89600; font-size: 30rpx;">￥{{price}}</text>
            </view>
            <view style="margin-bottom: 10rpx;" wx:if="{{is_set_meal_weight==1}}">
              <text class="content-notice">单价: {{price}}{{dishes_unit}}</text>
            </view>
            <view style="margin-bottom: 10rpx;" wx:if="{{is_set_meal_weight==1}}">
              <text class="content-notice">规格: {{min_weight}} ~ {{max_weight}} 斤</text>
            </view>
        </view>
      </view>
    </view>
    
    <view class="flex-row" style="align-items: center;margin-left: 20rpx;margin-top: 10rpx;" wx:if="{{is_set_meal_weight==1}}">
      <text class="content-notice" style="margin-right: 10rpx;">规格(重量):</text>
      <view class=".content-input-border" style="margin-right: 5rpx;"> 
        <input class="tui-number-cell" type="number" bindinput="buy_min_weight_change"  value='{{buy_min_weight}}'></input>
      </view>
      <text class="content-notice" style="margin-right: 5rpx;">-</text>
      <view class=".content-input-border" style="margin-right: 10rpx;">
        <input class="tui-number-cell" type="number"  bindinput="buy_max_weight_change" value='{{buy_max_weight}}'></input>
      </view>
      <text class="content-notice">斤/只</text>
    </view>

    <view class="flex-row" style="margin-top: 30rpx; align-items: center;" wx:if="{{is_set_meal_weight==0}}">
        <view class="property">
            <text class="content-notice">数量：</text>
            <view style="display: flex;flex-direction: row;align-items: center;justify-content: center;height: 75rpx;">
                <image src="https://test.fsmbdlkj.com/wx_official/web/images/image/delete.png" class='{{minusStatus}}' style="height: 80rpx;width: 80rpx;transform: scale(1.2);" type='number' bindtap='bindMinus'></image>
                <input bindinput="item_number_change" value='{{item_number}}' style="width: 70rpx;text-align: center;"></input>
                <image src="https://test.fsmbdlkj.com/wx_official/web/images/image/add.png" style="height: 80rpx;width: 80rpx;transform: scale(1.2);" bindtap='bindPlus'></image>
            </view>
        </view>      
    </view>

    <view class="flex-row" style="margin-left: 20rpx; margin-top: 30rpx;align-items: center;" wx:if="{{is_set_meal_weight==1}}">
      <text class="content-notice" style="margin-right: 10rpx;">数量:</text>
      <view class=".content-input-border" style="margin-right: 15rpx;"> 
        <input class="tui-number-cell" type="number" bindinput="item_number_change"  value='{{item_number}}'></input>
      </view>      
      <text class="content-notice" wx:if="{{is_set_meal_weight==0}}"> 只 </text>
      <text class="content-notice" wx:if="{{is_set_meal_weight==1}}">总重量 {{buy_max_weight*item_number}} 斤</text>
    </view>

    <view class="flex-row" style="align-items: center; margin-top: 10rpx; align-items: center;"wx:if="{{is_set_meal_weight==0}}" >
        <view class="property">
            <text class="content-notice" >总金额：</text>
            <text  style="margin-right:5rpx; color:rgb(255,153,0)">￥{{total_amount}} </text>
        </view>
    </view>

    <view class="flex-row" style="align-items: center;margin-left: 20rpx;margin-top: 30rpx; " wx:if="{{is_set_meal_weight==1}}">
      <text class="content-notice" style="margin-right: 10rpx;">预付金额:</text>
      <text  style="margin-right: 5rpx;color:rgb(255,153,0)">￥</text>
      <text  style="margin-right: 5rpx;color:rgb(255,153,0)">{{estimate_amount}}</text>
    </view>   
    
  
    <view style="padding-bottom:20rpx; margin-top: 40rpx; width: 92%; margin-left: 4%;" >
        <view class="content-notice" style="margin-bottom: 5rpx;">购买备注：</view>
        <textarea  cols="30" rows="10" style="border: 2rpx solid #dadada;width: auto;height: 200rpx; border-radius:6rpx; margin-top: 30rpx; padding: 10rpx;" bindinput="remark_change" value="{{remark}}"></textarea>
    </view>
    
</view>

    <view style="display:flex; flex-direction:row; justify-content:space-between; position:fixed; bottom:0rpx; margin:length; width:100%; align-items:center; height: 120rpx; background-color: #FFF;">
        <view style="width:70%; margin-bottom:30rpx;">            
            <text style="color: #F89600; font-weight:900; font-size:36rpx; margin-left:30rpx;" >￥{{total_amount}}</text>            
        </view>         
        <view style="width:30%; margin-bottom:40rpx; margin-right:20rpx;">
            <view class="tap" bindtap="insertCustomerShoppingCart">确   定</view>            
        </view>        
    </view>






