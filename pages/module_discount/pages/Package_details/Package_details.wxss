.banner_warp {
  margin-top: 30rpx;
}

.banner_warp .banner_warp .li {
  border-radius: 20rpx;
  overflow: hidden;
}

.banner_warp .wx-swiper-dot {
  width: 40rpx;
  height: 6rpx;
  background: rgba(255, 255, 255, .2);
  border-radius: inherit;
}

.banner_warp .wx-swiper-dot-active {
  width: 40rpx;
  height: 6rpx;
  background: #fff;
}

.banner_warp image {
  border-radius: 20rpx;
}

.ticket {
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 94%;
