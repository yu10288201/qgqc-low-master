}

.search-view{
  letter-spacing:10rpx;
  margin-left: 10rpx;
  display: flex;
  flex-direction: row;
  height: 134rpx;
  width: 96%;
  font-size: 30rpx;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  background-color:#ffffff;
  border-top-left-radius:16rpx;
  border-top-right-radius:16rpx;
}
.search-view1{
    /* letter-spacing:10rpx; */
    display: flex;
    margin-left: 10rpx;
    flex-direction: row;
    height: 104rpx;
