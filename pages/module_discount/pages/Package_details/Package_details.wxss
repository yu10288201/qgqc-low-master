::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

.model{
  display: flex;
  flex-direction: column;
  border-radius: 10rpx;
  width: 94%;
  margin-left: 2%;
  border: 0.5rpx solid #dadada;
}
.model_btn{
   display: flex;
  flex-direction: row;
  border-radius: 10rpx;
  align-items: center;
  justify-content: flex-end;
  width: 94%;
  height: 60rpx;
  margin-left: 2%;
  border: 0.5rpx solid #dadada;
  }
.model_title{
  margin-top: 10rpx;
  width: 96%;
  margin-left: 2%;
  display: flex;
  flex-direction: row;
  font-size: 24rpx;
}
.model_title text{
  padding-left: 6rpx;
  padding-right: 6rpx;
  color: #F89600;
  border: 0.5rpx solid #F89600;
}
.model video{
  margin-bottom: 20rpx;
  margin-top: 20rpx;
  margin-left: 10%;
  border-radius: 10rpx;
  height: 300rpx;
width: 80%;
}
.menu_star{
  font-size: 24rpx;
