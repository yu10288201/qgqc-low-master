    background-image: radial-gradient(circle at 344rpx 115rpx, transparent 0%, transparent 18rpx, #f8c6b8 18rpx, #fcfbf9 100%);
    background-position: 363rpx;
    padding: 10rpx 0rpx;
  }
.ticket_title{
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx dashed #dadada;
  display: flex;
  flex-direction: column;
  margin-left: 4%;
  margin-top: 1%;
  width: 92%;
}
.ticket_title image{
  width: 26rpx;
  height: 26rpx;
}
.ticket_title text{
  font-size: 24rpx;
}
