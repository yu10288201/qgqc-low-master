            <view class="tap" bindtap="Mealtap" wx:elif="{{id==0 && !ladderStart && !isFromBuyLoveSet}}">立即抢购</view>
            <view class="tap" bindtap="Coupontap" wx:elif="{{id==1 && !ladderStart && !isFromBuyLoveSet}}">立即抢购</view>
            <view class="tap" bindtap="Coupontap" wx:elif="{{id==1 && ladderStart && !isFromBuyLoveSet}}">立即抢购</view>
            <view class="tap" bindtap="Mealtap1" wx:if="{{id==0 && isFromBuyLoveSet}}">购买</view>
