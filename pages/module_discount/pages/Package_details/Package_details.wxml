                <view style="width: 40rpx;height: 40rpx;border-radius: 10rpx;background: {{currentBlockColor}};" bindtap="showChangeFontColorDialog" data-index="1"></view>
            </view>
        </view>

        <view class="popup-window1-bg" wx:if="{{isShowChangeFontColorDialog}}"></view>
