            <text style="text-decoration:line-through;color: #5a5a5a;font-size:26rpx;" wx:if="{{!isFromBuyLoveSet}}">￥{{filters.toFix2(item.originalPrice)}}</text>
            <text style="text-decoration:line-through;color: #5a5a5a;font-size:26rpx;" wx:if="{{isFromBuyLoveSet}}">￥{{filters.toFix2(item.originalPrice)/10}}</text>
            <text style="border:0.5rpx solid #F89600;font-size:20rpx;color: #F89600;">{{filters.toFix(item.price/item.originalPrice)}}折</text>
            <text wx:if="{{ladderStart}}" style="font-size:30rpx;color: #F89600;">剩：{{item.number}} {{filters.dishes_unit(item.dishes_unit,item.typeForSetMeal)}}</text>
        </view>
        <view class="pay_right" wx:if="{{id==1}}" style="width: 75%;display: flex;flex-direction: row;justify-content: space-between;align-items: center;">
            <text style="color: #F89600;font-weight: 900;font-size:36rpx;">购买价:￥{{filters.toFix2(CouponList.coupon_original)}}元/张</text>
            <text wx:if="{{ladderStart}}" style="font-size:20rpx;color: #F89600;">剩:{{CouponList.number}} 张</text>
