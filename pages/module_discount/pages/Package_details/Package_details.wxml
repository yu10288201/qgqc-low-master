          <!-- <view style="width: 100%;display: flex;justify-content: center;margin-top: 10rpx;font-weight: 900;">修改文字颜色</view> -->
          <view class="view-color-slider">
            <view style="width:100rpx;height:100rpx;border-radius:50rpx;background:{{blockColor}};margin-top: 20rpx;"></view>
            <slider class="slider-color-picker" style="width:86%;height:30rpx;border-radius:10rpx;margin-left:30rpx" activeColor="transparent" backgroundColor="transparent" bindchange="changeCorlor" block-size="24" value="{{sliderValue}}"></slider>
            <slider class="slider-color-picker-gamut" style="width:86%;height:30rpx;border-radius:10rpx;margin-left:30rpx;background:{{colorGamut}}" activeColor="transparent" backgroundColor="transparent" bindchange="changeCorlorGamut" block-size="24" value="{{sliderValue}}"></slider>
            <slider class="slider-color-picker-gray" style="width:86%;height:30rpx;border-radius:10rpx;margin-left:30rpx;background:{{colorGray}}" activeColor="transparent" backgroundColor="transparent" bindchange="changeCorlorGray" block-size="24" value="{{sliderValue}}"></slider>
          </view>
          <view style="width: 100%;display: flex;justify-content: space-evenly;margin-top: 40rpx;">
            <view class="uploadFile" style="padding: 0;width: 160rpx;height: 60rpx;" bindtap="showChangeFontColorDialog" data-index="2">确认</view>
            <view class="uploadFile" style="padding: 0;width: 160rpx;height: 60rpx;" bindtap="showChangeFontColorDialog" data-index="0">取消</view>
          </view>
        </view>

        <textarea placeholder="{{setMeal ? setMeal[0].setMealAbout : CouponList.coupon_Scopeofapplication}}" style="width: 90%;height: 200rpx;margin-bottom: 20rpx;border: 1rpx solid;border-radius: 10rpx;" bindinput="shareImageDetailConfirm"></textarea>
        
        <view style="width: 100%;display: flex;flex-direction: row;justify-content: flex-start;">
            <text style="margin: 20rpx;margin-right: 0;">图片/视频:</text>
        </view>

        <scroll-view scroll-y="ture" style="max-height: 500rpx;width: 90%;margin-bottom: 40rpx;">
          <view style="width: 99%;border: {{!loadImagePath1 && !temporaryImage && !temporaryImageOfVideo ? '1rpx solid' : '0'}};border-radius: 10rpx;display: flex;justify-content: center;align-items: center;margin-bottom: 40rpx;" bindtap="{{loadImagePath1 || temporaryImage || temporaryVideo ? '' : 'uploadImageOrVideo'}}">
          <image wx:if="{{!loadImagePath1 && !temporaryImage && !temporaryImageOfVideo}}" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/sszg/add_77ef0c0276eb4e249cacb29a6b57acae.png" style="width: 66rpx;height: 66rpx;margin: 82rpx 0;"></image>

          <view wx:if="{{loadImagePath1 || temporaryImage}}" style="position: relative;width: 100%;">
              <image src="{{loadImagePath1 ? loadImagePath1 : temporaryImage}}" style="width: 100%;" mode="widthFix"></image>
              <view bindtap="cancelTemporaryImage" style="position: absolute;top: 0;right: 0;width: 50rpx;height: 50rpx;border-radius: 200rpx 0 0;transform: rotate(270deg);background-color: red;display: flex;justify-content: center;align-items: center;color: white;font-size: 50rpx;">×</view>
            </view>

            <view wx:if="{{!loadImagePath1 && temporaryImageOfVideo}}" style="position: relative;width: 100%;">
              <image src="{{temporaryImageOfVideo}}" style="width: 100%;" mode="widthFix"></image>
              <view bindtap="cancelTemporaryImage" style="position: absolute;top: 0;right: 0;width: 50rpx;height: 50rpx;border-radius: 200rpx 0 0;transform: rotate(270deg);background-color: red;display: flex;justify-content: center;align-items: center;color: white;font-size: 50rpx;">×</view>
            </view>
          </view>
        </scroll-view>
        <view style="display: flex;width: 100%;">
          <view wx:if="{{showIndex == 0}}" style="width: 100%;display: flex;justify-content: center;margin-bottom: 20rpx;">
            <view bindtap="shareImageConfirm" class="uploadFile">生成专属推广海报</view>
          </view>
          <view wx:else style="width: 100%;display: flex;justify-content: space-around;margin-bottom: 20rpx;">
            <button class="uploadFile" style="margin: 0;padding: 0;width: 160rpx;height: 60rpx;" bindtap="shareImageConfirm1">{{shareImageTitle || shareImageDetail1 || loadImagePath1 || temporaryImage || temporaryImageOfVideo ? '确 定 生 成' : '默 认 生 成'}}</button>
            <button class="uploadFile" style="margin: 0;padding: 0;width: 160rpx;height: 60rpx;">素材库</button>
            <button wx:if="{{!loadImagePath1}}" class="uploadFile" style="margin: 0;padding: 0;width: 160rpx;height: 60rpx;" bindtap="tips">转 发</button>
            <button wx:elif="{{showIndex == 2}}" class="uploadFile" style="margin: 0;padding: 0;width: 160rpx;height: 60rpx;" bindtap="shareToCust">转 发</button>
            <button wx:else class="uploadFile" style="margin: 0;padding: 0;width: 160rpx;height: 60rpx;" open-type="share">转 发</button>

          </view>
        </view>
    </view>
</view>

