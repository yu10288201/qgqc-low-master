                    平台主页
                </view>
                <view  style="font-size: 26rpx;line-height: 0;display: flex;flex-direction: row;align-items: center;border-radius: 20rpx;background-color: rgb(255,153,0);height: 41rpx;color: #fff;padding-right: 20rpx;padding-left: 20rpx;margin-right: 30rpx;margin-left:70rpx"  bindtap="toShop">
                   店铺主页
                </view>
              
      </view>
