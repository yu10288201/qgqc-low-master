                <block wx:for="{{setMeal[0].pageUrl}}" wx:key='' wx:key='{{index}}'>
                    <swiper-item>
                        <view class='li'>
                            <image style="height:{{height}}px;width:{{width}}px;" src="{{item.pageURL}}?x-oss-process=image/resize,m_fill,h_{{height}},w_{{width}}" bindtap='bigimg2' data-src="{{item.pageURL}}"></image>
                        </view>
                    </swiper-item>
                </block>
            </swiper>
        </view>
        <view class="model_title" wx:for="{{setMeal}}">
            <view style="width:74%">
                <text wx:if="{{item.refund == 1}}">可退款</text>
                <text wx:else>不可退款</text>
                <text wx:if="{{item.appointment == 1}}" style="margin-left: 12rpx;">需预约</text>
                <text wx:else style="margin-left: 12rpx;">免预约</text>
                <text wx:if="{{item.pastRefund == 1}}" style="margin-left: 12rpx;">过期可退款</text>
                <text wx:else style="margin-left: 12rpx;">过期不退款</text>
                <text wx:if="{{item.pickOneself == 1}}" style="margin-left: 12rpx;">可自提</text>
                <text wx:else style="margin-left: 12rpx;">不可自提</text>
            </view>
        </view>
        <view class="model_title" wx:for="{{setMeal}}">
            <view style="width:60%">
                <text wx:if="{{item.holidays == 1}}">节假日可用</text>
                <text wx:else>节假日不可用</text>
                <text wx:if="{{item.privateRoom == 1}}" style="margin-left: 12rpx;">包间可用</text>
                <text wx:else style="margin-left: 12rpx;">包间不可用</text>
            </view>
            <!-- <view style="width:40%;text-align:right">销量:{{item.setMealSales}}</view> -->
        </view>
        <view class="menu_star" wx:for="{{setMeal}}">
            <view style="width:60%">
                <image style="margin-top:3px;padding-right:1px;width:240rpx;height:40rpx;" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/{{item.starNum}}star.png"></image>
            </view>
            
            <view style="width:40%;text-align:right">
                <image style="margin-top:2rpx" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_like_on.png"></image>
                <text style="padding-top:4rpx;padding-right:1rpx">:{{item.setMealLike}}</text>
            </view>
        </view>
        <view class="menu_star" wx:if="{{setMeal[0].customer_platform_commission_amount || setMeal[0].customer_platform_commission_star || setMeal[0].customer_shop_commission_amount || setMeal[0].customer_shop_commission_star}}" style="color: #ea9518;font-size: 26rpx; font-weight: bolder;">
                <text>提成奖励：</text>
                <text>{{setMeal[0].customer_platform_commission_amount > 0 ? setMeal[0].customer_platform_commission_amount + '元 [平台现金]' : setMeal[0].customer_platform_commission_star > 0 ? setMeal[0].customer_platform_commission_star + '个 [平台星盾]' : ''}}</text>
                <text style="margin-left: 30rpx;">{{setMeal[0].customer_shop_commission_amount > 0 ? setMeal[0].customer_shop_commission_amount + '元 [商家现金]' : setMeal[0].customer_shop_commission_star > 0 ? setMeal[0].customer_shop_commission_star + '个 [商家星盾]' : ''}}</text>
            </view>
        <view class="menu_star" style="display: flex;flex-direction: row;justify-content: space-between;width: 96%; align-items: center;" wx:for="{{setMeal}}" wx:if="{{item.startUsing3 != 1}}">
            <text style="text-align:left;">{{usefulDateText}} <text>[{{filters.userTimeFor(item.useTimeType) == '不限'? '': filters.userTimeFor(item.useTimeType)}}]</text></text>
            <view style="display: flex;flex-direction: row;">
                <button class="dnlm" style="font-size: 32rpx;line-height: 0;display: flex;flex-direction: row;align-items: center;border-radius: 20rpx;background-color: rgb(255,153,0);height: 39rpx;" data-item="{{item}}" bindtap="shareSelect">
                    <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/qgqc/00586bfc2184c33493da987da652235.png" style="width: 45rpx;height: 18rpx;"></image>
                </button>
            </view>
        </view>
        <view class="menu_star" style="display: flex;flex-direction: row;justify-content: space-between;width: 96%; align-items: center;" wx:if="{{item.startUsing3 != 1}}">
            {{startTime}} ~ {{endTime}}
        </view>
        <view style="margin-left: 10rpx;margin-top: 6rpx;display: flex;justify-content: flex-start;font-weight: bold;font-size: 27rpx;" wx:for="{{setMeal}}" wx:if="{{item.startUsing3 == 1}}">
            <view style="color: rgb(135,71,1);">男士价:{{item.manPrice}}元/人</view>
            <view style="color: rgb(255,153,0);margin-left: 8rpx;">返佣:{{item.commission_manPrice}}元</view>
            <view style="color: rgb(135,71,1);margin-left: 20rpx;">女士价:{{item.ladyPrice}}元/人</view>
            <view style="color: rgb(255,153,0);margin-left: 8rpx;">返佣:{{item.commission_ladyPrice}}元</view>
        </view>
        <view style="margin-left: 10rpx;margin-top: 6rpx;display: flex;justify-content: flex-start;font-weight: bold;font-size: 27rpx;" wx:for="{{setMeal}}" wx:if="{{item.startUsing3 == 1}}">
            <view>用餐活动日期:{{filters.formatDate(item.activityDate.time)}}</view>
            <button class="dnlm" style="position: absolute;right: 64rpx;font-size: 32rpx;line-height: 0;display: flex;flex-direction: row;align-items: center;border-radius: 20rpx;background-color: rgb(255,153,0);height: 39rpx;" data-item="{{item}}" data-indexShare="{{index}}" bindtap="shareSelect" wx:if="{{item.coupon_id == null}}">
                <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/qgqc/00586bfc2184c33493da987da652235.png" style="width: 45rpx;height: 18rpx;"></image>
            </button>
        </view>
        <view class="menu_star">
        </view>
    </view>

