/* 新双向选择页面 */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 0 0 40rpx 0;
}

.header {
  background-color: #eed6ba;
  padding: 24rpx 30rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.activity-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.activity-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex-shrink: 0;
}

.activity-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
  border: 1rpx solid #ccc;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
  justify-content: space-between;
}

.activity-picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.activity-picker-arrow {
  font-size: 32rpx;
  color: #999;
}

.table-wrap {
  margin: 20rpx 20rpx 0;
  background-color: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.table-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  gap: 20rpx;
  border-top: 1rpx solid #aaa;
  background-color: #fff;
  z-index: 10;
}

.table-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-bottom: 5px double #aaa;
}

.row-selected {
  background-color: #e8f5ee;
}

.table-row:last-child {
  border-bottom: 5px double #aaa;
}

.table-head {
  background-color: #eed6ba;
  border-bottom: 2rpx solid #b89a7a;
}

.table-head text {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  padding: 16rpx 0;
  text-align: center;
  border-right-color: #b89a7a;
}

.table-row text {
  font-size: 26rpx;
  color: #333;
  padding: 14rpx 0;
  text-align: center;
}

.col-no       { width: 80rpx; flex: none; border-right: 1rpx solid #aaa; }
.col-name     { width: 150rpx; flex: none; border-right: 1rpx solid #aaa; }
.col-gender   { width: 70rpx; flex: none; border-right: 1rpx solid #aaa; text-align: center; }
.col-name-no  { flex: 2; border-right: 1rpx solid #aaa; }
.col-invite-group  { width: 200rpx; flex: none; border-right: 1rpx solid #aaa; text-align: center; }
.col-invited-group { width: 200rpx; flex: none; text-align: center; }
.col-invite        { width: 100rpx; flex: none; display: flex; align-items: center; justify-content: center; border-right: 1rpx solid #aaa; }
.col-reply-invite  { width: 100rpx; flex: none; display: flex; align-items: center; justify-content: center; border-right: 1rpx solid #aaa; }
.col-invited       { width: 100rpx; flex: none; display: flex; align-items: center; justify-content: center; border-right: 1rpx solid #aaa; }
.col-reply         { width: 100rpx; flex: none; display: flex; align-items: center; justify-content: center; }

.table-scroll { height: calc(100vh - 200rpx); }

.rect {
  width: 50rpx;
  height: 34rpx;
  border: 2rpx solid #ccc;
  background-color: transparent;
}



.detail-box {
  background: #fff;
  border-radius: 16rpx;
  width: 660rpx;
  padding: 40rpx 30rpx 50rpx;
  position: relative;
  box-sizing: border-box;
}

.detail-box-invite {
  background: #eed6ba;
}

.detail-box-invite .detail-row {
  border-bottom: 0.5rpx solid #c8a882;
}

.detail-box-invite .detail-input {
  border: 1rpx solid #8b5e2a;
}

.detail-box-invite .detail-reply-scroll {
  border: 1rpx solid #8b5e2a;
}

.detail-scroll {
  max-height: 80vh;
  width: 660rpx;
  border-radius: 16rpx;
  background: #fff;
}

.detail-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 0.5rpx solid #f0f0f0;
}

.detail-col-auto {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-right: 20rpx;
}

.detail-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
}

.detail-val {
  font-size: 28rpx;
  color: #333;
}

.detail-input {
  width: 100%;
  height: 120rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #999;
  border-radius: 12rpx;
  padding: 8rpx;
  box-sizing: border-box;
  margin-top: 8rpx;
}

.detail-input-lg {
  width: 100%;
  height: 140rpx;
  margin-top: 8rpx;
}


.detail-footer {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.detail-reply-scroll {
  height: 160rpx;
  width: 100%;
  margin-top: 8rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.detail-reply-content {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  padding: 8rpx 12rpx;
}

.modal-mask {
  position: fixed;
  top: 0; left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  background: #fff;
  border-radius: 16rpx;
  width: 560rpx;
  padding: 40rpx 40rpx 50rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-close {
  position: absolute;
  top: 20rpx;
  right: 28rpx;
  font-size: 36rpx;
  color: #999;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  margin-top: 10rpx;
}

.reply-textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.modal-btns {
  display: flex;
  flex-direction: row;
  gap: 60rpx;
  justify-content: center;
  width: 100%;
}

.modal-btn {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  border-radius: 30rpx;
  padding: 9rpx 32rpx;
  text-align: center;
}

.modal-btn-accept {
  background-color: #52A76E;
  color: #fff;
}

.modal-btn-reject-red {
  background-color: #e05555;
  color: #fff;
  border: none;
}

.circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  background-color: transparent;
}

.circle-done {
  background-color: #52A76E;
  border-color: #52A76E;
}

.triangle-done {
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 36rpx solid #52A76E;
  background-color: transparent;
  width: 0;
  height: 0;
}

.rect-done {
  background-color: #52A76E;
  border-color: #52A76E;
}

.rect-accept {
  background-color: #52A76E;
  border-color: #52A76E;
}

.rect-reject {
  background-color: #e05555;
  border-color: #e05555;
}

.rect-pending {
  background-color: #ccc;
  border-color: #ccc;
}

.triangle {
  width: 0;
  height: 0;
  background-color: transparent;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 36rpx solid #ccc;
}




.footer-btn {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  background-color: #52A76E;
  border-radius: 30rpx;
  padding: 9rpx 32rpx;
}

.guide-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
  width: 100%;
}

.guide-text {
  font-size: 26rpx;
  color: #333;
  margin-left: 20rpx;
}



