<!--pages/order/order.wxml-->

<view class='top' style="background:url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/store/store_black.png');background-size: 100% 100%">
	<view class='search-view'>
		<text style="margin-left:20rpx">{{dishes_name}}</text>
	</view>
</view>

<view class="model" style="margin-top:90rpx">
	<image style="width: 100%;" src="{{image}}"></image>
</view>



<view class="num" style="border-bottom:2rpx solid #dadada;padding-bottom:20rpx" wx:if="{{setMeal!=''||CouponList!=''||distributionFoodInfo != ''}}">
	<text style="width:50%">数量</text>
	<view class='stepper'>
		<view style="width:100%">
			<image wx:if="{{statu == 1}}" src="https://test.fsmbdlkj.com/wx_official/web/images/image/add.png" bindtap='bindPlus'></image>
			<input bindinput='' disabled value='{{num}}'></input>
			<!-- bindManual -->
			<image wx:if="{{statu == 1}}" src="https://test.fsmbdlkj.com/wx_official/web/images/image/delete.png" class='{{minusStatus}}' type='number' bindtap='bindMinus'></image>
		</view>
	</view>
</view>




<view class="num" style="border-bottom:2rpx solid #dadada;padding-bottom:20rpx">
	<text style="width:50%">支付金额</text>
	<text style="width:50%;text-align:right;color:#F89600;font-size:32rpx;padding-right:20rpx">￥{{totalPrice}}</text>
</view>




<view wx:if="{{statu == 1}}" style="margin-top: 20rpx;margin-bottom: 15%;display: flex;flex-direction: column;justify-content: center;align-items: center;width: 100%;">
	<scroll-view scroll-y style="height: 765rpx;background-color: #f2f2f2;width: 93%;">
		<view wx:for="{{constituteTypeList}}" wx:key="index">
			<view wx:if="{{item.choosableCount != -1}}">
				● {{item.constituteTypeName}}
				<text wx:if="{{item.constituteTypeCount != 1 && item.choosableCount != -1}}">{{item.constituteTypeCount}} 选{{item.choosableCount}}</text>
				<text wx:if="{{item.constituteTypeCount != 1 && item.choosableCount == -1}}">{{item.constituteTypeCount}} {{item.setMealConstituteList[0].constituteUnit}} </text>
				<checkbox-group bindchange="chooseChange" class="meal_dishes" wx:for="{{item.lstSetMealConstitute}}" wx:for-item="chooseDetail" data-item="{{item}}" data-index="{{index}}" data-chooseIndex="{{chooseIndex}}" wx:for-index="chooseIndex">
					<label style="width: 100%;display: flex;flex-direction: row;justify-content: space-between;">
						<view style="display: flex;flex-direction: row;width: 100%;">
							<checkbox disabled="{{chooseDetail.isChoose}}" />
							<text style="width:80%">{{chooseDetail.constituteName}}（{{chooseDetail.constituteUnit}}）x{{chooseDetail.constituteNum}}</text>
						</view>
						<!-- <view>
							<text style="width:20%;text-align:right">￥{{chooseDetail.constituteValue*chooseDetail.constituteNum}}</text>
						</view> -->
					</label>
				</checkbox-group>
			</view>
			<view wx:elif="{{item.choosableCount == -1}}">
				<view style="display: flex;">
					<view>
						<text>● {{item.constituteTypeName}}</text>
						<view style="margin-left: 15%;width: 100%;" wx:for="{{item.lstSetMealConstitute}}" wx:for-item="item1">
							{{item1.constituteName}}
						</view>
					</view>
				</view>
			</view>
		</view>
	</scroll-view>
</view>

<view wx:else style="margin-top: 20rpx;margin-bottom: 15%;display: flex;flex-direction: column;justify-content: center;align-items: center;width: 100%;">
	<scroll-view scroll-y style="height: 765rpx;background-color: #f2f2f2;width: 93%;">
		<view wx:for="{{constituteTypeList}}" wx:key="index">
			<view wx:if="{{item.choosableCount != -1}}">
				● {{item.constituteTypeName}}
				<text wx:if="{{item.constituteTypeCount != 1 && item.choosableCount != -1}}">{{item.constituteTypeCount}} 选{{item.choosableCount}}</text>
				<text wx:if="{{item.constituteTypeCount != 1 && item.choosableCount == -1}}">{{item.constituteTypeCount}} {{item.setMealConstituteList[0].constituteUnit}} </text>
				<view class="meal_dishes" wx:for="{{item.lstSetMealConstitute}}" wx:for-item="chooseDetail" data-item="{{item}}" data-index="{{index}}" data-chooseIndex="{{chooseIndex}}" wx:for-index="chooseIndex">
					<view style="width: 100%;display: flex;flex-direction: row;justify-content: space-between;" wx:if="{{!chooseDetail.isChoose}}">
						<view style="display: flex;flex-direction: row;width: 100%;">
							<!-- <checkbox disabled="{{chooseDetail.isChoose}}" /> -->
							<text style="width:80%">{{chooseDetail.constituteName}}（{{chooseDetail.constituteUnit}}）x{{chooseDetail.constituteNum}}</text>
						</view>
						<!-- <view>
							<text style="width:20%;text-align:right">￥{{chooseDetail.constituteValue*chooseDetail.constituteNum}}</text>
						</view> -->
					</view>
				</view>
			</view>
			<view wx:elif="{{item.choosableCount == -1}}">
				<view style="display: flex;">
					<view>
						<text>● {{item.constituteTypeName}}</text>
						<view style="margin-left: 15%;width: 100%;" wx:for="{{item.lstSetMealConstitute}}" wx:for-item="item1">
							{{item1.constituteName}}
						</view>
					</view>
				</view>
			</view>
		</view>
	</scroll-view>
</view>



<!-- <button open-type="getUserInfo" bindgetuserinfo="getUserInfo"> 获取头像昵称 </button> -->
<view class="tap" wx:if="{{statu == 1}}" open-type="getUserInfo" bindtap="addDishNew">
	<button class="tap">添加购物车</button>
</view>



