<!--设置按钮点击后打开选项-->
<view style="display:flex;flex-direction:column;position:fixed;justify-content:center;align-items:center;width:100vw;bottom:0;height:100vh;background-color:#00000055;left:0;right:0;top:0;margin:auto;z-index:9999;" wx:if="{{mall_password_dialog==true}}">
    <view style="display: flex;flex-direction: column;justify-content: space-between;width: 90vw;border-radius: 20rpx; height: 400rpx;background-color: #FFFFFF;" >
      <view style="display: flex;flex-direction: column;width: 100%;height: 100%;">
        <view style="margin: 0 20rpx 0 20rpx;font-size:18px;font-weight:bold;margin-top:20rpx;display: flex;flex-direction: row;justify-content: space-between;align-items: center;">
          <view>
            代金券使用密码
          </view>
          <view  catch:tap="closeBuyerPasswordDialog">
            <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_close.png" style="width: 50rpx;height: 50rpx;"></image>
          </view>
        </view>

        <view style="overflow-x:scroll;">
        <view style="display: flex;flex-direction: column;align-items: center;justify-content: center;">
          
          <view style="flex: 1;display: flex;flex-direction: row;justify-content: flex-start;width: 100%;margin-top: 40rpx;"> 
            <text style="margin-right: 20rpx;font-weight: 600;font-size: 29rpx;width: 120rpx;text-align: right;">密码:</text>
         
         <input type="password" model:value="{{buyer_password}}" style="background-color: #fff;width: 320rpx;border:1rpx solid #ccc;border-radius: 10rpx;font-size: 20rpx;" />
          </view>

          <view catch:tap="checkBuyerPassword" style="height: 52rpx; color: white;background-color:#52A76E;display: flex;align-items: center;justify-content: center;border-radius: 35rpx;padding: 0rpx 30rpx; font-size: 29rpx;margin-left: 20rpx;margin-top: 30rpx;">
                确定
              </view>
        </view>

        </view>
      </view>
  
    </view>
</view>