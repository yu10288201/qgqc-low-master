var filters = {
  toFix: function (value) {
    return Math.round(value*1000)/100
  },
  people:function(value2){
    var b = ''
    var c = value2
    if(c == '2'){
      b = '[超值菜品]'
    }else{ 
      b = '[超值套餐]'
    }
    return b
  },
  dishes_unit:function(value,value2){
    var a = value;
    var b = value2;
    if(b == 2){
      return a
    }else{
      return '套'
    }
  },
  toFix2: function (value) {
    return value != null ? parseFloat(value.toFixed(2)) : ''//此处2为保留两位小数
  },
  addHeight:function(index){
    return index * 4 + 25 ;
  },
  usefulDate:function (usefulDate) {
