    }
    if(usefulDate.indexOf('4') != -1){
      day += '四、'
    }
    if(usefulDate.indexOf('5') != -1){
      day += '五、'
    }
    if(usefulDate.indexOf('6') != -1){
      day += '六、'
    }
    if(usefulDate.indexOf('7') != -1){
      day += '日、'
    }
    // console.log(day)
    return '周'+day.substring(0,day.length-1)+'可用'
  
    //别人拉屎我也拉，我直接拉一大坨
  
