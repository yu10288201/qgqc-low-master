<!-- 打印机弹窗页面 -->
<!-- 选择打印机弹窗 -->
<!-- <view class='popup-window-bg' wx:if="{{showPrintChoose}}" style="flex-direction:column;"> -->
<view class='popup-window-print' style="height:{{windowHeight*0.92}}px;align-items: center;margin-top: 5%" wx:if="{{showPrintChoose}}">
    <text style="font-size:32rpx;width:100%;color:red;margin-left: 20rpx;margin-top:25px;font-weight:bold;">选择打印机：</text>
    <view class="modal-title print-mod-1" style="width:90%;">
        <scroll-view scroll-y='true' style='width:100%;height: {{windowHeight*0.75}}px;' class="print_scroll">
            <label class="radio print-lab" data-type="0" style="border-bottom: 0.5px solid green;padding-bottom: 2px;width:100%;height:auto;">
                <view class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
                    <text style="font-size:32rpx;">编号</text>
                </view>
                <view class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
                    <text style="font-size:32rpx;">状态</text>
                </view>
                <view class="box" style="width:40%;height:80rpx;margin-bottom: -2rpx;">
                    <text style="font-size:32rpx;">名称</text>
                </view>
            </label>
            <label class="radio print-lab" data-type="0" bindtap="chooseOnePrint" wx:for="{{printShowArray}}" data-index="{{index}}" data-item="{{item}}" wx:key="index" style="border-bottom: 0.5px solid green;padding-bottom: 2px;width:100%;height:auto;">
                <view class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
                    <radio value="r1" checked="{{item.check}}" />
                    <text style="font-size:32rpx;">{{item.num}}</text>
                </view>

                <view wx:if="{{item.paper_state!=0}}" class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
                    <text style="font-size:32rpx;" wx:if="{{item.connect_status==0}}">未连接</text>
                    <text style="font-size:32rpx;color:green" wx:if="{{item.connect_status==1}}">正常</text>
                    <text style="font-size:32rpx;" wx:if="{{item.connect_status==2}}">脱机</text>
                </view>

                <view wx:if="{{item.paper_state==0}}" class="box" style="border-right:1rpx solid green;width:30%;height:80rpx;margin-bottom: -2rpx;">
                    <text style="font-size:32rpx;color:red">{{item.paper_state==0?'缺纸':''}}</text>
                </view>

                <view class="box" style="width:40%;height:80rpx;margin-bottom: -2rpx;">
                    <text style="font-size:32rpx;">{{item.name}}</text>
                </view>
            </label>
        </scroll-view>
    </view>

    <image style='width:60rpx;height:60rpx;float:right;position: absolute;right: 10px;top:10px' src='{{i_close_img_url}}' bindtap='closePrint'></image>
    <view class="print_btn" style="margin-top:50rpx;padding-left: 34%;">
        <button class="btn_mid_y" bindtap="{{showprintmodalstatus && !showAllConfirmPrintView?'submitTheOrder':'printAllConfirmNew'}}" style="height: 25px;">确认</button>
    </view>
</view>
<!-- </view> -->


<!-- 全单部长确认打印机打印总单弹窗页面 -->
<view class='popup-window-bg' wx:if="{{showAllConfirmPrintView}}" style="flex-direction:column;">
    <view class='popup-window-print' wx:if="{{showAllConfirmPrintView}}" style="height:350rpx">
