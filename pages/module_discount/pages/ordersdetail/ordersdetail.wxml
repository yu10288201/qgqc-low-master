            <view wx:if="{{advanceDeposit}}" style="display: flex;flex-direction: row;justify-content: center;align-items: center;width: 100%;"><text style="width: 55%;text-align: right;">预存抵扣：</text><text style="width: 45%;text-align: left;">{{filters.toFix(advanceDeposit > actualTotalByOrderId ? actualTotalByOrderId : advanceDeposit )}}元</text></view>
