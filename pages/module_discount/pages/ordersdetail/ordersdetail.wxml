        <view class="modal-title print-mod-1">
            <view class="box" style="margin-top:80rpx;width:90%;border: 1rpx solid green;justify-content: flex-start;padding: 10rpx;height:150rpx">
                <label class="radio print-lab" data-type="0" bindtap="choosePrint" style="width:auto;margin-left: 2%;">
                    <!-- <radio value="r2" checked="{{printType1}}"/> -->
                    <text style="font-size:32rpx;">是否打印结账总单：</text>
                </label>
                <radio-group style="display: flex;">

                    <view class="box">
                        <label style="width:auto;display:flex" bindtap="closePrintAllConfirm" data-type="0">
                            <radio value="r2" name="pt" /><text style="font-size:32rpx;width:auto">否</text>
                        </label>
                    </view>

                    <view class="box" style="margin-left: 25rpx">
                        <label style="width:auto;display:flex" bindtap="choosePrint" data-type="1">
                            <radio value="r2" name="pt" /><text style="font-size:32rpx;width:auto">是</text>
                        </label>
                    </view>

                </radio-group>
            </view>

        </view>

        <image style='width:60rpx;height:60rpx;float:right;position: absolute;right: 10px;top:10px' src='{{i_close_img_url}}' bindtap='closePrint2'></image>
    </view>
</view>
