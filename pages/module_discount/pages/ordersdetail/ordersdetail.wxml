            <wxs module="ahh">
                function getUsePayment(paymethod) {
                    var usePayment = ''
                    switch (paymethod) {
                        case 2:
                            usePayment = "微信线上"
                            break;
                        case 9:
                            usePayment = "微信线下"
                            break;
                        case 4:
                            usePayment = "银行卡"
                            break;
                        case 5:
                            usePayment = "支付宝"
                            break;
                        case 3:
                            usePayment = "现金"
                            break;
                        case 8:
                            usePayment = "其他方式"
                            break;
                        default:
                            usePayment = "还需其他方式"
                            break;
                    }
                    return usePayment
                }
                module.exports = {
                    getUsePayment: getUsePayment
                }
            </wxs>
