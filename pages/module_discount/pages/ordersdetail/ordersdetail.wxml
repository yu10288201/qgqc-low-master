<wxs module="Detail">
    function getCartListTotal(cartList) {
        var total = 0
        cartList.forEach(function (item) {
            if (item.countNum) {
                total = total + item.dishes_price * item.number
            } else {
                total = total + item.dishes_price * item.number
            }
        })
        return toFixed(total)
    }
    function getCartListCount(cartList) {
        var total = 0
        cartList.forEach(function (item) {
            if (item.countNum) {
                total = parseInt(item.countNum) + total
            } else {
                total = parseInt(item.number) + total
            }
        })
        return total
    }
    function getCountNum(cartList, id) {
        if (cartList.length && id) {
            var countNum = 0
            cartList.forEach(function (item) {
                if (item.dishes_id === id) {
                    countNum = countNum + (item.countNum || item.number)
                }
            })
            return countNum === 0 ? '' : countNum
        } else {
            return ''
        }
    }
    function toFixed(num, len) {
        if (len == undefined) {
            len = 2
        }
        return parseFloat(num).toFixed(len)
    }
    module.exports = {
        toFixed: toFixed
    }
</wxs>
