  padding-left: 20rpx;
  border: 0.5rpx solid #F07971;
}
.favourable_text{
  font-size: 28rpx;
  margin-left: 20rpx;
  color: #444444;
}
.up{
  animation: up .2s;
}
.down{
  animation: down 1s;
}
@keyframes up
{
  0% { transform: translateY(550rpx); }
  100% { transform: translateY(0); }
}
@keyframes down
{
  0% { transform: translateY(0); }
  100% { transform: translateY(550rpx); }
}

