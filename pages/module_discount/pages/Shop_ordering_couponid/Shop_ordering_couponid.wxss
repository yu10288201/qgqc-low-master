/* 区域 */
.nav {
  position: relative;
  z-index: 99;
  display: flex;
}

.nav-son {
  display: flex;
  flex: 1;
  text-align: center;
  align-items: center;
  justify-content: center;
}

.content {
  display: inline-block;
  letter-spacing: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 120rpx;
}

.quyu {
  position: relative;
  /* 区域的筛选：默认状态下不显示 */
  display: none;
  /* height: 450rpx; */
  height: 800rpx;
  z-index: 5;
}

.quyu .qy {
  overflow-y: scroll;
  float: left;
  width: 33.333333333%;
  /* height: 450rpx; */
  height: 96%;
  line-height: 80rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  border-right: 1rpx solid #f4f4f4;
  /* border-bottom: 1rpx solid rgb(183, 183, 184); */
}

.quyuAll {
  width: 100%;
  height: 100%;
}

.qy view {
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
  border-bottom: 1rpx solid #f4f4f4;
}

.quyu-left {
  background: #fff;
}

.quyu-center {
  background: #fff;
}

.quyu-right {
  background: #fff;
}

.quyu-right view {
  border-bottom: 1rpx solid #efefef;
  display: flex;
  align-items: center;
}

.quyu-right image {
  width: 34rpx;
  height: 34rpx;
  margin-left: 30rpx;
}
.current {
  /* background: #e0e0e0; */
  color: #f23030;
}

.current2 {
  /* background: #fff; */
  color: #f23030;
}

.current3 {
  /* background: #fff; */
  color: #f23030;
}

.fullbg {
  position: fixed;
  top: 110rpx;
  z-index: 1;
  width: 100%;
  height: 100%;
  background: #fff;
  transition: all 2s;
  opacity: 0;
}

.fullopacity {
  opacity: 0.5;
}

.nav-son.active .content {
  color: #f23030;
}

.nav-son.active image {
  transform: rotate(180deg);
  background: none;
}

@keyframes slidown {
  from {
    transform: translateY(-100%);
  }

  to {
    transform: translateY(0%);
  }
}

.slidown {
  display: block;
  animation: slidown 0s ease-in both;
  width: 750rpx;
  height: 600rpx;
  background-color: #ffffff;
}


@keyframes slidup {
  from {
    transform: translateY(0%);
  }

  to {
    transform: translateY(-100%);
  }
}

.slidup {
  display: block;
  animation: slidup 0.7s ease-in both;
  width: 750rpx;
}

.disappear {
  display: none;
}

button::after {
  border: none;
}

button {
  background-color: #f23030;
  height: 88rpx;
  width: 48%;
  border-radius: 40rpx;
  font-size: 32rpx;
  display: flex;
  justify-content: center;
