<!--pages/Shop_ordering/Shop_ordering.wxml-->
<wxs module="filters" src="../Shop_ordering_couponid/filter.wxs"></wxs>
<import src="../../../../components/filterbar/filterbar.wxml" />
<wxs module="quote" src="../superValueOrderDetail/superValueOrderDetail.wxs"></wxs>


<view class='top' style="background:url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/store/store_black.png');background-size: 100% 100%">
  <view class='search-view'>
    <!-- <image src="http://img3.imgtn.bdimg.com/it/u=2064794736,2436845779&fm=26&gp=0.jpg"></image> -->
    <text wx:if="{{shop_id!=''}}" style="margin-left:20rpx;color: #000000">{{shop_name}}</text>
    <!-- <view wx:else  style="width:90%" bindtap="selectJump" data-id="搜索">
			<view class='search-input' style="display: flex;justify-content: space-around;">
				<input type="text" class='input' disabled="true" placeholder-class="placeholder-color" placeholder="请输入商家名称、菜品" value="{{wxSearchData.value}}" />
				<image src='https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/search.png' />
			</view>
		</view> -->
    <view wx:else style="letter-spacing: 0rpx;display:flex;width: 100%;">
      <!-- <view class="show_view {{file_id==0?'active':''}}" data-id="0" data-index="0" bindtap="file1">超值套餐/菜品</view> -->
      <view class="show_view {{file_id==1?'active':''}}" data-id="1" data-index="0" bindtap="file1">优惠券</view>
    </view>
  </view>
</view>

<view class="show">
  <view wx:if="{{shop_id!=''}}" style="display: flex;width: 100%;">
    <!-- <view class="show_view {{file_id==0?'active':''}}" data-id="0" data-index="0" bindtap="file">超值套餐/菜品</view> -->
    <view class="show_view {{file_id==1?'active':''}}" data-id="1" data-index="0" bindtap="file">优惠券</view>
  </view>
  <view wx:else style="width:100%" data-id="搜索">
    <view style="display:flex" class="search-input">
      <input type="text" class='input' style="width:80%;padding-left: 40rpx;" placeholder-class="placeholder-color" placeholder="请输入优惠券关键词" value="{{wxSearchData.value}}" bindtap="inputTap" bindinput="wxSearchInput" bindconfirm="wxSearchConfirm" focus="{{focus}}" disabled="{{input_bol}}" />
      <view style="width:20%;display: flex;justify-content: center;" bindtap="wxSearchConfirm">
        <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/image/search.png" role='img'></image>
      </view>
    </view>
    <view class="weui-icon-clear" wx:if="{{wxSearchData.value.length > 0}}" bindtap="wxSearchClear">
      <icon type="clear" size="14"></icon>
    </view>
    <!-- 搜索搬运-->

    <view catchtouchmove="true" class='myFilterBar' wx:if='{{select_bol}}'>
      <view catchtouchmove="true" class='allArea'>
        <view class="nav">
          <view class="nav-son {{shownavindex == 1? 'active' : ''}}" bindtap="listqy" data-nav="1">
            <view class="content" style='font-weight: bold;'>{{city}}</view>
            <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/xiala.png"></image>
          </view>
        </view>

        <!-- 区域-》区域、标签 -->
        <view class="quyu {{qyopen ? 'slidown' : 'slidup'}} {{qyshow ? 'disappear':''}}">
          <view class='quyuAll'>

            <view class="qy quyu-left">
              <view class="{{select1 == item.city_name ? 'current' : ''}}" wx:for="{{cityleft}}" wx:key="key" bindtap="selectleft" data-city='{{item.city_name}}' data-ID="{{item.id}}">
                {{item.city_name}}
              </view>
            </view>

            <view class="qy quyu-center">
              <view class="{{select2 == item.county_name? 'current2' : ''}}" wx:for="{{citycenter}}" wx:key="key" bindtap="selectcenter" data-city='{{item.county_name}}' data-ID="{{item.id}}">
                {{item.county_name}}
              </view>
            </view>

            <view class="qy quyu-right">
              <view class="{{select3 == item.area_name? 'current3':''}}" wx:for="{{cityright}}" wx:key="key" bindtap="selectright" data-city='{{item.area_name}}' data-ID="{{item.id}}">
                {{item.area_name}}
              </view>
            </view>
          </view>

          <view class='form-btn'>
            <button class='btn-reset' bindtap='quyuEmpty'>重 置</button>
            <button class='btn-submit' bindtap='submitFilter'>确 定</button>
          </view>
        </view>
      </view>

      <view catchtouchmove="true" class="classification">
        <view class="tabTit box">
          <view class="flex1{{!file[index]?' active':''}}" wx:for="{{fileTxt}}" wx:key="type" data-index="{{index}}" bindtap="filetab">
            <text style='letter-spacing:10rpx;font-weight: bold;'>{{item}}</text>
            <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/xiala.png"></image>
          </view>
        </view>

        <view class="tabLayer1" hidden="{{file[0]}}">
          <view style="margin-bottom:30rpx;margin-top:10rpx">
            <block wx:for="{{typeList}}">
              <text class="{{fileid==item.id?'active':''}}" data-id="{{item.id}}" data-index="0" data-txt="{{item.typeName}}" data-condition="{{item.condition}}" bindtap="file">{{item.typeShowName}}</text>
            </block>
          </view>
          <view class="tab-button">
            <button class='reset' bindtap='reset'>重 置</button>
            <button class='submit' bindtap='submit'>确 定</button>
          </view>
        </view>
      </view>

      <view catchtouchmove="true" class='sort'>
        <view class="tabTit box">
          <view class="flex1{{!tab[index]?' active':''}}" wx:for="{{tabTxt}}" wx:key="type" data-index="{{index}}" bindtap="filterTab">
            <text style='letter-spacing:10rpx;font-weight: bold;'>{{item}}</text>
            <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/xiala.png"></image>
            <!-- <image src="{{item.pageUrl)}}"></image> -->
          </view>
        </view>

        <view catchtouchmove="true" class="tabLayer" hidden="{{tab[0]}}">
          <view style="margin-bottom:30rpx;margin-top:10rpx">
            <text class="{{sort_id==0?'active':''}}" data-id="0" data-index="0" data-txt="智能排序" data-condition="priceAsc" bindtap="filter">智能排序</text>
            <text class="{{sort_id==1?'active':''}}" data-id="1" data-index="0" data-txt="月销量 ↓" data-condition="priceDesc" bindtap="filter">月销量 ↓</text>
            <text class="{{sort_id==2?'active':''}}" data-id="2" data-index="0" data-txt="距离 ↑" data-condition="salesAsc" bindtap="filter">距离 ↑</text>
            <text class="{{sort_id==3?'active':''}}" data-id="3" data-index="0" data-txt="点赞 ↓" data-condition="fabulousAsc" bindtap="filter">点赞 ↓</text>
            <text class="{{sort_id==4?'active':''}}" data-id="4" data-index="0" data-txt="价格 ↑" data-condition="fabulousDesc" bindtap="filter">价格 ↑</text>
            <text class="{{sort_id==5?'active':''}}" data-id="5" data-index="0" data-txt="折扣 ↑" data-condition="dishesName" bindtap="filter">折扣 ↑</text>
            <!-- <text wx:if="{{menushow}}" class="{{sort_id==3?'active':''}}" data-id="3" data-index="0" data-txt="人均消费 ↑" data-condition="salesDesc"  bindtap="filter">人均消费 ↑</text> -->
            <text class="{{sort_id==6?'active':''}}" data-id="6" data-index="0" data-txt="人均消费↑" data-condition="salesDesc" bindtap="filter">人均消费↑</text>
          </view>
          <view class="tab-button">
            <button class='reset' bindtap='reset'>重 置</button>
            <button class='submit' bindtap='submit'>确 定</button>
          </view>
        </view>
      </view>

      <view class='screen1' bindtap='closeOther'>
        <template is="filterbar" data="{{ ...$wux.filterbar }}" />
      </view>

    </view>
    <!-- 搜索搬运结束-->





  </view>
</view>

