<view class="meal" wx:if="{{file_id==1 && select_coupon}}" style="{{select_bol ? '' :'margin-top:150rpx'}}">
  <view wx:if="{{showid ==0}}" style="width:100%;text-align:center;color:#777777;margin-top:40%">
    没有关键词或没搜索出相关优惠券
  </view>
  <view wx:if="{{couponid ==1}}" style="margin-top: 20rpx" wx:for="{{discountList}}">
    <view>
      <view class="ticket_title" style="flex-direction: row;" bindtap="top" data-index="{{index}}">
        <view style="display:flex;justify-content: center;align-items: center;width:15%">
          <image style="width: 80rpx;height: 80rpx;" src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/%E5%88%87%E7%93%9C%E5%88%87%E8%8F%9C/image/bg1.png"></image>
        </view>
        <view style="display:flex;flex-direction: column;width:85%">
          <view class="menu_right_view" style="margin-left: 0px;margin-bottom:5rpx;margin-top: 10rpx;">
            <!-- <text style="width:100%;font-size:30rpx;font-weight:900;width:76%">{{item.coupon_original}}元优惠券</text> -->
            <text style="font-size:30rpx;color:#000;font-weight:900;width:100%;">{{item.shop_name}}</text>
            <!-- <view class="detail" bindtap="top" wx:for-index="index" data-index="{{index}}">详情</view> -->
          </view>
          <view class="menu_right_view" style="margin:10rpx 0rpx;width: 100%;">
            <view style="width:50%;">
              <text style="white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">{{(item.per_capita_price == null || item.per_capita_price == '') ? '50':item.per_capita_price}}元/人 | {{item.shop_type}}</text>
            </view>
            <view style="background:transparent;color:#777777;text-align: right;width: 50%;margin-left:0%;font-size: 25rpx;">
              <text style="padding:5rpx">{{item.area}} | {{filters.getDistance(item.distance)}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="ticket">
        <view class="menu_right_view">
          <!-- <text style="width:100%;font-size:30rpx;font-weight:900;width:76%">{{item.coupon_original}}元优惠券</text> -->
          <text style="width:100%;font-size:30rpx;font-weight:900;width:76%">{{item.coupon_name}}</text>
          <view class="detail" bindtap="top" wx:for-index="index" data-index="{{index}}">详情</view>
        </view>
        <view class="menu_right_view">
          <text style="width:100%;width:76%">[{{item.shop_name}}]</text>
        </view>
        <view class="menu_right_view" style="margin-top:5rpx">
          <text wx:if="{{shop_id==''}}" style="white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">月销量:{{item.coupon_salesvolue}} |</text>
          <text wx:if="{{item.coupon_superposition == 0}}" style="white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">不可叠加</text>
          <text wx:elif="{{item.coupon_superposition >= '9999'}}" style="white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">可无限叠加</text>
          <text wx:else style="white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">可叠加{{item.coupon_superposition}}张</text>
        </view>
        <!-- <view class="menu_right_view">
				<image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/images/i_like_on.png"></image>
				<text style="padding-top:4rpx;padding-right:1rpx">:234</text>
					<text style="width:100%;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;font-weight:900">店铺：东海明珠酒楼</text>
			</view> -->

        <view class="menu_right_view" style="margin-top:5rpx">
          <text style="width:100%;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">周{{item.coupon_ruleweekstar}}至周{{item.coupon_ruleweekend}}可用</text>
          <!-- <text style="width:100%;white-space: nowrap;text-overflow: ellipsis;overflow: hidden;">周{{item.coupon_ruleweekstar}}至周{{item.coupon_ruleweekend}}可用</text> -->
        </view>

        <view style="display: flex;margin-bottom: 15rpx;width: 94%;margin-top: 10rpx;font-size: 26rpx;color: #ea9518;" wx:if="{{(item.customer_platform_commission_star != 0 || item.customer_platform_commission_amount != 0) && (item.customer_shop_commission_star != 0 || item.customer_shop_commission_amount != 0)}}">
            <view style="font-weight: bolder;">提成奖励:</view>
            <view style="font-weight: bolder;" wx:if="{{item.customer_platform_commission_star != 0 || item.customer_platform_commission_amount != 0}}">{{item.customer_platform_commission_star == 0 ? item.customer_platform_commission_amount : item.customer_platform_commission_star}}{{item.customer_platform_commission_star == 0 ? '元 [平台现金]' : '个 [平台星盾]'}}</view>
            <view style="font-weight: bolder;margin-left: 30rpx;" wx:if="{{item.customer_shop_commission_star != 0 || item.customer_shop_commission_amount != 0}}">{{item.customer_shop_commission_star == 0 ? item.customer_shop_commission_amount : item.customer_shop_commission_star}}{{item.customer_shop_commission_star == 0 ? '元 [商家现金]' : '个 [商家星盾]'}}</view>

          </view>

        <view class="menu_right_view">
          <view style="width:76%">
            <view style="margin-bottom:10rpx;color:#ea9518;margin:0rpx">
              <text style="font-size:28rpx;font-weight:900">￥{{filters.toFix2(item.coupon_facevalue)}}元</text>
              <text style="text-decoration:line-through;margin-left:20rpx;padding-top:6rpx;color:#363636">￥{{item.coupon_original}}</text>
              <text style="font-size:20rpx;margin-top:9rpx;line-height:24rpx;height:24rpx;margin-left:20rpx;border: 0.5rpx solid #ea9518;">{{filters.toFix(item.coupon_facevalue/item.coupon_original)}}折</text>
            </view>
          </view>
          <view class="rush" bindtap="goorder" wx:for-index="index" data-index="{{index}}">抢购</view>
        </view>

      </view>
    </view>
  </view>
</view>


<view class="meal" wx:if="{{file_id==1 && !select_coupon}}" style="{{select_bol ? '' :'margin-top:150rpx'}}">
  <view wx:if="{{couponid ==0}}" style="width:100%;text-align:center;color:#777777;margin-top:40%">
    该店铺未录入优惠券
  </view>
  <view wx:if="{{couponid ==1}}" style="margin-top: 20rpx" wx:for="{{CouponList}}">
    <view>
      <view class="ticket" style="display: flex;flex-direction: row;justify-content: space-between;">
        <view class="menu_right_view">
          <view style="width:100%;display: flex;justify-content: space-between;">
            <view style="font-size:30rpx;font-weight:900;width: 75%;">{{item.coupon_name}}</view>
            <view class="detail" style="width: 15%;margin-top:10rpx;margin-left: 0;height: 40rpx;" bindtap="top" wx:for-index="index" data-index="{{index}}">详情</view>
          </view>
          <text style="width:100%;">[{{item.shop_name}}]</text>

          <view style="width: 100%;display: flex;justify-content: space-between;">
            <view style="display: flex;flex-direction: column;">
              <text wx:if="{{item.coupon_superposition ==0}}">不可叠加</text>
              <text wx:elif="{{item.coupon_superposition >= '9999'}}">可无限叠加</text>
              <text wx:else>可叠加{{item.coupon_superposition}}张</text>
              <text>{{quote.usefulWeek(item.coupon_ruleweekstar,item.coupon_ruleweekend)}}</text>
            </view>
            <text style="font-size:40rpx;font-weight:bolder;color: #ea9518;margin-right: 20rpx;">￥{{filters.toFix2(item.coupon_facevalue)}}元</text>
          </view>

          <view style="display: flex;width: 100%;margin-top: 10rpx;font-size: 26rpx;color: #ea9518;" wx:if="{{(item.customer_platform_commission_star != 0 || item.customer_platform_commission_amount != 0) && (item.customer_shop_commission_star != 0 || item.customer_shop_commission_amount != 0)}}">
            <text style="font-weight: bolder;">提成奖励:</text>
            <text style="font-weight: bolder;" wx:if="{{item.customer_platform_commission_star != 0 || item.customer_platform_commission_amount != 0}}">{{item.customer_platform_commission_star == 0 ? item.customer_platform_commission_amount : item.customer_platform_commission_star}}{{item.customer_platform_commission_star == 0 ? '元 [平台现金]' : '个 [平台星盾]'}}</text>
            <text style="font-weight: bolder;margin-left: 30rpx;" wx:if="{{item.customer_shop_commission_star != 0 || item.customer_shop_commission_amount != 0}}">{{item.customer_shop_commission_star == 0 ? item.customer_shop_commission_amount : item.customer_shop_commission_star}}{{item.customer_shop_commission_star == 0 ? '元 [商家现金]' : '个 [商家星盾]'}}</text>

          </view>

          <view style="width:76%">
            <view style="margin-bottom:10rpx;color:#ea9518;margin:0rpx">
              <text style="font-weight: bolder;">购买价：<text style="color: green;font-size: 30rpx;font-weight: bold;">￥{{item.coupon_original}}元</text></text>
            </view>
          </view>
          <view style="width: 100%;display: flex;justify-content: space-between;">
            <view>
              <text wx:if="{{item.coupon_validityend != null}}">有效期：{{quote.formatDate(item.coupon_validityend,0)}} 止</text>
            </view>
            <view class="rush" style="width: 15%;margin-bottom: 10rpx;height: 40rpx;" bindtap="goorder" wx:for-index="index" data-index="{{index}}">抢购</view>
          </view>

          <!-- <text wx:if="{{item.coupon_validityend == null}}">有效期：{{item.period_of_validity}} 天</text> -->
        </view>
        <!-- <view style="display: flex;flex-direction: column;justify-content: space-between;width: 45%;align-items: flex-end;margin-right: 20rpx;">
                    <view class="detail" style="width: 30%;margin-top:10rpx;" bindtap="top" wx:for-index="index" data-index="{{index}}">详情</view>
                    <text style="font-size:40rpx;font-weight:bolder;margin-right: 130rpx;color: #ea9518;">￥{{filters.toFix2(item.coupon_facevalue)}}元</text>
                    <view class="rush" style="width: 30%;margin-bottom: 10rpx;" bindtap="goorder" wx:for-index="index" data-index="{{index}}">抢购</view>
                </view> -->
      </view>
    </view>
  </view>
</view>



<!-- 立即预约 -->
<view class="screen" wx:if="{{disTag}}"></view>
<view wx:if="{{disTag}}" class='notice_details'>
  <view style="width:94%;margin-left:3%">
    <view class="order-box {{disTag== true ? 'up' : 'down'}}">
      <icon class='clear' type="clear" size="24" bindtap='clear' />
      <view style="display:flex;flex-direction:row">
        <view class="coupon_details">
          <view style="width:66%;border-right: 1rpx dashed #F07971;">
            <view class="coupon_price_details">
              <text style="font-size:24rpx;margin-top:15rpx">￥</text>
              <text style="font-size:40rpx">2</text>
            </view>
            <view class="coupon_price_details">
              <text style="font-size:22rpx;">满30可用</text>
            </view>
            <view class="coupon_price_details" style="margin-bottom:10rpx">
              <text style="font-size:22rpx;">有效期至2020.04.27</text>
            </view>
          </view>
