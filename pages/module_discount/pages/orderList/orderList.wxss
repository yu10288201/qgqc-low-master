.modelview {
  position: fixed;
  top: 0;
  bottom: 0;
  right: 0;
  left: 0;
  background-color: #474747;
  opacity: 0.7;
  z-index: 77;
}

.modelTitle {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  text-align: center;
  line-height: 80rpx;
  border-bottom: 1rpx solid #f4f4f4;
  display: flex;
  flex-direction: row;
}

.menu_name {
  display: flex;
  flex-direction: row;
  margin-top: 20rpx;
  margin-left: 3%;
  width: 94%;
}

.menu_name text {
  font-size: 30rpx;

  font-weight: 900;
}

.menu_name input {
  font-size: 28rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  text-align: center;
  margin-left: 10rpx;
  border-radius: 14rpx;
  height: 40rpx;
  min-height: 40rpx;

  border: 0.5rpx solid #dadada;
}

.modelTitle1 {
  margin-top: 80rpx;
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  text-align: center;
  line-height: 80rpx;
  background: #009AA2;
  color: #ffffff;
  font-weight: 900;
  border-top: 1rpx solid #f4f4f4;
}

.model {
  position: fixed;
  top: 20%;
  left: 16%;
  width: 500rpx;
  background: #ffffff;
  z-index: 89;
}

.right {
  width: 90%;
  font-size: 26rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.oneline {
  display: flex;
}

.section {
  display: flex;
  height: 36rpx;
  border: #e5e5e5 solid 2rpx;
  border-radius: 10rpx;
  align-items: baseline;
  background: #fff;
}

.model1 {
  position: fixed;
  top: 20%;
  left: 15%;
  width: 70%;
  height: 675rpx;
  background: #ffffff;
  z-index: 89;
  display: flex;
  justify-content: center;
  align-items: center;
}


.top-head-right {
  width: 50rpx;
  height: 50rpx;
}

.btn-bar {
  display: flex;
  width: 100%;
}

.cancelBtn {
  margin: 0%;
  padding: 0;
  background-color: rgba(255, 60, 0, 0.76);
  width: 25%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #ffffff;
}

.confirmBtn {
  margin: 0%;
  padding: 0;
  background-color: #2bca52;
  width: 25%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: white;
}

.window {
  background-repeat: no-repeat;
  background-size: 100% 100%;
  -moz-background-size: 100% 100%;

  width: 94%;
  height: 37%;
  margin-top: 60%;
  background: white;
  border-radius: 15rpx;
}

.window-bg {
  position: fixed;
  left: 0px;
  top: 0px;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 88;
  display: flex;
  justify-content: center;
}

.window-item {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-evenly;
  align-items: center;
  align-items: center;
}

.window-item-content {
  font-size: 38rpx;
  /* 宋体 */
  font-family: SimSuncss;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
}

.window-item-title {
  font-size: 70rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
}