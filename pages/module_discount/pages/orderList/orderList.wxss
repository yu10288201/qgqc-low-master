.page {
  width: 100vw;
  height: 100vh;
  display: flex;
  /* justify-content: center; */
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/image/background_order_package.png") no-repeat;
  background-size: 100% 100%;
  flex-direction: column;
  align-items: center;
}

.navigation {
  display: flex;
  width: 96%;
  height: 200rpx;
  flex-direction: column;
  border-radius: 8rpx;
  background-color: rgb(255, 255, 252);
}

.icon {
  width: 75rpx;
  height: 75rpx;
}

.part4 {
  width: 100%;
  /* border: 2rpx solid gray; */
  margin: 10rpx 0rpx 0rpx 0rpx;
  border-radius: 10rpx;
}

.btn_big_green {
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/image/meal_buttom.png") no-repeat;
  background-size: 100% 100%;
  font-weight: bold;
  width: 80%;
  height: 100rpx;
  font-size: 36rpx;
  display: flex;
  justify-content: center;
  border-radius: 10rpx;
  color: white;
  padding-left: 0;
  padding-right: 0;
  margin-left: 0;
  margin-right: 0;
  line-height: 75rpx;
  margin-top: 15rpx;
  border: none;
}

.box {
  display: flex;
  justify-content: center;
  align-items: center;
}

.category {
  width: 100%;
  height: 60%;
  display: flex;
  align-items: center;
}

.listButton {
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/image/buttom_left_down.png") no-repeat;
  background-size: 100% 100%;
  line-height: 50rpx;
  width: 175rpx;
  font-size: 26rpx;
  height: 70rpx;
  border: none;
  color: #fff;
  border: 0;
  margin: 0;
}

.listButton_grey{
  background: grey;
  line-height: 50rpx;
  width: 175rpx;
  font-size: 26rpx;
  height: 58rpx;
  border: none;
  color: #fff;
  border: 0;
  border-radius: 28rpx;
  margin: 0;
}

.listButton2 {
  background: url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/image/buttom_right_down2.png") no-repeat;
  background-size: 100% 100%;
  line-height: 50rpx;
  width: 165rpx;
  font-size: 26rpx;
  height: 60rpx;
  border: none;
  color: #fff;
  border: 0;
  margin: 0;
  border-radius: 25rpx;
  margin-right: 5rpx;
  margin-top: 2rpx;
}

.categoryButton {
  /* background:url("https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/image/buttom_right_down.png") no-repeat;
  background-size: 100% 100%; */
  display: flex;
  flex-direction: row;
  justify-content: center;
  background-color: #4fa06e;
  line-height: 58rpx;
  width: 182rpx;
  font-size: 26rpx;
  height: 58rpx;
  border: none;
  color: #fff;

}

.categoryButton::after {
  border: none;
}

.listButton::after {
  border: none;
}

.listButton2::after {
  border: none;
}

.status {
  width: 100%;
  height: 40%;
  display: flex;
  justify-content: space-around;
}

.state {
  font-size: 28rpx;
  height: 50rpx;
  /* width: 125rpx; */
  display: flex;
  justify-content: center;
  color: green;
}

.ModuleOrder {
  display: flex;
  width: 100%;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.List {
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  border: 2rpx solid rgb(253, 227, 210);
  background-color: white;
  width: 96%;
  margin-left: 2%;
}

.List_left {
  margin-top: 80rpx;
  margin-left: 2%;
  width: 20%;
}

.List_left image {
  border-radius: 8rpx;
  width: 100%;
  height: 125rpx;
}

.List_right {
  display: flex;
  flex-direction: column;
  margin-top: 10rpx;
  margin-left: 4%;
  width: 72%;
}

.order_shop {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  width: 100%;
}

.order_shop text {
  font-size: 28rpx;
  color: #777777;
}

.order_shop image {
  margin-left: 2%;
  width: 26rpx;
  height: 26rpx;
}

.order_button {
  margin-bottom: 30rpx;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: right;
  width: 99%;
}

