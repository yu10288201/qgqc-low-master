  <!-- 获取手机号码 -->
  <view wx:if="{{showAuthorize}}" class='window-bg'>
    <view class='window' style="background-size:100% 100%;-moz-background-size:100% 100%;">
      <view class='window-item'>
        <view style="width:100%;height:10%;display: flex;flex-direction: column;justify-content: space-between;align-items: center;text-align: center;">
          <view style="font-size: 25px;width: 100%;font-weight: bolder;">申请授权</view>
        </view>
        <view class='window-item-content'><text style="text-align: center;">接收赠送需要获取您的手机号码\n是否同意?</text></view>
        <view class='btn-bar' style="width: 100%;display: flex;flex-direction: row;justify-content: space-evenly;align-items: center;">
          <button class='cancelBtn' bindtap='refused'>否</button>
          <button class='confirmBtn' open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">是</button>
        </view>
      </view>
    </view>
  </view>

</view>


