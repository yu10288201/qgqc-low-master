.shopName{
  height: 55rpx;
  width: 100%;
  background-color: #F3F3F3;
  margin-bottom: 10rpx;
  
}

.shopName text{
  color: red; 
  font-weight: bold;
  margin-left: 10rpx;
  font-size: 32rpx;
}

.ad_popError{ 
  background: #de352d;
  color: #fff;
  height: 58rpx; line-height: 58rpx;
  font-size: 32rpx;
  width:100%;
  display: flex;
  justify-content: center;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  }

.tapPick{
  height: 200rpx;
  width: 95%;
  margin-bottom: 10rpx;
  display: -webkit-flex;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  padding-bottom: 10rpx;
  border-top:4rpx solid #AAAAAA;
  border-bottom:4rpx solid #AAAAAA;
}

.tapPick .title{
  height:40rpx;
  width:100%;
  font-size:30rpx;
  margin-left: 20rpx;
}

