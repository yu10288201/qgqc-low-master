<view style="width: 100vw;height: 100vh;display: flex;flex-direction: column;align-items: center;background-color: #f7f7f7;">
  <view style="width: 100%;position: relative;font-weight: bold;display: flex;justify-content: center;align-items: center;padding: 20rpx 0;background-color: white;">
    <view style="font-size: 40rpx;">选择收货地址</view>
  </view>

  <scroll-view wx:if="{{addressList.length > 0}}" scroll-y="ture" style="height: 80%;display: flex;flex-direction: column;">
    <view style="width: 100%;display: flex;flex-direction: column;" wx:for="{{addressList}}">
      <view style="width: 100%;padding: 30rpx 0;background-color: white;display: flex;justify-content: center;">
        <view style="width: 78%;display: flex;flex-direction: column;padding-right: 20rpx;" bindtap="navigateBack" data-item="{{item}}">
          <view style="display: flex;align-items: center;">
            <view wx:if="{{item.labelType != 0}}" class="label color">{{item.labelType == 1 ? '家' : item.labelType == 2 ? '公司' : '学校'}}</view>
            <view style="font-weight: bolder;">{{item.address}}</view>
          </view>
          <view style="margin-top: 20rpx;font-size: 28rpx;">{{item.contacts}}({{item.sex == 1 ? '男士' : '女士'}}) {{item.phone}}</view>
        </view>

        <view style="display: flex;justify-content: center;align-items: center;">
          <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/qgqc/edit.png" style="width: 60rpx;height: 60rpx;" bindtap="toAddZone" data-index="2" data-item="{{item}}"></image>
        </view>
      </view>
      <view style="width: 100%;height: 1rpx;transform: scaleY(0.3);background-color: gray;"></view>
    </view>
  </scroll-view>

  <view wx:else style="width: 100%;height: 80%;display: flex;justify-content: center;align-items: center;">
    <view style="display: flex;flex-direction: column;justify-content: center;align-items: center;">
      <image src="https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/qgqc/map.png" style="width: 260rpx;height: 248rpx;"></image>
      <view style="color: gray;">没有收货地址</view>
      <view style="font-size: 24rpx;color: gray;margin-top: 8rpx;">点击下方按钮新增</view>
    </view>
  </view>

</view>

<view style="position: fixed;bottom: 0;width: 100%;height: 8%;display: flex;justify-content: center;">
  <view style="width: 80%;height: 70rpx;line-height: 70rpx;background-color: #009aa2;color: white;text-align: center;border-radius: 40rpx;font-size: 34rpx;" bindtap="toAddZone" data-index="1">新增收货地址</view>
</view>