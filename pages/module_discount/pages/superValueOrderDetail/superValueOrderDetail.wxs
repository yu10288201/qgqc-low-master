  //   var b = ''
  //   if((val1 == null || val1 == undefined || val1 == '') && (val2 == null || val2 == undefined || val1 == '')){
  //     return '';
  //   }
  //   val1 = Number(val1)
  //   val2 = Number(val2)
  //   switch(val1){
  //     case 1: a = '一'; break;
  //     case 2: a = '二'; break;
  //     case 3: a = '三'; break;
  //     case 4: a = '四'; break;
  //     case 5: a = '五'; break;
  //     case 6: a = '六'; break;
  //     case 7: a = '日'; break;
  //     default: a = ''; break;
  //   }
  //   switch(val2){
  //     case 1: b = '一'; break;
  //     case 2: b = '二'; break;
  //     case 3: b = '三'; break;
  //     case 4: b = '四'; break;
  //     case 5: b = '五'; break;
  //     case 6: b = '六'; break;
  //     case 7: b = '日'; break;
  //     default: b = ''; break;
  //   }
  //   return '周' + a + '至周' + b + '可用'
  },
}
module.exports = {
  formatDate: filters.formatDate,
  toFix: filters.toFix,
  usefulDate: filters.usefulDate,
  usefulWeek: filters.usefulWeek,
}