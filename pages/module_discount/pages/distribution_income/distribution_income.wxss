input{
  width: 300rpx;
  height: 48rpx;
  border: 1rpx solid rgba(153, 106, 62, 0.281);
  border-radius: 22rpx;
}

picker{
  width: 300rpx;
  height: 48rpx;
  border: 1rpx solid rgba(153, 106, 62, 0.281);
  border-radius: 22rpx;
}

.return_out {
  position: fixed;
  top: 40px;
  left: 5px;
  width: 75rpx;
  height: 75rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.return {
  width: 17rpx;
  height: 31rpx;
}

.top {
  background: url(https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/weixinpay/bg3.png) no-repeat;
  background-size: 100% 100%;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.comtainer {
  border-radius: 10rpx;
  width: 95%;
  /* background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/weixinpay/bg4.png') no-repeat; */
  /* background-size: 100% 100%; */
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 30rpx;
}

.tbody{
  width: 95%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.th{
  display: flex;
  justify-content: center;
  height: 66rpx;
  line-height: 66rpx;
  border: 1px solid black;
  border-right: 0;
  font-size: 30rpx;
}

.th:last-child{
  border-right: 1px solid black;
}

.td{
  display: flex;
  justify-content: center;
  height: 66rpx;
  line-height: 66rpx;
  border-left: 1px solid black;
  border-bottom: 1px solid black;
  border-right: 0;
  font-size: 30rpx;
}

.td:last-child{
  border-right: 1px solid black;
}

.popup-window-bg {
  position: fixed;
  left: 0rpx;
  top: 0rpx;
  width: 100%;
  height: 100%;
  /* background: rgba(0, 0, 0, 0.5); */
  z-index: 997;
  display: flex;
  justify-content: center;
}

.popup-window {
  background: white;
  position: fixed;
  /* height: 88%; */
  height: 50%;
  top: 20%;
  left: 4%;
  width: 92%;
  z-index: 998;
  border-radius: 5%;
  display: flex;
  flex-direction: column;
  justify-content: space-around;

}

.queryButton{
  position:absolute;
  right: 30rpx;
  height: 60rpx;
  width: 140rpx;
  background: url(https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/切瓜切菜/weixinpay/btn2.png);
  background-size: 100% 100%;
  font-size: 30rpx;
  font-weight: 500;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50rpx;
  border: 0rpx;
  padding-bottom: 10rpx;
}

.query{
  display: flex;
  width: 100%;
  height: auto;
  margin-top: 5rpx;
}