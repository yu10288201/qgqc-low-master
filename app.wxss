/**app.wxss**/

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

.go-center {
  display: flex;
  justify-content: center;
}

.down-center {
  display: flex;
  align-items: center;
}

.oneline {
  display: flex;
}

.allcenter {
  display: flex;
  justify-content: center;
  align-items: center;
}

.hide {
  display: none;
}

.show {
  display: block;
}

@font-face {
  font-family: 'iconfont';
  src: url(data:application/font-woff;charset=utf-8;base64,) format('woff'),
         url('iconfont.ttf') format('truetype');
  font-weight: normal;
  font-style: normal;
}

.iconfont {
  font-family: "iconfont" !important;
  font-size: 16px;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.icon-icon:before {
  content: "\e610";
}

.icon-youhuiquan:before {
  content: "\e61e";
}

.icon-lajitong:before {
  content: "\e61b";
}

.icon-jiahao2fill:before {
  content: "\e728";
}

.icon-gouwuchefill:before {
  content: "\e73c";
}

.icon-xiangshangjiantou:before {
  content: "\e601";
}

.icon-jian:before {
  content: "\e61a";
}

.icon-xiangxiajiantou:before {
  content: "\e74b";
}

.icon-dingdan:before {
  content: "\e609";
}

.icon-shouye:before {
  content: "\e620";
}

.icon-wode:before {
  content: "\e61f";
}

.icon-dingwei:before {
  content: "\e7cd";
}

.icon-shouji:before {
  content: "\e666";
}

/* 呼叫弹窗 */

/* *************************** */

.hiddenvieww {
  position: fixed;
  left: 0px;
  top: 0px;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  justify-content: center;
}

.hiddenview2w {
  background-color: white;
  position: fixed;
  top: 20%;
  left: 14%;
  width: 550rpx;
  height: 550rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.exitw {
  height: 5%;
}

.exitTablew {

  position: absolute;
  top: 11rpx;
  right: 11rpx;
  color: #fff;
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  z-index: 2;
  line-height: 40rpx;
  text-align: center;
  background-color: #f00;
  font-size: 40rpx;
  padding-bottom: 5rpx;
}

.shopTypeListw {
  display: flex;
  height: 60rpx;
}

.shopTypeItemsw {
  display: flex;
  align-items: center;
  /* flex-direction: column-reverse; */
  justify-content: center;
  height: 100%;
  width: 30%;
}

.shopTypeItemsValuew {
  font-size: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 70%;
}

checkboxw .wx-checkbox-input {
  width: 30rpx;
  height: 30rpx;
}

.nablaw {
  font-size: 26rpx;
  color: rgb(175, 169, 169);
  border-top-right-radius: 10rpx;
  border-bottom-right-radius: 10rpx;
  border-right: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  margin-right: 10rpx;
  height: 30rpx;
  line-height: 30rpx;
  min-height: 30rpx;
}

.shopTypeInput1w {
  border-top-left-radius: 10rpx;
  border-bottom-left-radius: 10rpx;
  border-left: 2rpx solid #d6d6d6;
  border-top: 2rpx solid #d6d6d6;
  border-bottom: 2rpx solid #d6d6d6;
  display: flex;
  justify-content: center;
  /* height: 50rpx; */
  padding: 2rpx;
  font-size: 26rpx;
  text-align: center;
  align-items: baseline;
  width: 100%;
  height: 26rpx;
  line-height: 26rpx;
  min-height: 26rpx;
}

.shopTypeInput2w {
  font-size: 30rpx;
  border-radius: 15rpx;
  border: 2rpx solid #d6d6d6;
  text-align: center;
  width: 390rpx;
}

.shopTypeLeftw {
  display: flex;
  justify-content: flex-end;
  width: 32%;
}

.shopTypeRightw {
  display: flex;
  width: 68%;
}

.divw {
  display: flex;
  margin-bottom: 10rpx;
}

.onelinew {
  flex-wrap: nowrap;
  display: flex;
  margin-top: 5rpx;
}

.btnw {
  width: 160rpx;
  background: #fcaf17;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 10rpx;
  font-size: 26rpx;
  height: 40rpx;
  color: white;
  padding-left: 0;
  padding-right: 0;
  margin-right: 0;
  margin-left: 0;
  font-weight: bold;
  /* border: 0.1rpx solid #e9e6e6; */
}
