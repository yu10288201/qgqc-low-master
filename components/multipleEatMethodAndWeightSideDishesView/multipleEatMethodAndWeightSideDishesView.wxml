<!--components/sideDishesView/sideDishesView.wxml-->
<!-- 这个是之前封装好，避免浪费，决定两用。一个是弹窗，一个是列表 -->
<!-- 列表形式 -->
<view class='box_table1' wx:if="{{isTable}}">
  <!-- <view
    style="width: 100%;border: #e4e4e4 solid 2rpx;height:15%;border-left: black solid 2rpx;border-right: black solid 2rpx;"> -->
    <view
    style="width: 100%;height:20%;border-left: black solid 2rpx;border-right: black solid 2rpx;">
    <view class="tr1">
      <view class="td1">配菜名称</view>
      <view class="td1" style='width: 20%;'>单价</view>
      <view class="td1" style="width: 20%;">数量</view>
      <view class="td1" style="width: 20%;">金额</view>
    </view>
  </view>
  <scroll-view style='height: 80%;text-align: center;' scroll-y="true">
    <view style="width:100%;" wx:if="{{SideDishList_choose.length!=0}}">
      <checkbox-group bindchange="checkboxChange">
        <view wx:for="{{SideDishList_choose}}" wx:key="index" wx:for-item="item" wx:for-index="index">
          <!-- <view class='down-center' style='border-bottom:#ddd solid 2rpx;height: 60rpx;'> -->
          <view class='down-center' style='height: 15%;'>
            <view class="td1">{{item.sideDishName || item.side_dish_name}}</view>
            <view class='td1' style="width: 20%;">{{item.sideDishdPrice? (item.sideDishdPrice * 0.01):item.side_dish_price}}</view>
            <view class="td1" style="width: 20%;">{{item.orderDetailedNum ? item.orderDetailedNum:item.side_dish_number}}</view>
            <view class="td1" style="width: 20%;">{{item.sideDishdPrice?(item.sideDishdPrice * 0.01 * item.orderDetailedNum):item.side_dish_subtotal}}</view>
          </view>
        </view>
      </checkbox-group>
    </view>
    <view wx:if="{{SideDishList_choose.length==0}}" style="height: 100%;width: 100%;">
      <view style="height: 100%;width: 100%;justify-content: center;align-items: center;display: flex;color:#888">
        <view>--未选择配菜--</view>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 弹窗形式 -->
<view class="container" wx:if="{{!isTable}}">
    <view class="container-top" style="height:10%;">
      <text style="height: 60rpx;width: 300rpx;float: left;margin-left: 20rpx;">{{dishesInfo.dishes_name}}</text>
      <image style='width:60rpx;height:60rpx;float:right' src='{{i_close_img_url}}' bindtap='showpeicai'></image>
      <!-- <text wx:if="{{dishesInfo.spec_type!= 9&&spec_type!=1}}" style="text-align: right;width: 300rpx;position: absolute;top: 70rpx;font-weight: normal;right: 100rpx;">{{eatMethodArray[eatMethodChooseIndex].em_name + " " + eatMethodArray[eatMethodChooseIndex].eating_method}}</text> -->
      <text wx:if="{{dishesInfo.spec_type == 9 || dishesInfo.spec_type == 91}}"></text>
      <text wx:else style="text-align: right;width: 300rpx;position: absolute;top: 70rpx;font-weight: normal;right: 100rpx;">{{eatMethodArray[eatMethodChooseIndex].em_name + " " + eatMethodArray[eatMethodChooseIndex].eating_method}}</text>
      <text wx:if="{{spec_type==1}}" style="text-align: right;width: 300rpx;position: absolute;top: 70rpx;font-weight: normal;right: 100rpx;">配菜和口味</text>
	  
      <!-- <text wx:else style="text-align: right;width: 300rpx;position: absolute;top: 70rpx;font-weight: normal;right: 100rpx;">{{eatMethodArray[eamChoose].em_name + " " + eatMethodArray[eamChoose].eating_method}}</text> -->
    </view>
    <view class="container-mid" style="height:80%;">
      <scroll-view scroll-y='true' class="scroll-part" style="display:flex;">
        <!-- <view style='height:1800rpx;width:100%;'> -->
        <view style='height:960rpx;width:100%;'>
          <!-- 这个配菜列表-->
          <view class="container-table" style='height: 100%;'>
            <view wx:if="{{SideDishList != null && SideDishList.length!=0}}" style="height:33%;border-top: 1rpx solid black;border-bottom: 1rpx solid black;">
              <!-- 2020-11-17 去掉文字-->
              <!-- <text style='height:20%;'>选择配菜</text> -->
              <scroll-view scroll-y='true' class="scroll-part1" style='height:100%;'>
                <radio-group  name="peicai">
                  <label style="width:30%;display: inline-block;margin:10rpx 10rpx" wx:for="{{SideDishList}}"
                    wx:key="index">
                    <button data-index="{{index}}" bindtap="chooseSideDish"
                      class="hallcheckbox {{item.checked ? 'yerrow_background':'grey_background'}}" value="{{item}}"
                      style="{{item.checked ? 'color:#000':'color:#fff'}};display: flex;flex-direction: row;">
                      <text class="red_dot" wx:if="{{sideDishIndex==index && item.checked}}">●</text>
                      <view class="asd">{{item.sideDishName}}</view>
                      <text class="number" wx:if="{{item.orderDetailedNum!=0}}">{{item.orderDetailedNum}}</text>
                      <text class="price">{{item.sideDishdPrice*0.01}}</text>
                    </button>
                  </label>
                </radio-group>

                <!-- <view class="modal-textarea" style="height: 100%;width: 100%;" wx:else>
                  <view style="height: 100%;width: 100%;justify-content: center;align-items: center;display: flex;">
                    <view>--未设置配菜--</view>
                  </view>
                </view> -->
              </scroll-view>
            </view>
            <!-- 口味列表-->
            <!-- <view style="height:{{SideDishList.length!=0?'33%':'43%'}};border-top: 1rpx solid black;border-bottom: 1rpx solid black;"> -->
            <view style="height:{{SideDishList != null && SideDishList.length!=0?'67%':'100%'}};border-top: 1rpx solid black;border-bottom: 1rpx solid black;">
              <!-- <view style='height:10%;display: flex;align-items: center;'><text>选择口味</text></view> -->
              <scroll-view scroll-y='true' class="scroll-part1" style='height:100%;'>
                <radio-group wx:if="{{tasteList.length!=0}}" name="kouwei">
                  <label style="width:21%;display: inline-block;margin:10rpx 10rpx" wx:for="{{tasteList}}"
                    wx:key="index" data-index="{{index}}" bindtap="chooseTaste" value="{{item.value}}">
                    <button class="hallcheckbox {{item.checked ? 'yerrow_background':'pink_background'}}"
                      style="{{item.checked ? 'color:#000':'color:#fff'}}">
                      <view class="asd">{{item.value}}</view>
                    </button>
                  </label>
                </radio-group>

                <view class="modal-textarea" style="height: 100%;width: 100%;" wx:else>
                  <view style="height: 100%;width: 100%;justify-content: center;align-items: center;display: flex;">
                    <view>--未设置常用口味--</view>
                  </view>
                </view>
              </scroll-view>
            </view>

            <!-- 常用备注列表-->
            <!-- <view style="height:{{SideDishList.length!=0?'33%':'43%'}};border-top: 1rpx solid black;border-bottom: 1rpx solid black;">
              <text style='height:20%;'>选择备注</text>
              <scroll-view scroll-y='true' class="scroll-part1" style='height:80%;'>
                <radio-group wx:if="{{quickRemarkList.length!=0}}" name="beizhu">
                  <label style="width:21%;display: inline-block;margin:10rpx 10rpx" wx:for="{{quickRemarkList}}"
                    wx:key="index" data-index="{{index}}" bindtap="chooseRemark" value="{{item.value}}">
                    <button class="hallcheckbox {{item.checked ? 'yerrow_background':'green_background'}}"
                      style="{{item.checked ? 'color:#000':'color:#fff'}}">
                      <view class="asd">{{item.value}}</view>
                    </button>
                  </label>
                </radio-group>
                <view class="modal-textarea" style="height: 100%;width: 100%;" wx:else>
                  <view style="height: 100%;width: 100%;justify-content: center;align-items: center;display: flex;">
                    <view>--未设置常用备注--</view>
                  </view>
                </view>
              </scroll-view>
            </view> -->
          </view>
          <!-- <view class='container' style='height: 20%;margin:0rpx;width:100%;'>
            <view class="container-top1">
              <text>客人备注：</text>
            </view>
            <view class="container-bottom1">
              <view class='textarea'>
                <view wx:if="{{eatMethodTastesRemark!=''}}"
                  style="height:20%;width:100%;background:#e5e5e5;font-size:26rpx">
                  <text>口味：{{eatMethodTastesRemark}}</text>
                </view>
                <text fixed name="remark" wx:if="{{onHide}}" value='{{eatMethodRemark}}' class="note-text" data-type="0"
                  bindinput='remarks' style="height:{{eatMethodRemark!=''?80:100}}%;width:100%"></text>
                <textarea name="remark" fixed wx:else value='{{eatMethodRemark}}' class="note-text" data-type="0"
                  bindinput='remarks' style="height:{{eatMethodRemark!=''?80:100}}%;width:100%"></textarea>
              </view>
            </view>
          </view> -->
        </view>
      </scroll-view>
    </view>
    <view class="container-bottom" style="height:10%;">
      <view class='down-center' style="justify-content:space-between;width: 200rpx;display:{{SideDishList != null && SideDishList.length!=0?'':'none'}}">
        <i class="iconfont icon-jian plus-icon-off" style="color:{{orderDetailedNum==0?'':'#ff9c35'}};font-size: 30px;"
          data-type="0" bindtap="addOReduce"></i>
        <view class='oneline'>
          <view class='menucount' style="color:{{items.item_type==2?'green':''}}" bindtap="reduce">{{SideDishList[sideDishIndex].orderDetailedNum}}
          </view>
        </view>
        <i class="iconfont icon-jiahao2fill plus-icon-on" style="color:#ff9c35;font-size: 30px;" data-type="1"
          bindtap="addOReduce"></i>
      </view>
      <!-- 2020-11-18 来料加工增加取消选择配菜按钮-->
      <button class="btn_mid_y" bindtap="cancelSideDish" style="height:50rpx;line-height: 50rpx;display:{{SideDishList[sideDishIndex].checked?'':'none'}}">取消选择</button>
      <button class="btn_mid_y" bindtap="submitSideDish" style="height:50rpx;line-height: 50rpx;">确定</button>
    </view>
</view>