
<view class='window-bg' wx:if="{{isShow}}">
  <view class='window' style="background-size:100% 100%;-moz-background-size:100% 100%;">
    <view class='window-item'>
      <view style="width:100%;height:10%;display: flex;flex-direction: column;justify-content: space-between;align-items: center;text-align: center;">
        <view style="font-size: 25px;width: 100%;font-weight: bolder;">申请授权</view>
      </view>
      <view class='window-item-content'><text style="text-align: center;">请获取您的头像和名称</text></view>
      <button class="btgeta" style="width: 150rpx;height: 150rpx;border-radius: 50%;padding: 0;border: 1rpx #777 solid;display: flex;justify-content: center;align-items: center;flex-direction: column;" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <text class="window-item-content" style="font-size: 28rpx;" wx:if="{{!avatarUrl}}">获取头像</text>
        <image src="{{avatarUrl}}" style="width: 150rpx;height: 150rpx;" wx:else />
      </button>
      <view class='window-item-content'>
        <mp-form>
          <mp-cells>
            <mp-cell title="昵称" style="display: flex;justify-content: center;align-items: center;">
              <text>昵称:</text>
              <input type="nickname" class="weui-input" style="border: 1rpx #999 solid;text-align: center;border-radius:20rpx;color: #000;margin-left: 20rpx;width: 50%;" placeholder="请输入昵称" model:value="{{nickName}}" />
            </mp-cell>
          </mp-cells>
        </mp-form>
      </view>

      <view class='btn-bar' style="width: 100%;display: flex;flex-direction: row;justify-content: space-evenly;align-items: center;">
        <button class='cancelBtn' bindtap='refused'>否</button>
        <button class='confirmBtn' bindtap="getUserInfo">是</button>
      </view>
    </view>
  </view>
</view>