/* pages/testpopup/testpopup.wxss */
@import "../../app.wxss";
.page{
  background-size: 100% 100%;
  overflow:hidden;
  position:fixed;
  margin: 0px;
  width: 100%;
  height: 100%;
  /* background-color: #CEFBE8; */
}

.popupView{
  display: flex;
  flex-direction: column;
  z-index: 1000;
  font-size: 26rpx;
}

.popupView-window {
  background: white;
  position: fixed;
  z-index: 1000;
  width: 100%;
  height: 100%;
}

.container {
  width: 94%;
  height: 1200rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  border: 1px solid #000;
  padding:0;
  margin: 10px;
}

.container-top {
  font-size: 32rpx;
  width: 100%;
  height: 7%;
  /* align-items: center;
  justify-content: center;
  display: flex; */
  font-weight: bold; 
  
}

.container-table {
  width: 100%;
  height: 80%;
}

.scroll-part{
  width:100%;
  height:100%;
  border-top: 1rpx solid black;
  border-bottom: 1rpx solid black;
  display:flex;
  justify-content: space-between;
  flex-direction: row;
  flex-wrap: wrap;
  padding-left: 2%;
  padding-top: 2%;
  padding-bottom: 2%;
}

.hallcheckbox {
  height: 70rpx;
  line-height: 70rpx;
  font-size: 27rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0rpx;
  flex-direction: column;
  box-shadow: 6rpx 6rpx 12rpx 6rpx #D3D3D3;
}

.red_background {
  background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/orderDirectly/red.png');
  background-size: 100% 100%;
}

.yerrow_background {
  /* background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/orderDirectly/yerrow.png');
  background-size: 100% 100%; */
  background-color: rgb(255, 255, 65);
}

.green_background {
  /* background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/orderDirectly/green.png');
  background-size: 100% 100%; */
  background-color: rgb(94, 181, 129);
}

.pink_background {
  background-color: rgb(203,106,104);
}

.asd{
  font-size:28rpx;
}

.container-bottom{
  width: 100%;
  height: 10%;
  align-items: center;
  justify-content: center;
  display: flex;
}


