<view class="container">
  <view class="container-top">
    <text style="height: 60rpx;width: 300rpx;float: left;margin-left: 20rpx;">{{dishesInfo.dishes_name}}</text>
    <image style='width:60rpx;height:60rpx;float:right' src='{{i_close_img_url}}' bindtap='closeTaste'></image>
    <text style="width: 140rpx;position: absolute;top: 70rpx;font-weight: normal;right: 100rpx;">常用口味</text>
  </view>
  <!-- 列表-->
  <view class="container-table">
    <form style='width:100%;height:100%'>
      <scroll-view scroll-y='true' class="scroll-part">
        <radio-group wx:if="{{tasteList.length!=0}}">
          <label style="width:21%;display: inline-block;margin:10rpx 10rpx" wx:for="{{tasteList}}" wx:key="index" data-index="{{index}}" bindtap="chooseTaste">
            <button class="hallcheckbox {{item.checked ? 'yerrow_background':'pink_background'}}" style="{{item.checked ? 'color:#000':'color:#fff'}}">
              <view class="asd">{{item.value}}</view>
            </button>
          </label>
        </radio-group>

        <view class="modal-textarea" style="height: 100%;width: 100%;" wx:else>
          <view style="height: 100%;width: 100%;justify-content: center;align-items: center;display: flex;">
            <view>--未设置常用口味--</view>
          </view>
        </view>
      </scroll-view>
    </form>
  </view>
  <view class="container-bottom"> 
    <button class="btn_mid_y" bindtap="submitTaste" style="height:50rpx;line-height: 50rpx;">确定</button>
  </view>
</view>