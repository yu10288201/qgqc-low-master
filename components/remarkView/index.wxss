.container {
  width: 100%;
  height: 250rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  /* margin: 10px 10px 0px 10px; */
  border: 2rpx solid #888;
  font-size: 28rpx;
}

.container-top {
  height: 25%;
  margin-left: 10px;
  font-weight:bold;
  font-size:30rpx;
  justify-content: space-between;
  align-items: center;
  display: flex;
}

.container-bottom {
  height: 75%;
  width: 100%;
  font-size: 28rpx;
  background-color: #e5e5e5;
}

/* 2020-11-10*/
.container-bottom2 {
  padding-top:7px;
  height: 70%;
  width: 100%;
  font-size: 28rpx;
  background-color: #e5e5e5;
}

.container-bottom .placeholder-textarea{
  font-size: 28rpx;
  color: #ACACAC;
}

.textarea {
  background: #e5e5e5;
  height:100%;
  width:100%
}

.note-text {
  width: 100%;
  font-size: 26rpx;
  background: #e5e5e5;
  height: 100rpx;
}
