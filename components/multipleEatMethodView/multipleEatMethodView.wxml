	<view style="display:flex;flex-direction: column;height: 90%;width: 100%;">
		<view class="container-top" style="height: {{ isType10 ? 70 : filters.toFix(em_arry.length) }}rpx;display: inline-block;">
			<view style="width:100%;height: 60rpx;">
				<text style="margin-left: 40%;">{{dishesInfo.dishes_name}}</text>
				<image style='width:60rpx;height:100%;float:right' src='{{i_close_img_url}}' bindtap="{{isType10 ? 'showMultipleEatAndSpecView' :'showMultipleEatMethodView'}}"></image>
			</view>
			<view style="width:100%;height:{{filters.toFix1(em_arry.length)}}rpx;flex-wrap: wrap;display: flex;" wx:if="{{!isType10}}">
				<view wx:for="{{em_arry}}" wx:key="index" wx:item="item" style="width:33%;align-items: center;display: flex;justify-content: center;">
					<button wx:if="{{item[0].em_name!='剩余部位'}}" class="btn_mid {{partsName[index].checked||partIndex==index?'green':'yellow'}}" style="box-shadow: 6rpx 6rpx 12rpx 6rpx rgb(141, 150, 147);" data-index="{{index}}" bindtap="switchPart">
						<text class="red_dot"  wx:if="{{partIndex==index}}">●</text>
						<text style="height: 100%;width: 100%;">{{item[0].em_name}}</text>
					</button>
					<button wx:elif="{{item[0].em_name=='剩余部位'}}" class="btn_mid {{canRemain?(partsName[index].checked||partIndex==index?'green':'yellow'):'gray'}}" disabled="{{!canRemain}}" style="box-shadow: 6rpx 6rpx 12rpx 6rpx rgb(141, 150, 147);" data-index="{{index}}" bindtap="switchPart">
						<text class="red_dot"  wx:if="{{partIndex==index}}">●</text>
						<text style="height: 100%;width: 100%;">{{item[0].em_name}}</text>
					</button>
				</view>
			</view>
			<!-- 多规格多做法头部显示 -->
			<!-- <view style="width:100%;height:{{filters.toFix1(em_arry.length)}}rpx;flex-wrap: wrap;display: flex;" wx:if="{{isType10}}">
				<view style="width:68%;align-items: center;display: flex;justify-content: flex-start;">

					<button wx:if="{{eatMethodIndex!=-1}}" class="btn_mid {{partsName[index].checked||partIndex==index?'green':'yellow'}}" style="box-shadow: 6rpx 6rpx 12rpx 6rpx rgb(141, 150, 147);">
						<text class="red_dot"  wx:if="{{partIndex==index}}">●</text>
						<text style="height: 100%;width: 100%;">{{showChooseEatMethod}}</text>
					</button>
