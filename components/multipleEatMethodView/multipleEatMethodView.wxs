var filters = {
  toFix: function (len) {
    return len != null && len != '' && len > 0 ? (Math.ceil(len / 3) + 1) * 70 + 30 : 70
  },
  toFix1: function (len) {
    return len != 0 ? len >= 3 ? (Math.ceil(len / 3) + 1) * 60 : 60 : 0
  },
  indexOf: function (arr, value) {
    if (arr.indexOf(value) < 0) {
      return false;
    } else {
      return true;
    }
  }
}

module.exports = {
  toFix: filters.indexOf,
  toFix: filters.toFix,
  toFix1: filters.toFix1,
}