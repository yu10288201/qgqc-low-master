var filters = {
    toHeight: function (len1,len2) {
        var len = len1 + len2;
        if(len1 != null && len2 != null && len1 != 0 && len2 != 0){
            return true;
        }else if(len != null && len != '' && len > 0){
            if(Math.ceil((len +4)/ 40) > 1){
                return true;
            }
        }
        return false;
    },
}

module.exports = {
    toHeight: filters.toHeight,
}