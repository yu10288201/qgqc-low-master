.window {
  background-repeat: no-repeat;
  background-size: 100% 100%;
  -moz-background-size: 100% 100%;

  width: 94%;
  height: 37%;
  background: white;
  border-radius: 15rpx;
}

.window-bg {
  position: fixed;
  left: 0px;
  top: 0px;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.window-item {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-evenly;
  align-items: center;
  align-items: center;
}

.window-item-content {
  font-size: 38rpx;
  /* 宋体 */
  font-family: SimSuncss;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
}

.btgeta::after{
  border: none;
}

.window-item-title {
  font-size: 70rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
}


.cancelBtn {
  margin: 0%;
  padding: 0;
  background-color: rgba(200, 200, 200, 0.76);
  width: 25%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #ffffff;
}

.confirmBtn {
  margin: 0%;
  padding: 0;
  background-color: #2bca52;
  width: 25%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: white;
}

