@import "../../app.wxss";
.page{
  background-size: 100% 100%;
  overflow:hidden;
  position:fixed;
  margin: 0px;
  width: 100%;
  height: 100%;
}

.container1 {
  width: 100%;
  height: 100%;
  padding: 0rpx;
  display: flex;
  flex-direction: column;
  /* justify-content: center; */
  border: 2rpx solid #888;
}
.container2 {
  width: 100%;
  height: 30%;
  padding: 0rpx;
  display: flex;
  flex-direction: column;
  /* justify-content: center; */
  border: 2rpx solid #888;
}
.container-top {
  margin: 5px 10px 0px 10px;
  font-size: 26rpx;
}
.container-table {
  /* margin: 0px 10px 0px 10px; */
}

.table1 {
  /* border-right: #e4e4e4 solid 2rpx; */
  z-index: 10;
}
 
.tr1 {
  display: flex;
  width: 100%;
  justify-content: center;
  height: 50rpx;
}

.td1 {
  width: 40%;
  display: flex;
  justify-content: center;
  align-items: center;
  border-left: #e4e4e4 solid 2rpx;
  border-bottom: #e4e4e4 solid 2rpx;  
  font-size: 24rpx;
  height: 44rpx;
}

.container-select{
  /* margin-left: 10px;
  margin-right: 10px; */
}

.down-center {
  display: flex;
  align-items: center;
}

.oneline {
  flex-wrap: nowrap;
  display: flex;
  align-content: center;
  top: 0;
  left: 0;
}

.radio {
  width: 35rpx;
  height: 35rpx;
}

.input-text {
  text-align:center;
  vertical-align:middle;
  flex-wrap: nowrap;
  border: 1px solid #000;
}

.price{
  position: absolute;
  right: 8%;
  top: 35%;

}

/* 以下是弹窗的样式 */


.container-view {
  width: 94%;
  height: 1200rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  border: 1px solid #000;
  padding:0;
  margin: 10px;
}

.container-view-top {
  font-size: 32rpx;
  width: 100%;
  height: 7%;
  font-weight: bold; 
  
}

.container-view-table {
  width: 100%;
  height: 80%;
}

.scroll-part{
  width:100%;
  height:100%;
  border-top: 1rpx solid black;
  border-bottom: 1rpx solid black;
  display:flex;
  justify-content: space-between;
  flex-direction: row;
  flex-wrap: wrap;
  padding-left: 2%;
  padding-top: 2%;
  padding-bottom: 2%;
}

.hallcheckbox {
  height: 80rpx;
  line-height: 70rpx;
  font-size: 27rpx;
  display: flex;
  /* justify-content: center;
  align-items: center; */
  padding: 0rpx;
  flex-direction: column;
  box-shadow: 6rpx 6rpx 12rpx 6rpx #D3D3D3;
}

.red_background {
  background: url('https://smp-south-china.oss-cn-shenzhen.aliyuncs.com/zsfiles/IMG/膳食掌柜/orderDirectly/red.png');
  background-size: 100% 100%;
}

.yerrow_background {
  background-color: rgb(255, 255, 65);
}

.green_background {
  background-color: rgb(94, 181, 129);
}

.asd{
  font-size:28rpx;
}

.container-view-bottom{
  width: 100%;
  height: 10%;
  align-items: center;
  justify-content: center;
  display: flex;
}


